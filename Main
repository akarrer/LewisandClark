# ═══════════════════════════════════════════════════════════════════════════════
#  GAME STATE
# ═══════════════════════════════════════════════════════════════════════════════
@dataclass
class GameState:
    current_wp:           int  = 0
    food:                 int  = 80
    health:               int  = 100
    morale:               int  = 75
    current_month:        int  = 5
    current_year:         int  = 1804
    journal:              List[str] = field(default_factory=list)
    completed_objectives: List[int] = field(default_factory=list)
    tribe_relations:      Dict      = field(default_factory=dict)
    inventory:            Dict      = field(default_factory=dict)
    characters:           Dict      = field(default_factory=dict)
    discoveries:          int  = 0
    peaceful_tribes:      int  = 0
    traded_tribes:        List[str] = field(default_factory=list)
    route_taken:          List[str] = field(default_factory=list)
    events_seen:          List[str] = field(default_factory=list)
    game_over:            bool = False
    victory:              bool = False

    def __post_init__(self):
        if not self.tribe_relations:
            self.tribe_relations = {k: v["relation"] for k,v in TRIBES.items()}
        if not self.inventory:
            self.inventory = copy.copy(STARTING_INVENTORY)
        if not self.characters:
            self.characters = copy.deepcopy(SPECIAL_CHARACTERS)

    @property
    def season(self): return get_season(self.current_month)

    @property
    def date_str(self):
        M=["","January","February","March","April","May","June","July",
           "August","September","October","November","December"]
        return f"{M[self.current_month]} {self.current_year}"

    def advance_date(self, days=14):
        self.current_month += 1
        if self.current_month > 12:
            self.current_month = 1; self.current_year += 1

    def add_journal(self, e):
        self.journal.append(f"[{self.date_str}] {e}")

    def clamp(self):
        self.food   = max(0, min(100, self.food))
        self.health = max(0, min(100, self.health))
        self.morale = max(0, min(100, self.morale))

    def apply_effect(self, effect, chars_active):
        self.food   += effect.get("food",0)
        self.health += effect.get("health",0)
        self.morale += effect.get("morale",0)
        for item,qty in effect.get("inventory",{}).items():
            self.inventory[item] = max(0, self.inventory.get(item,0)+qty)
        for item,qty in effect.get("inventory_gain",{}).items():
            self.inventory[item] = self.inventory.get(item,0)+qty
        for ck,bonus in effect.get("char_bonus",{}).items():
            if chars_active.get(ck):
                self.food   += bonus.get("food",0)
                self.health += bonus.get("health",0)
                self.morale += bonus.get("morale",0)
        if chars_active.get("york"):      self.morale += 2
        if chars_active.get("sacagawea"): self.food   += 3
        if chars_active.get("drouillard"):
            self.inventory["Furs"] = self.inventory.get("Furs",0)+1
        self.clamp()

    def to_dict(self):
        return {"current_wp":self.current_wp,"food":self.food,"health":self.health,
                "morale":self.morale,"current_month":self.current_month,
                "current_year":self.current_year,"journal":self.journal,
                "completed_objectives":self.completed_objectives,
                "tribe_relations":self.tribe_relations,"inventory":self.inventory,
                "discoveries":self.discoveries,"peaceful_tribes":self.peaceful_tribes,
                "traded_tribes":self.traded_tribes,"route_taken":self.route_taken,
                "events_seen":self.events_seen,"game_over":self.game_over,
                "victory":self.victory,
                "characters":{k:{"active":v["active"]} for k,v in self.characters.items()}}

    @classmethod
    def from_dict(cls, d):
        s = cls.__new__(cls)
        for attr in ["current_wp","food","health","morale","current_month","current_year",
                     "journal","completed_objectives","tribe_relations","inventory",
                     "discoveries","peaceful_tribes","traded_tribes","route_taken",
                     "game_over","victory"]:
            setattr(s, attr, d[attr])
        s.events_seen = d.get("events_seen",[])
        s.characters  = copy.deepcopy(SPECIAL_CHARACTERS)
        for k,v in d.get("characters",{}).items():
            if k in s.characters: s.characters[k]["active"] = v["active"]
        return s

# ═══════════════════════════════════════════════════════════════════════════════
#  CARTOGRAPHIC MAP SURFACE
#  Rendered once to a large surface, then zoomed/panned as a texture
# ═══════════════════════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════════════════════
#  HEX GRID
# ═══════════════════════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════════════════════
#  UI COMPONENTS
# ═══════════════════════════════════════════════════════════════════════════════
class Button:
    def __init__(self, rect, label, fill=UI_CARD2, fill_h=GOLD,
                 text_col=PARCH_DARK, text_h=INK, font=None, sub=None):
        self.rect     = pygame.Rect(rect)
        self.label    = label
        self.fill     = fill
        self.fill_h   = fill_h
        self.text_col = text_col
        self.text_h   = text_h
        self.font     = font or F["btn"]
        self.sub      = sub
        self.hovered  = False
        self.disabled = False

    def draw(self, surf):
        col  = self.fill_h if (self.hovered and not self.disabled) else self.fill
        tcol = self.text_h if (self.hovered and not self.disabled) else self.text_col
        if self.disabled: col = darken(self.fill, 0.6); tcol = DIM
        pygame.draw.rect(surf, col, self.rect, border_radius=4)
        pygame.draw.rect(surf, GOLD if self.hovered else UI_BORDER, self.rect, 1, border_radius=4)
        ts = self.font.render(self.label, True, tcol)
        r  = ts.get_rect(center=self.rect.center)
        if self.sub: r.centery = self.rect.centery - 7
        surf.blit(ts, r)
        if self.sub:
            ss = F["tiny"].render(self.sub, True, darken(tcol, 0.7) if not self.disabled else DIM)
            surf.blit(ss, ss.get_rect(centerx=self.rect.centerx, top=self.rect.centery+4))

    def handle(self, event):
        if event.type == pygame.MOUSEMOTION:
            self.hovered = self.rect.collidepoint(event.pos)
        if event.type == pygame.MOUSEBUTTONDOWN and event.button==1:
            if self.rect.collidepoint(event.pos) and not self.disabled:
                return True
        return False


class ScrollPanel:
    """Scrollable text panel — journal, event text, etc."""
    def __init__(self, rect, bg=UI_PANEL, border=UI_BORDER):
        self.rect    = pygame.Rect(rect)
        self.bg      = bg
        self.border  = border
        self.lines   = []   # list of (text, font, colour)
        self.scroll  = 0
        self.content_h = 0
        self._surf   = None

    def set_lines(self, lines):
        self.lines   = lines
        self.scroll  = 0
        self._surf   = None   # invalidate cache

    def _render(self):
        # Build content surface
        pad = 8
        w   = self.rect.w - 2*pad - 8  # -8 for scrollbar
        y   = pad
        items = []
        for text, font, colour in self.lines:
            words = text.split()
            line  = ""
            for word in words:
                test = (line+" "+word).strip()
                if font.size(test)[0] <= w: line = test
                else:
                    if line: items.append((line, font, colour, y)); y += font.get_height()+2
                    line = word
            if line: items.append((line, font, colour, y)); y += font.get_height()+4
        self.content_h = y + pad
        self._items    = items

    def draw(self, surf):
        if self._surf is None: self._render()
        pygame.draw.rect(surf, self.bg,     self.rect, border_radius=3)
        pygame.draw.rect(surf, self.border, self.rect, 1, border_radius=3)
        # Clip
        clip = surf.subsurface(self.rect.inflate(-2, -2))
        clip.fill(self.bg)
        for text, font, colour, y in self._items:
            sy = y - self.scroll
            if sy > self.rect.h: break
            if sy > -font.get_height():
                ts = font.render(text, True, colour)
                clip.blit(ts, (8, sy))
        # Scrollbar
        if self.content_h > self.rect.h:
            bar_h = max(20, int(self.rect.h**2 / self.content_h))
            bar_y = int(self.scroll / self.content_h * self.rect.h)
            bar_r = pygame.Rect(self.rect.right-7, self.rect.y+bar_y, 5, bar_h)
            pygame.draw.rect(surf, UI_BORDER, bar_r, border_radius=2)

    def handle(self, event):
        if event.type == pygame.MOUSEWHEEL:
            if self.rect.collidepoint(pygame.mouse.get_pos()):
                self.scroll = max(0, min(self.content_h-self.rect.h,
                                         self.scroll - event.y*18))


# ═══════════════════════════════════════════════════════════════════════════════
#  MAP VIEW — renders cached map surface + hex grid overlay + waypoints
# ═══════════════════════════════════════════════════════════════════════════════
class MapView:
    MAP_RECT = pygame.Rect(0, 50, 920, SH-50)

    def __init__(self):
        self.zoom       = 1.0
        self.pan_x      = 0.0
        self.pan_y      = 0.0
        self.hover_wp   = None
        self._drag_start= None
        self._drag_pan  = None
        self.frame      = 0
        self._particles = []   # list of [x, y, vx, vy, life, size]

    # ── coordinate transforms ──────────────────────────────────────────────────
    def ws(self, wx, wy):
        """World (0-1 normalized) → screen pixel within MAP_RECT."""
        R = self.MAP_RECT
        W, H = R.w, R.h
        sx = int((wx + self.pan_x) * self.zoom * W) + R.x
        sy = int((wy + self.pan_y) * self.zoom * H) + R.y
        return sx, sy

    def sw(self, sx, sy):
        """Screen pixel → world (0-1)."""
        R = self.MAP_RECT
        W, H = R.w, R.h
        wx = (sx - R.x) / (self.zoom * W) - self.pan_x
        wy = (sy - R.y) / (self.zoom * H) - self.pan_y
        return wx, wy

    # ── particles (embers at current position) ────────────────────────────────
    def _tick_particles(self, cx, cy):
        # Spawn
        if random.random() < 0.38:
            ang = random.uniform(0, math.pi*2)
            spd = random.uniform(0.3, 1.2)
            self._particles.append([cx, cy, math.cos(ang)*spd,
                                    math.sin(ang)*spd - 1.2,
                                    random.uniform(0.6, 1.0),
                                    random.uniform(1.5, 3.5)])
        # Update
        alive = []
        for p in self._particles:
            p[0] += p[2]; p[1] += p[3]; p[4] -= 0.018
            p[3] -= 0.04   # gravity up
            if p[4] > 0: alive.append(p)
        self._particles = alive

    def _draw_particles(self, surf):
        for p in self._particles:
            t = p[4]
            r = min(255, int(200 + t*55))
            g = min(255, int(t * 180))
            b = min(255, int(t * 40))
            sz = max(1, int(p[5] * t))
            pygame.draw.circle(surf, (r, g, b), (int(p[0]), int(p[1])), sz)

    # ── map drawing ───────────────────────────────────────────────────────────
    def draw(self, surf, state):
        R   = self.MAP_RECT
        z   = self.zoom
        s   = state
        W, H= R.w, R.h
        self.frame += 1

        # Clip all drawing to map rect
        clip_save = surf.get_clip()
        surf.set_clip(R)

        # Local map colour aliases matching tkinter exactly
        PARCH_BASE  = (232, 216, 168)
        PARCH_DARK  = (200, 176, 120)
        PARCH_EDGE  = (168, 144,  88)
        INK_C       = ( 58,  40,   8)
        INK_LIGHT   = (106,  72,  32)
        INK_FAINT   = (154, 120,  72)
        WATER_WASH  = (184, 204, 216)
        WATER_DEEP  = (136, 152, 168)
        LAND_WASH   = (200, 176, 120)
        LAND_HATCH  = (168, 152,  88)
        MTN_INK     = ( 90,  56,  24)
        RIVER_INK   = (104, 136, 168)
        PATH_INK    = (136,  48,  16)
        RED_INK_C   = (138,  32,  16)

        def lw(base): return max(1, int(base * z))

        # ── 1. Water fill ─────────────────────────────────────────────────────
        surf.fill(WATER_WASH, R)

        # Water texture — horizontal dashed lines
        rng = random.Random(7)
        for wi in range(0, H, 6):
            dc = (max(0, WATER_WASH[i]-12) for i in range(3))
            pygame.draw.line(surf, WATER_DEEP, (R.x, R.y+wi), (R.x+W, R.y+wi), 1)

        # ── 2. Parchment base ─────────────────────────────────────────────────
        # Re-fill parchment on top so water shows only outside territory polys
        surf.fill(PARCH_BASE, R)

        # Diagonal cross-hatch texture (linen)
        hatch = (max(0, PARCH_BASE[i]-18) for i in range(3))
        HATCH_COL = (PARCH_BASE[0]-14, PARCH_BASE[1]-14, PARCH_BASE[2]-10)
        for i in range(0, W+H, 18):
            pygame.draw.line(surf, HATCH_COL,
                             (R.x+i, R.y), (R.x+max(0,i-H), R.y+min(H,i)), 1)
        for i in range(-H, W, 18):
            pygame.draw.line(surf, HATCH_COL,
                             (R.x+max(0,i), R.y), (R.x+min(W,i+H), R.y+H), 1)

        # ── 3. Lat/lon grid ───────────────────────────────────────────────────
        GRID_COL = (INK_FAINT[0], INK_FAINT[1], INK_FAINT[2])
        step_x = max(20, W//10); step_y = max(20, H//8)
        for gx in range(0, W, step_x):
            for dy4 in range(0, H, 8):
                surf.set_at((R.x+gx, R.y+dy4), GRID_COL)
        for gy5 in range(0, H, step_y):
            for dx4 in range(0, W, 8):
                surf.set_at((R.x+dx4, R.y+gy5), GRID_COL)

        # ── 4. Territory land polygons ────────────────────────────────────────
        TERR_WASHES = {
            "Illinois": (212,200,136), "Missouri": (204,192,128),
            "Iowa":     (200,188,120), "Nebraska": (196,184,112),
            "Kansas":   (192,180,104), "Dakota":   (188,176, 96),
            "Montana":  (184,172, 88), "Idaho":    (180,168, 80),
            "Oregon":   (176,164, 72), "Washington":(180,168, 80),
        }
        for terr in TERRITORIES:
            poly = terr["poly"]
            pts  = [self.ws(poly[i], poly[i+1]) for i in range(0, len(poly), 2)]
            if len(pts) >= 3:
                wash = TERR_WASHES.get(terr["name"], LAND_WASH)
                pygame.draw.polygon(surf, wash, pts)
                pygame.draw.polygon(surf, INK_LIGHT, pts, lw(1))
                # Alternate hatching
                if TERRITORIES.index(terr) % 2 == 0:
                    pygame.draw.polygon(surf, LAND_HATCH, pts, 1)

            # Territory name label
            if z >= 0.7:
                lx, ly = self.ws(terr["label_x"], terr["label_y"])
                fsz = max(6, int(8*z))
                try:
                    f_lbl = pygame.font.SysFont("Georgia", fsz, italic=True)
                    tname = terr["name"].upper()
                    ts_sh = f_lbl.render(tname, True, PARCH_BASE)
                    surf.blit(ts_sh, ts_sh.get_rect(center=(lx+1, ly+1)))
                    ts_lbl = f_lbl.render(tname, True, INK_LIGHT)
                    surf.blit(ts_lbl, ts_lbl.get_rect(center=(lx, ly)))
                except: pass

        # ── 5. Rocky Mountains hachure ────────────────────────────────────────
        ridge = [
            (0.13,0.48),(0.14,0.40),(0.15,0.34),(0.16,0.28),(0.17,0.22),
            (0.18,0.26),(0.19,0.20),(0.20,0.24),(0.21,0.17),(0.22,0.21),
            (0.23,0.26),(0.24,0.30),(0.25,0.36),(0.26,0.42),(0.26,0.50),
        ]
        for mx6, my6 in ridge[::2]:
            sx6, sy6 = self.ws(mx6, my6)
            sz6 = max(6, int(10*z))
            # Back shadow mountain
            pts_b = [(sx6-sz6+3, sy6+sz6//2+3),
                     (sx6+sz6//3+3, sy6-sz6//3+3),
                     (sx6+sz6+5, sy6+sz6//2+3)]
            pygame.draw.polygon(surf, PARCH_EDGE, pts_b)
            # Main mountain symbol
            pts_m = [(sx6-sz6, sy6+sz6//2), (sx6, sy6-sz6), (sx6+sz6, sy6+sz6//2)]
            pygame.draw.polygon(surf, PARCH_BASE, pts_m)
            pygame.draw.polygon(surf, MTN_INK, pts_m, lw(1))
            # Secondary peak
            pts_s = [(sx6-sz6//2, sy6+sz6//2), (sx6+sz6//3, sy6-sz6//3),
                     (sx6+int(sz6*1.2), sy6+sz6//2)]
            pygame.draw.polygon(surf, PARCH_BASE, pts_s)
            pygame.draw.polygon(surf, MTN_INK, pts_s, 1)
            # Snow cap
            pygame.draw.circle(surf, PARCH_BASE, (sx6, sy6-sz6), 3)
            pygame.draw.circle(surf, MTN_INK, (sx6, sy6-sz6), 3, 1)

        if z >= 0.8:
            rx6, ry6 = self.ws(0.20, 0.38)
            fsz2 = max(5, int(7*z))
            try:
                fm = pygame.font.SysFont("Georgia", fsz2, italic=True)
                ts_sh = fm.render("ROCKY MOUNTAINS", True, PARCH_BASE)
                surf.blit(ts_sh, ts_sh.get_rect(center=(rx6+1, ry6+1)))
                ts_lbl = fm.render("ROCKY MOUNTAINS", True, MTN_INK)
                surf.blit(ts_lbl, ts_lbl.get_rect(center=(rx6, ry6)))
            except: pass

        # ── 6. Pacific NW forest symbols ──────────────────────────────────────
        for tx7, ty7 in [(0.07,0.25),(0.09,0.28),(0.11,0.26),(0.06,0.30),(0.08,0.32)]:
            sx7, sy7 = self.ws(tx7, ty7)
            sz7 = max(4, int(7*z))
            pygame.draw.line(surf, INK_LIGHT, (sx7, sy7), (sx7, sy7+int(sz7*1.4)), lw(1))
            pts_t = [(sx7-sz7, sy7), (sx7, sy7-int(sz7*1.6)), (sx7+sz7, sy7)]
            pygame.draw.polygon(surf, LAND_WASH, pts_t)
            pygame.draw.polygon(surf, INK_LIGHT, pts_t, lw(1))

        # ── 7. Missouri River — double blue ink line ───────────────────────────
        rp = [self.ws(wp["x"], wp["y"]) for wp in WAYPOINTS]
        rw = max(2, int(4*z))
        if len(rp) >= 2:
            pygame.draw.lines(surf, WATER_WASH,  False, rp, rw+6)
            pygame.draw.lines(surf, RIVER_INK,   False, rp, rw+2)
            pygame.draw.lines(surf, WATER_DEEP,  False, rp, max(1,rw-2))

        if z >= 0.8:
            mid = WAYPOINTS[len(WAYPOINTS)//2]
            rlx7, rly7 = self.ws(mid["x"]-0.04, mid["y"]-0.04)
            fsz3 = max(6, int(8*z))
            try:
                fr = pygame.font.SysFont("Georgia", fsz3, italic=True)
                ts_sh = fr.render("Missouri R.", True, PARCH_BASE)
                surf.blit(ts_sh, (rlx7+1, rly7+1))
                ts_r = fr.render("Missouri R.", True, RIVER_INK)
                surf.blit(ts_r, (rlx7, rly7))
            except: pass

        # ── 8. Expedition route — red ink dashed ──────────────────────────────
        pw = max(2, int(3*z))
        for i in range(s.current_wp):
            p1 = self.ws(WAYPOINTS[i]["x"],   WAYPOINTS[i]["y"])
            p2 = self.ws(WAYPOINTS[i+1]["x"], WAYPOINTS[i+1]["y"])
            pygame.draw.line(surf, PATH_INK, p1, p2, pw+1)
            # Dashes
            dx8 = p2[0]-p1[0]; dy8 = p2[1]-p1[1]
            dist8 = max(1, int(math.hypot(dx8, dy8)))
            dash_on = max(4, int(6*z)); dash_off = max(3, int(4*z))
            d = 0; on = True
            while d < dist8:
                chunk = dash_on if on else dash_off
                if on:
                    ex8 = p1[0]+int(dx8*(d+chunk)/dist8)
                    ey8 = p1[1]+int(dy8*(d+chunk)/dist8)
                    bx8 = p1[0]+int(dx8*d/dist8)
                    by8 = p1[1]+int(dy8*d/dist8)
                    pygame.draw.line(surf, PARCH_BASE, (bx8,by8), (ex8,ey8), 1)
                d += chunk; on = not on

        # ── 9. Waypoints — cartographic markers ───────────────────────────────
        pulse = abs(math.sin(self.frame * 0.06))
        for i, wp in enumerate(WAYPOINTS):
            sx9, sy9 = self.ws(wp["x"], wp["y"])
            if not R.collidepoint(sx9, sy9): continue
            sz9 = max(5, int(8*z))
            is_cur = i == s.current_wp
            is_vis = i <  s.current_wp
            is_hov = i == self.hover_wp

            if is_cur:
                pr = int(sz9 + 4 + pulse*5)
                pygame.draw.circle(surf, PARCH_BASE, (sx9,sy9), pr)
                pygame.draw.circle(surf, RED_INK_C,  (sx9,sy9), pr, 2)
                pygame.draw.circle(surf, RED_INK_C,  (sx9,sy9), sz9)
                pygame.draw.line(surf, RED_INK_C, (sx9-sz9-6,sy9),(sx9+sz9+6,sy9), 2)
                pygame.draw.line(surf, RED_INK_C, (sx9,sy9-sz9-6),(sx9,sy9+sz9+6), 2)
                # Particle emitter at current position
                self._tick_particles(sx9, sy9)
            elif is_vis:
                pygame.draw.circle(surf, INK_C, (sx9,sy9), sz9-1)
            else:
                col9 = INK_C if is_hov else INK_FAINT
                pygame.draw.circle(surf, PARCH_BASE, (sx9,sy9), sz9-1)
                pygame.draw.circle(surf, col9, (sx9,sy9), sz9-1, lw(1))

            # Labels
            ly9 = sy9 - int(14*z) if sy9 > R.y+50 else sy9 + int(16*z)
            fsz4 = max(6, int(7*z))
            fsz4b = max(6, int(6*z))
            if is_hov or is_cur or z >= 1.8:
                lw9 = max(55, len(wp["name"])*max(4,int(5*z))+10)
                box9 = pygame.Rect(sx9-lw9//2, ly9-9, lw9, 16)
                pygame.draw.rect(surf, PARCH_BASE, box9)
                pygame.draw.rect(surf, RED_INK_C if is_cur else INK_LIGHT, box9, 1)
                try:
                    fb = pygame.font.SysFont("Georgia", fsz4, bold=True)
                    tl = fb.render(wp["name"], True, INK_C)
                    surf.blit(tl, tl.get_rect(center=(sx9, ly9)))
                except: pass
                if z >= 1.4 or is_cur:
                    try:
                        fi2 = pygame.font.SysFont("Georgia", fsz4b, italic=True)
                        td = fi2.render(wp["desc"][:28], True, INK_FAINT)
                        surf.blit(td, td.get_rect(centerx=sx9, top=ly9+8))
                    except: pass
            elif z >= 0.7:
                try:
                    fn2 = pygame.font.SysFont("Georgia", fsz4)
                    col9b = INK_C if is_vis else INK_FAINT
                    ts_sh = fn2.render(wp["name"], True, PARCH_BASE)
                    surf.blit(ts_sh, ts_sh.get_rect(center=(sx9+1, ly9+1)))
                    ts_lbl = fn2.render(wp["name"], True, col9b)
                    surf.blit(ts_lbl, ts_lbl.get_rect(center=(sx9, ly9)))
                except: pass

        # ── 10. Particles ─────────────────────────────────────────────────────
        self._draw_particles(surf)

        # ── 11. Compass rose ──────────────────────────────────────────────────
        cr = max(32, int(44*min(z,1.5)))
        cx9 = R.right - cr - 14
        cy9 = R.bottom - cr - 14
        pygame.draw.circle(surf, PARCH_BASE,  (cx9,cy9), cr+4)
        pygame.draw.circle(surf, INK_LIGHT,   (cx9,cy9), cr+4, 2)
        pygame.draw.circle(surf, PARCH_DARK,  (cx9,cy9), cr)
        for pt9 in range(16):
            ang9 = math.radians(pt9*22.5)
            length9 = (cr-4) if pt9%4==0 else ((cr-8) if pt9%2==0 else cr-14)
            ex9 = cx9+int(math.sin(ang9)*length9)
            ey9 = cy9-int(math.cos(ang9)*length9)
            pygame.draw.line(surf, INK_C, (cx9,cy9), (ex9,ey9), 2 if pt9%4==0 else 1)
        for lb9, ag9 in [("N",0),("E",90),("S",180),("W",270)]:
            lx9 = cx9+int(math.sin(math.radians(ag9))*(cr-10))
            ly9b = cy9-int(math.cos(math.radians(ag9))*(cr-10))
            try:
                fc9 = pygame.font.SysFont("Georgia", max(7,int(9*z)), bold=True)
                tsh9 = fc9.render(lb9, True, PARCH_BASE)
                surf.blit(tsh9, tsh9.get_rect(center=(lx9+1, ly9b+1)))
                tc9 = fc9.render(lb9, True, RED_INK_C if lb9=="N" else INK_C)
                surf.blit(tc9, tc9.get_rect(center=(lx9, ly9b)))
            except: pass
        pygame.draw.circle(surf, INK_C, (cx9,cy9), 3)

        # ── 12. Legend box ────────────────────────────────────────────────────
        leg_x = R.x+6; leg_y = R.y+6; leg_w = 160; leg_h = 80
        pygame.draw.rect(surf, PARCH_DARK,  (leg_x,leg_y,leg_w,leg_h))
        pygame.draw.rect(surf, INK_C,       (leg_x,leg_y,leg_w,leg_h), 2)
        pygame.draw.rect(surf, INK_LIGHT,   (leg_x+3,leg_y+3,leg_w-6,leg_h-6), 1)
        try:
            fl = pygame.font.SysFont("Georgia", max(6,int(7*z)), bold=True, italic=True)
            tl2 = fl.render("REFERENCES", True, INK_C)
            surf.blit(tl2, tl2.get_rect(centerx=leg_x+leg_w//2, top=leg_y+4))
        except: pass
        try:
            fe = pygame.font.SysFont("Georgia", max(6,int(7*z)))
            for dy9, fill9, txt9 in [
                (22, RED_INK_C,  "Present Camp"),
                (36, INK_C,      "Camp Visited"),
                (50, INK_FAINT,  "Camp Ahead"),
                (64, PATH_INK,   "Route of Expedition"),
            ]:
                if txt9 == "Route of Expedition":
                    pygame.draw.line(surf, PATH_INK,
                                     (leg_x+10, leg_y+dy9), (leg_x+26, leg_y+dy9), 2)
                else:
                    pygame.draw.circle(surf, fill9, (leg_x+18, leg_y+dy9), 5)
                    pygame.draw.circle(surf, INK_C,  (leg_x+18, leg_y+dy9), 5, 1)
                tleg = fe.render(txt9, True, INK_C)
                surf.blit(tleg, (leg_x+30, leg_y+dy9-6))
        except: pass

        # ── 13. Scale bar ─────────────────────────────────────────────────────
        sc_x = R.x + W//2-60; sc_y = R.y+H-18
        pygame.draw.line(surf, INK_C, (sc_x,sc_y), (sc_x+120,sc_y), 2)
        pygame.draw.line(surf, INK_C, (sc_x,sc_y-5), (sc_x,sc_y+5), 2)
        pygame.draw.line(surf, INK_C, (sc_x+60,sc_y-3), (sc_x+60,sc_y+3), 1)
        pygame.draw.line(surf, INK_C, (sc_x+120,sc_y-5), (sc_x+120,sc_y+5), 2)
        try:
            fs = pygame.font.SysFont("Georgia", max(5,int(6*z)), italic=True)
            ts2 = fs.render("SCALE OF MILES", True, INK_FAINT)
            surf.blit(ts2, ts2.get_rect(centerx=sc_x+60, bottom=sc_y-2))
            t0 = fs.render("0",   True, INK_FAINT)
            t5 = fs.render("500", True, INK_FAINT)
            surf.blit(t0, t0.get_rect(centerx=sc_x, top=sc_y+3))
            surf.blit(t5, t5.get_rect(centerx=sc_x+120, top=sc_y+3))
        except: pass

        # ── 14. Cartouche box ─────────────────────────────────────────────────
        cart_x = R.x+6; cart_y = R.y+H-88; cart_w = 186; cart_h = 76
        pygame.draw.rect(surf, PARCH_DARK, (cart_x,cart_y,cart_w,cart_h))
        pygame.draw.rect(surf, INK_C,      (cart_x,cart_y,cart_w,cart_h), 2)
        pygame.draw.rect(surf, INK_LIGHT,  (cart_x+4,cart_y+4,cart_w-8,cart_h-8), 1)
        for ccx, ccy, ddx, ddy in [
            (cart_x+4,cart_y+4,8,0),(cart_x+4,cart_y+4,0,8),
            (cart_x+cart_w-4,cart_y+4,-8,0),(cart_x+cart_w-4,cart_y+4,0,8),
            (cart_x+4,cart_y+cart_h-4,8,0),(cart_x+4,cart_y+cart_h-4,0,-8),
            (cart_x+cart_w-4,cart_y+cart_h-4,-8,0),(cart_x+cart_w-4,cart_y+cart_h-4,0,-8),
        ]:
            pygame.draw.line(surf, INK_C, (ccx,ccy), (ccx+ddx,ccy+ddy), 2)
        ccx9 = cart_x+cart_w//2
        try:
            for cy_off, txt_c, bold_c, col_c in [
                (12, "MAP of the",                        False, INK_LIGHT),
                (26, "LOUISIANA TERRITORY",               True,  INK_C),
                (42, "Explored by Capts LEWIS & CLARK",   False, INK_FAINT),
                (56, "By order of the President  MDCCCIV",False, INK_FAINT),
                (70, f"Season: {s.season}   {s.date_str}", False, INK_LIGHT),
            ]:
                fsz_c = max(5,int(9*z)) if bold_c else max(5,int(6*z))
                fc2 = pygame.font.SysFont("Georgia", fsz_c, bold=bold_c, italic=not bold_c)
                tc2 = fc2.render(txt_c, True, col_c)
                surf.blit(tc2, tc2.get_rect(centerx=ccx9, top=cart_y+cy_off))
        except: pass

        # ── 15. Vignette edges ────────────────────────────────────────────────
        for vi in range(20):
            t3 = vi/20; alpha = int(t3*t3*70)
            r3 = max(0, PARCH_BASE[0]-alpha*2)
            g3 = max(0, PARCH_BASE[1]-alpha*2)
            b3 = max(0, PARCH_BASE[2]-alpha*3)
            pygame.draw.rect(surf, (r3,g3,b3),
                             (R.x+vi*4, R.y+vi*4, W-vi*8, H-vi*8), 4)

        # ── 16. Zoom badge ────────────────────────────────────────────────────
        if z != 1.0:
            try:
                fz = pygame.font.SysFont("Georgia", max(6,int(7*z)))
                tz = fz.render(f"×{z:.1f}", True, INK_FAINT)
                surf.blit(tz, tz.get_rect(topright=(R.right-6, R.y+4)))
            except: pass

        surf.set_clip(clip_save)
        pygame.draw.rect(surf, UI_BORDER, R, 2)

    def handle(self, event, state, on_move):
        R = self.MAP_RECT
        mpos = pygame.mouse.get_pos()
        z = self.zoom
        W, H = R.w, R.h

        if event.type == pygame.MOUSEMOTION:
            self.hover_wp = None
            if R.collidepoint(mpos):
                for wp in WAYPOINTS:
                    sx, sy = self.ws(wp["x"], wp["y"])
                    r = max(12, int(12*z))
                    if abs(mpos[0]-sx)<r and abs(mpos[1]-sy)<r:
                        self.hover_wp = wp["id"]; break
                if self._drag_start:
                    dx = (mpos[0]-self._drag_start[0]) / (z*W)
                    dy = (mpos[1]-self._drag_start[1]) / (z*H)
                    self.pan_x = self._drag_pan[0]+dx
                    self.pan_y = self._drag_pan[1]+dy

        if event.type == pygame.MOUSEBUTTONDOWN and R.collidepoint(mpos):
            if event.button == 3:
                self._drag_start = mpos
                self._drag_pan   = (self.pan_x, self.pan_y)
            elif event.button == 1:
                # Click a waypoint → trigger movement
                for wp in WAYPOINTS:
                    sx, sy = self.ws(wp["x"], wp["y"])
                    r = max(14, int(14*z))
                    if abs(mpos[0]-sx)<r and abs(mpos[1]-sy)<r:
                        on_move(wp["id"])
                        return

        if event.type == pygame.MOUSEBUTTONUP and event.button == 3:
            self._drag_start = None

        if event.type == pygame.MOUSEWHEEL and R.collidepoint(mpos):
            factor = 1.25 if event.y > 0 else 0.8
            wx0, wy0 = self.sw(*mpos)
            self.zoom = max(0.5, min(4.0, self.zoom * factor))
            # Re-anchor so mouse stays over same world point
            nx = mpos[0] - R.x; ny = mpos[1] - R.y
            self.pan_x = nx/(self.zoom*W) - wx0
            self.pan_y = ny/(self.zoom*H) - wy0

        # Zoom with +/- keys handled by GameScreen
    def zoom_in(self):  self.zoom = min(4.0, self.zoom*1.25)
    def zoom_out(self): self.zoom = max(0.5, self.zoom/1.25)
    def zoom_reset(self): self.zoom=1.0; self.pan_x=0.0; self.pan_y=0.0


# ═══════════════════════════════════════════════════════════════════════════════
#  CINEMATIC SCREEN
# ═══════════════════════════════════════════════════════════════════════════════
class CinematicScreen:
    ART_W = int(SW * 0.60)

    def __init__(self, on_done):
        self.on_done   = on_done
        self.idx       = 0
        self.cine_line = 0
        self.cine_char = 0
        self.pause     = 0
        self.frame     = 0
        self.next_btn  = Button((SW*3//5+120, SH-58, 180, 38), "NEXT  ▶",
                                fill=UI_CARD2, fill_h=GOLD, text_col=PARCH, text_h=INK)
        self.back_btn  = Button((SW*3//5+10, SH-58, 100, 38), "◀ BACK",
                                fill=UI_PANEL, text_col=DIM2)
        self.skip_btn  = Button((SW-90, SH-28, 78, 20), "Skip All",
                                fill=UI_BG, text_col=DIM, font=F["small"])
        self.begin_btn = Button((SW*3//5+50, SH-62, 280, 46),
                                "⚑  BEGIN THE EXPEDITION  ⚑",
                                fill=GOLD, fill_h=GOLD2, text_col=INK, text_h=INK,
                                font=F["btn_lg"])

    @property
    def scene(self): return CINE_SCENES[self.idx]

    def advance(self):
        if self.idx < len(CINE_SCENES)-1:
            self.idx += 1; self.cine_line=0; self.cine_char=0; self.pause=0

    def retreat(self):
        if self.idx > 0:
            self.idx -= 1; self.cine_line=0; self.cine_char=0; self.pause=0

    def draw(self, surf):
        sd   = self.scene
        t    = self.frame * 0.022
        self.frame += 1

        # ── Left: art panel ───────────────────────────────────────────────────
        art_surf = pygame.Surface((self.ART_W, SH))
        self._draw_scene(art_surf, sd["id"], t)
        surf.blit(art_surf, (0, 0))

        # Accent border between art and text
        acc = sd["accent"]
        pygame.draw.rect(surf, acc, (self.ART_W, 0, 3, SH))
        pygame.draw.rect(surf, darken(acc, 0.6), (self.ART_W+3, 0, 1, SH))

        # ── Right: text panel ─────────────────────────────────────────────────
        rx = self.ART_W + 20
        rw = SW - rx - 12

        surf.fill(UI_BG, (self.ART_W+4, 0, SW-self.ART_W-4, SH))

        # Year/location badge
        badge_h = 28
        pygame.draw.rect(surf, acc, (rx, 16, rw-8, badge_h), border_radius=3)
        badge_txt = f"{sd['year']}   ·   {sd['location']}"
        draw_text(surf, badge_txt, F["small_i"], darken(acc,0.2),
                  (rx+10, 16+badge_h//2), anchor="midleft")

        # Title
        ty = 56
        draw_text(surf, sd["title"], F["cine"], PARCH, (rx+1, ty+1), max_w=rw-8)
        draw_text(surf, sd["title"], F["cine"], PARCH, (rx, ty), max_w=rw-8)
        pygame.draw.line(surf, acc, (rx, ty+46), (rx+rw-8, ty+46), 2)

        # Narration — typewriter
        narr   = sd["narration"]
        ny     = ty + 54
        LINE_H = 22
        for li, line in enumerate(narr):
            if li < self.cine_line:
                wrapped = textwrap.fill(line, 42)
                for wl in wrapped.split("\n"):
                    draw_text(surf, wl, F["narr"], PARCH_DARK, (rx, ny))
                    ny += LINE_H
                ny += 6
            elif li == self.cine_line:
                partial = line[:self.cine_char]
                if partial:
                    wrapped = textwrap.fill(partial, 42)
                    for wl in wrapped.split("\n"):
                        draw_text(surf, wl, F["narr"], PARCH, (rx, ny))
                        ny += LINE_H
                # Cursor
                if self.cine_char % 20 < 11:
                    draw_text(surf, "▌", F["narr"], acc, (rx+2, ny))
                break

        # Fact badge
        fact = sd.get("fact","")
        if fact:
            fy2 = SH - 150
            fact_r = pygame.Rect(rx-2, fy2-4, rw-6, 74)
            pygame.draw.rect(surf, UI_CARD, fact_r, border_radius=4)
            pygame.draw.rect(surf, acc,     fact_r, 1, border_radius=4)
            badge2 = pygame.Rect(rx-2, fy2-4, rw-6, 18)
            pygame.draw.rect(surf, acc, badge2, border_radius=4)
            draw_text(surf, "DID YOU KNOW", F["tiny_b"], darken(acc,0.2),
                      (rx+8, fy2+2))
            draw_text(surf, fact, F["small"], GOLD, (rx+4, fy2+20), max_w=rw-14)

        # Progress dots
        dot_y = SH - 74
        for di in range(len(CINE_SCENES)):
            dcol = acc if di==self.idx else PARCH_EDGE if di<self.idx else UI_BORDER
            dot_x2 = rx + di*24
            pygame.draw.rect(surf, dcol, (dot_x2, dot_y, 16, 16), border_radius=3)

        # Advance typewriter state
        if self.pause > 0:
            self.pause -= 1
        elif self.cine_line < len(narr):
            self.cine_char += 3
            if self.cine_char >= len(narr[self.cine_line]):
                self.cine_line += 1; self.cine_char = 0; self.pause = 20

        # "Continue" pulse when done
        if self.cine_line >= len(narr):
            pulse2 = int(abs(math.sin(self.frame*0.07))*120+80)
            pc = (pulse2, int(pulse2*0.7), 10)
            draw_text(surf, "▶  CONTINUE", F["subhead"], pc,
                      (rx + rw//2, SH-82), anchor="midbottom")

        # Nav buttons
        if self.idx < len(CINE_SCENES)-1:
            self.next_btn.draw(surf)
        else:
            self.begin_btn.draw(surf)
        if self.idx > 0:
            self.back_btn.draw(surf)
        self.skip_btn.draw(surf)

    def _draw_scene(self, surf, scene_id, t):
        """Draw the art scene."""
        W, H = surf.get_size()
        dispatch = {
            "secret_message": self._scene_jefferson,
            "napoleon":       self._scene_napoleon,
            "lewis_prepares": self._scene_lewis,
            "clark_recruited":self._scene_clark,
            "corps_assembled":self._scene_camp,
            "the_river":      self._scene_river,
            "depart":         self._scene_departure,
        }
        fn = dispatch.get(scene_id, self._scene_river)
        fn(surf, W, H, t)
        # Film grain
        if self.frame % 5 < 2:
            rng2 = random.Random(self.frame//5)
            for _ in range(40):
                gx, gy = rng2.randint(0,W-1), rng2.randint(0,H-1)
                v2 = surf.get_at((gx,gy))
                surf.set_at((gx,gy), tuple(max(0,c-20) for c in v2[:3]))
        # Border
        pygame.draw.rect(surf, (*INK_LT,200), (0,0,W,H), 3)

    # ── Scene helpers ─────────────────────────────────────────────────────────
    def _sky_grad(self, surf, W, H, stops, h_end=None):
        if h_end is None: h_end = H
        n = len(stops)
        for y in range(h_end):
            seg = y/h_end*(n-1); lo=int(seg); hi=min(n-1,lo+1); f2=seg-lo
            col = tuple(int(stops[lo][i]+(stops[hi][i]-stops[lo][i])*f2) for i in range(3))
            pygame.draw.line(surf, col, (0,y),(W,y))

    def _ground(self, surf, W, H, layers):
        for base_frac, col, freq, amp in layers:
            pts = [(0, H)]
            for x in range(0, W+4, 4):
                y = int(H*base_frac + math.sin(x*freq)*amp + math.sin(x*freq*2.3)*amp*0.4)
                pts.append((x, y))
            pts.append((W, H))
            pygame.draw.polygon(surf, col, pts)

    def _flame(self, surf, cx, cy, t, seed=0):
        fk = int(math.sin(t*6.5+seed)*4)
        # Glow halos
        for r in range(24, 4, -5):
            g2 = min(255, 16 + (24-r)*4)
            s2 = pygame.Surface((r*2, r*2), pygame.SRCALPHA)
            pygame.draw.ellipse(s2, (g2, g2//2, 2, 60), (0,0,r*2,r*2))
            surf.blit(s2, (cx-r+fk, cy-r//2))
        # Flame body
        pygame.draw.ellipse(surf, (200,100,10), (cx-7+fk,cy-20,14,22))
        pygame.draw.ellipse(surf, (240,200,20), (cx-4+fk,cy-28,8,14))
        pygame.draw.ellipse(surf, (255,255,200),(cx-2+fk,cy-32,4,8))

    def _person(self, surf, x, y, scale, body_col, seated=False, facing_right=True):
        d = 1 if facing_right else -1
        s = scale
        sz = max(1, int(s))
        # Legs
        if not seated:
            pygame.draw.line(surf, body_col, (x-int(5*s),y),(x-int(9*s),y+int(26*s)),max(1,int(6*s)))
            pygame.draw.line(surf, body_col, (x+int(5*s),y),(x+int(9*s),y+int(26*s)),max(1,int(6*s)))
        else:
            pygame.draw.line(surf, body_col, (x-int(4*s),y),(x+d*int(20*s),y+int(4*s)),max(1,int(6*s)))
        # Torso
        pygame.draw.rect(surf, body_col,
                         (x-int(10*s), y-int(28*s), int(20*s), int(28*s)))
        # Arms
        arm_y = y-int(20*s)
        pygame.draw.line(surf, body_col, (x-int(10*s),arm_y),(x-int(24*s),arm_y+int(16*s)),max(1,int(5*s)))
        pygame.draw.line(surf, body_col, (x+int(10*s),arm_y),(x+int(24*s),arm_y+int(16*s)),max(1,int(5*s)))
        # Head
        pygame.draw.circle(surf, body_col, (x, y-int(40*s)), int(10*s))
        # Hat brim + crown
        pygame.draw.rect(surf, (10,8,6),
                         (x-int(13*s), y-int(50*s), int(26*s), int(4*s)))
        pygame.draw.rect(surf, (10,8,6),
                         (x-int(9*s), y-int(64*s), int(18*s), int(14*s)))

    # ── Scene 1: Jefferson writing ────────────────────────────────────────────
    def _scene_jefferson(self, surf, W, H, t):
        surf.fill((12, 8, 4))
        # Stone wall — horizontal bands
        for row in range(0, H, 18):
            shade = 13 + (row//18)%5
            for col in range(0, W, 54+row%12):
                pygame.draw.rect(surf, (shade,int(shade*0.65),int(shade*0.45)),
                                 (col, row, 52, 16))
                pygame.draw.rect(surf, (shade//2,shade//3,shade//4),
                                 (col, row, 52, 16), 1)

        # Large arched window — night sky
        wx, wy, ww, wh = int(W*0.10), 28, int(W*0.36), int(H*0.64)
        pygame.draw.rect(surf, (4, 8, 18), (wx, wy, ww, wh))
        pygame.draw.ellipse(surf, (4, 8, 18), (wx, wy-ww//2, ww, ww))
        pygame.draw.rect(surf, (28, 20, 8), (wx, wy, ww, wh), 5)
        # Window cross-panes
        pygame.draw.line(surf, (26,18,6),(wx+ww//2,wy),(wx+ww//2,wy+wh),4)
        pygame.draw.line(surf, (26,18,6),(wx,wy+wh//3),(wx+ww,wy+wh//3),4)
        # Stars
        rng3 = random.Random(99)
        for _ in range(40):
            sx, sy = wx+rng3.randint(4,ww-4), wy+rng3.randint(4,int(wh*0.75))
            bv = rng3.randint(80,200)
            tw2 = int(math.sin(t*2.2+sx*0.08)*20)
            bv2 = max(30, min(240, bv+tw2))
            pygame.draw.circle(surf, (bv2,bv2,int(bv2*0.85)),(sx,sy),1)
        # Moon
        pygame.draw.circle(surf, (200,200,148),(wx+int(ww*0.7), wy+24),20)
        pygame.draw.circle(surf, (4,8,18),     (wx+int(ww*0.7)+14,wy+18),14)

        # Desk
        dx, dy = int(W*0.38), int(H*0.58)
        dw = int(W*0.58)
        pygame.draw.rect(surf, (48, 26, 8), (dx, dy, dw, 20))
        pygame.draw.rect(surf, (34, 18, 4), (dx, dy+20, dw, 10))
        for lx3 in [dx+18, dx+dw-18]:
            pygame.draw.rect(surf, (28, 14, 4), (lx3-5, dy+30, 10, H-dy-30))

        # Parchment paper — large hero prop
        px, py = dx+int(dw*0.15), dy-80
        pygame.draw.rect(surf, (12, 8, 4),   (px+4, py+4, 136, 90))
        pygame.draw.rect(surf, (232, 216, 112),(px, py, 132, 88))
        pygame.draw.rect(surf, (140, 100, 24),(px, py, 132, 88), 2)
        # Writing lines
        for li in range(10):
            lw2 = 80+random.Random(li*3).randint(-12,18)
            pygame.draw.line(surf, (58, 40, 8),(px+10, py+9+li*7),(px+10+lw2, py+9+li*7),1)
        # CONFIDENTIAL stamp
        cs = F["tiny_b"].render("CONFIDENTIAL", True, (136, 20, 20))
        surf.blit(cs, cs.get_rect(center=(px+66, py+42)))
        # Wax seal
        pygame.draw.circle(surf, (170, 16, 16),(px+114, py+72),14)
        pygame.draw.circle(surf, (170, 16, 16),(px+114, py+72),14, 2)
        js = F["tiny_b"].render("J", True, GOLD)
        surf.blit(js, js.get_rect(center=(px+114, py+72)))

        # Quill — animated
        qx = px+90+int(math.sin(t*2)*8); qy = py+30+int(math.cos(t*2)*6)
        pygame.draw.line(surf, (200, 184, 64),(qx,qy),(qx-38,qy+58),2)
        for fi in range(6):
            fx2 = qx-int(fi*6); fy2 = qy+int(fi*9)
            pygame.draw.line(surf, (180,160,40),(fx2,fy2),(fx2-int(8+fi*2),fy2-6),1)
            pygame.draw.line(surf, (160,140,32),(fx2,fy2),(fx2+int(6+fi*2),fy2-8),1)
        pygame.draw.circle(surf, (10,8,6),(qx,qy),3)

        # Three candles
        for cndx in [dx+30, dx+int(dw*0.76), wx+ww+int(W*0.05)]:
            cndy = dy - 46
            pygame.draw.rect(surf, (58,38,8),(cndx-3,cndy,6,28))
            self._flame(surf, cndx, cndy, t, seed=cndx)

        # Jefferson figure
        self._person(surf, dx+int(dw*0.38), dy+4, 0.9, (14,10,6),
                     seated=True, facing_right=False)

        # Bookshelf
        shx, shy = int(W*0.80), int(H*0.10)
        pygame.draw.rect(surf, (26,16,8),(shx, shy, int(W*0.18), int(H*0.42)))
        for shelf in range(5):
            sy3 = shy+shelf*int(H*0.42//5)
            pygame.draw.line(surf,(42,28,10),(shx,sy3),(shx+int(W*0.18),sy3),2)
            for bk in range(6):
                bx2 = shx+4+bk*int(W*0.028)
                bc  = [(58,16,16),(16,32,44),(26,44,12),(44,26,8),(8,26,44),(40,16,16)][bk%6]
                pygame.draw.rect(surf, bc, (bx2, sy3+3, int(W*0.025), int(H*0.42//5)-5))

        draw_text(surf, "The White House Study  ·  January 18, 1803",
                  F["small_i"], INK_FAINT, (10, H-22))

    # ── Scene 2: Napoleon selling Louisiana ───────────────────────────────────
    def _scene_napoleon(self, surf, W, H, t):
        surf.fill((14, 10, 6))
        # Parquet floor
        for fx in range(0, W, 28):
            for fy2 in range(int(H*0.72), H, 18):
                c2 = (26,20,8) if ((fx//28)+(fy2//18))%2==0 else (22,16,6)
                pygame.draw.rect(surf, c2, (fx, fy2, 26, 16))
                pygame.draw.rect(surf, (18,12,4), (fx,fy2,26,16), 1)
        # Columns
        for cx2 in [int(W*f) for f in [0.04,0.22,0.60,0.78,0.94]]:
            pygame.draw.rect(surf, (30,26,12),(cx2-10,0,20,int(H*0.75)))
            for fi2 in range(5):
                pygame.draw.line(surf,(22,18,8),(cx2-7+fi2*3,0),(cx2-7+fi2*3,int(H*0.74)),1)
            pygame.draw.polygon(surf,(46,40,18),
                                [(cx2-18,0),(cx2-10,int(H*0.06)),(cx2+10,int(H*0.06)),(cx2+18,0)])
        # Chandelier
        chx, chy = W//2, 18
        pygame.draw.ellipse(surf, (40,36,12),(chx-24,chy-8,48,16))
        for arm_a in range(0, 360, 45):
            ax2 = chx+int(math.cos(math.radians(arm_a))*32)
            ay2 = chy+int(math.sin(math.radians(arm_a))*14)
            pygame.draw.line(surf,(48,40,16),(chx,chy+4),(ax2,ay2),2)
            self._flame(surf, ax2, ay2, t, seed=arm_a)
        # Treaty table
        tx2, ty2, tw2 = int(W*0.08), int(H*0.52), int(W*0.84)
        pygame.draw.rect(surf, (10,6,4),(tx2+6,ty2+6,tw2+6,30))
        pygame.draw.rect(surf, (44,24,10),(tx2,ty2,tw2,28))
        pygame.draw.rect(surf, (60,38,16),(tx2,ty2,tw2,28),3)
        for lx4 in [tx2+22, tx2+tw2-22]:
            pygame.draw.rect(surf,(32,16,4),(lx4-6,ty2+28,12,H-ty2-28))
        # Treaty document
        doc_x, doc_y = tx2+int(tw2*0.38), ty2-90
        pygame.draw.rect(surf,(8,6,4),(doc_x+5,doc_y+5,142,98))
        pygame.draw.rect(surf,(236,224,112),(doc_x,doc_y,140,96))
        pygame.draw.rect(surf,(140,100,24),(doc_x,doc_y,140,96),3)
        dt = F["tiny_b"].render("LOUISIANA TERRITORY", True, (58,38,8))
        surf.blit(dt, dt.get_rect(centerx=doc_x+70, top=doc_y+10))
        for li2 in range(9):
            lw3 = 90+random.Random(li2+20).randint(-10,18)
            pygame.draw.line(surf,(74,48,16),(doc_x+10,doc_y+24+li2*7),(doc_x+10+lw3,doc_y+24+li2*7),1)
        pygame.draw.circle(surf,(170,16,16),(doc_x+112,doc_y+76),17)
        dr = F["tiny_b"].render("R", True, GOLD)
        surf.blit(dr, dr.get_rect(center=(doc_x+112,doc_y+76)))
        ds = F["tiny_b"].render("$15,000,000", True, (42,28,8))
        surf.blit(ds, ds.get_rect(centerx=doc_x+70, bottom=doc_y+94))
        # Map on wall
        mx2, my2, mw3, mh2 = int(W*0.28), int(H*0.06), int(W*0.30), int(H*0.32)
        pygame.draw.rect(surf,(26,18,8),(mx2-4,my2-4,mw3+8,mh2+8))
        pygame.draw.rect(surf,(200,184,96),(mx2,my2,mw3,mh2))
        terr_p = [(mx2+10,my2+int(mh2*0.8)),(mx2+22,my2+int(mh2*0.2)),
                  (mx2+int(mw3*0.5),my2+int(mh2*0.1)),(mx2+mw3-12,my2+int(mh2*0.3)),
                  (mx2+mw3-18,my2+int(mh2*0.9))]
        pygame.draw.polygon(surf,(136,112,48),terr_p)
        pygame.draw.polygon(surf,(74,52,16),terr_p,2)
        ml = F["tiny_i" if "tiny_i" in F else "tiny"].render("LOUISIANA", True, (80,58,20))
        surf.blit(ml, ml.get_rect(centerx=mx2+mw3//2, top=my2+mh2+4))
        # Figures
        self._person(surf, tx2+int(tw2*0.22), ty2+2, 0.92,(26,14,8),seated=False,facing_right=True)
        self._person(surf, tx2+int(tw2*0.55), ty2+2, 0.88,(14,24,40),seated=True,facing_right=False)
        self._person(surf, tx2+int(tw2*0.68), ty2+2, 0.88,(14,24,40),seated=True,facing_right=False)
        # Candelabras
        for cndx2 in [tx2+28, tx2+tw2-28]:
            pygame.draw.line(surf,(56,36,8),(cndx2,ty2-10),(cndx2,ty2-56),4)
            for arm2 in [-18,0,18]:
                self._flame(surf, cndx2+arm2, ty2-58, t, seed=arm2*10+cndx2)
        draw_text(surf,"Tuileries Palace, Paris  ·  April 30, 1803",F["small_i"],INK_FAINT,(10,H-22))

    # ── Scene 3: Lewis packing ────────────────────────────────────────────────
    def _scene_lewis(self, surf, W, H, t):
        self._sky_grad(surf, W, H, [(14,24,8),(24,44,14),(36,58,20),(28,48,14)],
                       h_end=int(H*0.45))
        self._ground(surf, W, H,
                     [(0.45,(30,44,16),0.006,14),(0.58,(28,52,18),0.009,10),(0.72,(22,38,12),0.015,7)])
        # River
        for ri in range(int(H*0.52),int(H*0.62)):
            sh2 = math.sin(ri*0.12+t*1.5)*0.3+0.6
            surf.set_at((0,ri),(0,0,0))  # just draw as line
        pygame.draw.rect(surf,WATER_DARK,(0,int(H*0.52),W,int(H*0.10)))
        # Arsenal building
        bx2, by2, bw2, bh2 = int(W*0.26), int(H*0.10), int(W*0.66), int(H*0.48)
        pygame.draw.rect(surf,(10,12,6),(bx2+8,by2+8,bw2+8,bh2+8))
        for band in range(0, bh2, 14):
            shade2 = 18 + band%8
            pygame.draw.rect(surf,(shade2,int(shade2*0.72),int(shade2*0.56)),
                             (bx2,by2+band,bw2,12))
        pygame.draw.rect(surf,(26,22,12),(bx2-8,by2-14,bw2+16,18))
        for bm in range(bx2, bx2+bw2, 22):
            pygame.draw.rect(surf,(26,22,12),(bm,by2-22,14,10))
        for wi3 in range(bx2+30, bx2+bw2-20, 60):
            pygame.draw.rect(surf,(192,112,16),(wi3,by2+20,22,int(bh2*0.7)))
            pygame.draw.rect(surf,(26,18,8),(wi3,by2+20,22,int(bh2*0.7)),2)
            pygame.draw.line(surf,(26,18,8),(wi3+11,by2+20),(wi3+11,by2+int(bh2*0.7)),2)
        # Door arch
        dax = bx2+bw2//2
        pygame.draw.ellipse(surf,(16,10,4),(dax-22,by2+bh2-60,44,40))
        pygame.draw.rect(surf,(16,10,4),(dax-22,by2+bh2-40,44,42))
        # Barrels and crates
        for eq_x, eq_y, eq_w, eq_h, eq_type in [
            (int(W*0.04),int(H*0.52),38,32,"barrel"),(int(W*0.10),int(H*0.54),44,28,"crate"),
            (int(W*0.16),int(H*0.51),36,34,"barrel"),(int(W*0.03),int(H*0.50),30,40,"crate"),
        ]:
            if eq_type=="barrel":
                pygame.draw.ellipse(surf,(42,24,8),(eq_x,eq_y,eq_w,eq_h))
                pygame.draw.ellipse(surf,(62,40,16),(eq_x,eq_y,eq_w,eq_h),2)
                for sv in [0.25,0.5,0.75]:
                    pygame.draw.line(surf,(62,40,16),(eq_x,eq_y+int(eq_h*sv)),(eq_x+eq_w,eq_y+int(eq_h*sv)),1)
            else:
                pygame.draw.rect(surf,(36,22,6),(eq_x,eq_y,eq_w,eq_h))
                pygame.draw.rect(surf,(58,38,16),(eq_x,eq_y,eq_w,eq_h),2)
                pygame.draw.line(surf,(26,16,4),(eq_x,eq_y),(eq_x+eq_w,eq_y+eq_h),1)
                pygame.draw.line(surf,(26,16,4),(eq_x+eq_w,eq_y),(eq_x,eq_y+eq_h),1)
        # Rifle rack
        rrx, rry = bx2+bw2+14, int(H*0.44)
        pygame.draw.line(surf,(42,28,8),(rrx,rry),(rrx,rry+int(H*0.22)),4)
        for ri2 in range(8):
            rx2 = rrx+ri2*7
            pygame.draw.line(surf,(42,28,8),(rx2,rry+10),(rx2,rry+int(H*0.22)),2)
            pygame.draw.circle(surf,(26,16,4),(rx2,rry+8),2)
        # Lewis figure
        self._person(surf, int(W*0.52), int(H*0.58), 0.96, (14,20,42), seated=False)
        draw_text(surf,"Harpers Ferry Arsenal  ·  Summer 1803",F["small_i"],INK_FAINT,(10,H-22))

    # ── Scene 4: Clark reading letter ─────────────────────────────────────────
    def _scene_clark(self, surf, W, H, t):
        self._sky_grad(surf, W, H, [(10,12,20),(20,28,52),(28,38,66),(22,32,56)],
                       h_end=int(H*0.52))
        rng4 = random.Random(55)
        for _ in range(55):
            sx4, sy4 = rng4.randint(0,W), rng4.randint(0,int(H*0.48))
            bv4 = rng4.randint(50,150)
            tw4 = int(math.sin(t*2+sx4*0.06)*18)
            bv5 = max(20, min(190, bv4+tw4))
            pygame.draw.circle(surf,(bv5,bv5,int(bv5*0.82)),(sx4,sy4),1)
        self._ground(surf, W, H,
                     [(0.52,(28,44,14),0.005,18),(0.65,(22,36,8),0.008,12),(0.80,(16,28,4),0.013,7)])
        # Log farmhouse
        fhx, fhy, fhw, fhh = int(W*0.46), int(H*0.22), int(W*0.42), int(H*0.36)
        pygame.draw.rect(surf,(10,12,6),(fhx+6,fhy+6,fhw+6,fhh+8))
        for log2 in range(0, fhh, 10):
            c3 = (28,16,8) if log2%20==0 else (24,14,6)
            pygame.draw.rect(surf, c3, (fhx,fhy+log2,fhw,8))
        pygame.draw.polygon(surf,(20,16,8),
                            [(fhx-10,fhy),(fhx+fhw//2,fhy-45),(fhx+fhw+10,fhy)])
        # Chimney + smoke
        pygame.draw.rect(surf,(26,18,8),(fhx+int(fhw*0.65),fhy-56,18,fhy+4-fhy+56))
        for sp2 in range(4):
            smoke_x2 = fhx+int(fhw*0.65)+9+int(math.sin(t*1.5+sp2)*8)
            smoke_y2 = fhy-56-sp2*18-int(math.cos(t+sp2)*5)
            alpha2 = min(255, 32+(3-sp2)*12)
            ps = pygame.Surface((24,18),pygame.SRCALPHA)
            pygame.draw.ellipse(ps,(alpha2,alpha2,int(alpha2*0.9),80),(0,0,24,18))
            surf.blit(ps,(smoke_x2-12,smoke_y2-9))
        # Lit windows
        for wxi2 in [fhx+18, fhx+fhw-46]:
            pygame.draw.rect(surf,(208,128,16),(wxi2,fhy+20,22,46))
            pygame.draw.rect(surf,(26,18,8),(wxi2,fhy+20,22,46),2)
            pygame.draw.line(surf,(26,18,8),(wxi2+11,fhy+20),(wxi2+11,fhy+66),1)
            pygame.draw.line(surf,(26,18,8),(wxi2,fhy+43),(wxi2+22,fhy+43),1)
        # Split-rail fence
        for fx2 in range(0, W, 60):
            fy3 = int(H*0.62)+random.Random(fx2).randint(-4,4)
            pygame.draw.line(surf,(26,18,8),(fx2,fy3),(fx2+58,fy3+random.Random(fx2+1).randint(-3,3)),3)
            pygame.draw.line(surf,(26,18,8),(fx2+6,fy3-10),(fx2+6,fy3+14),4)
        # Lantern glow
        clark_x, clark_y = int(W*0.22), int(H*0.64)
        for lr2 in range(5,0,-1):
            gs = pygame.Surface((lr2*40, lr2*32), pygame.SRCALPHA)
            pygame.draw.ellipse(gs,(20+lr2*12, 10+lr2*6, 2, 55),(0,0,lr2*40,lr2*32))
            surf.blit(gs,(clark_x-lr2*20, clark_y-lr2*16))
        lnx2, lny2 = clark_x+48, clark_y-55
        pygame.draw.line(surf,(42,28,8),(lnx2,lny2-20),(lnx2,lny2),2)
        pygame.draw.rect(surf,(42,28,8),(lnx2-8,lny2,16,22))
        self._flame(surf, lnx2, lny2, t, seed=100)
        # Clark figure
        self._person(surf, clark_x, clark_y, 0.96, (14,20,64), seated=False)
        # Letter
        lx6, ly6 = clark_x+24, clark_y-50
        pygame.draw.rect(surf,(8,6,4),(lx6+3,ly6+3,58,46))
        pygame.draw.rect(surf,(228,216,104),(lx6,ly6,56,44))
        pygame.draw.rect(surf,(120,92,18),(lx6,ly6,56,44),2)
        for li3 in range(6):
            lw5 = 36+random.Random(li3+30).randint(-4,8)
            pygame.draw.line(surf,(58,40,8),(lx6+5,ly6+6+li3*6),(lx6+5+lw5,ly6+6+li3*6),1)
        pygame.draw.rect(surf,(192,160,32),(lx6+4,ly6+12),(lx6+52-lx6-4,8))
        draw_text(surf,"Clarksville, Indiana  ·  June 19, 1803",F["small_i"],INK_FAINT,(10,H-22))

    # ── Scene 5: Camp Dubois ──────────────────────────────────────────────────
    def _scene_camp(self, surf, W, H, t):
        self._sky_grad(surf, W, H, [(8,12,18),(14,20,32),(20,28,44),(16,22,36)],
                       h_end=int(H*0.52))
        rng5 = random.Random(77)
        for _ in range(60):
            sx5, sy5 = rng5.randint(0,W), rng5.randint(0,int(H*0.46))
            bv6 = rng5.randint(40,130)
            pygame.draw.circle(surf,(bv6,bv6,int(bv6*0.85)),(sx5,sy5),1)
        self._ground(surf, W, H,
                     [(0.50,(24,40,14),0.006,14),(0.62,(22,44,18),0.01,10),(0.75,(18,32,10),0.018,6)])
        # Moon
        pygame.draw.circle(surf,(200,196,144),(int(W*0.76),int(H*0.12)),26)
        pygame.draw.circle(surf,(14,20,32),(int(W*0.76)+14,int(H*0.10)),16)
        # Missouri River
        pygame.draw.rect(surf,WATER_DARK,(0,int(H*0.48),W,int(H*0.12)))
        for ri3 in range(int(H*0.48),int(H*0.60)):
            sh3 = math.sin(ri3*0.10+t*1.8)*0.35+0.55
            c4  = (int(14+sh3*20),int(28+sh3*16),int(40+sh3*16))
            pygame.draw.line(surf,c4,(0,ri3),(W,ri3))
        # Tents
        for ti2, tx3 in enumerate([int(W*f) for f in [0.04,0.14,0.24,0.36,0.52,0.65,0.76,0.88]]):
            tent_col = (58,44,20) if ti2%2==0 else (52,38,16)
            tent_y   = int(H*0.43)
            pygame.draw.polygon(surf, tent_col,
                                [(tx3-18,tent_y+14),(tx3,tent_y-20),(tx3+18,tent_y+14)])
            pygame.draw.polygon(surf,(72,56,24),
                                [(tx3-18,tent_y+14),(tx3,tent_y-20),(tx3+18,tent_y+14)],1)
            pygame.draw.line(surf,(72,56,22),(tx3,tent_y-20),(tx3,tent_y-32),2)
            pygame.draw.line(surf,(42,32,14),(tx3,tent_y-20),(tx3-24,tent_y+8),1)
            pygame.draw.line(surf,(42,32,14),(tx3,tent_y-20),(tx3+24,tent_y+8),1)
        # Three campfires
        for cfx, cfy in [(int(W*0.20),int(H*0.46)),(int(W*0.48),int(H*0.45)),(int(W*0.74),int(H*0.46))]:
            pygame.draw.ellipse(surf,(16,12,6),(cfx-22,cfy-10,44,18))
            pygame.draw.line(surf,(30,18,8),(cfx-18,cfy+2),(cfx+18,cfy-4),5)
            pygame.draw.line(surf,(30,18,8),(cfx-14,cfy-6),(cfx+14,cfy+4),5)
            for fi3 in range(5):
                fof3 = fi3*8-16
                flk3 = int(math.sin(t*5+fi3*1.2+cfx)*5)
                r3   = 6-fi3
                fc   = (200,96,16) if fi3<3 else (232,192,32)
                pygame.draw.ellipse(surf, fc,
                                    (cfx+fof3-r3+flk3, cfy-18-fi3*4, r3*2, fi3*4+10))
        # Keelboat
        kx2, ky2 = int(W*0.52), int(H*0.51)
        pygame.draw.polygon(surf,(10,12,8),
                            [(kx2-80,ky2),(kx2-56,ky2-14),(kx2+78,ky2-14),(kx2+86,ky2)])
        pygame.draw.rect(surf,(20,16,8),(kx2-20,ky2-38,60,24))
        for cwx in [kx2-12,kx2+8,kx2+28,kx2+44]:
            pygame.draw.rect(surf,(160,96,8),(cwx,ky2-34,8,16))
        pygame.draw.line(surf,(30,20,8),(kx2+8,ky2-14),(kx2+8,ky2-82),4)
        pygame.draw.line(surf,(30,20,8),(kx2-22,ky2-68),(kx2+44,ky2-68),2)
        # Flag
        for fi4 in range(6):
            fx3 = kx2+8+fi4*10; fy4 = ky2-82+fi4*3+int(math.sin(t*4.5+fi4*0.7)*5)
            fc2 = (136,16,16) if fi4%2==0 else (200,184,136)
            pygame.draw.rect(surf,fc2,(fx3,ky2-82,10,14))
        # Corps silhouettes
        for pi3,(px2,py2,fc3) in enumerate([
            (int(W*0.08),int(H*0.47),(14,20,8)),
            (int(W*0.14),int(H*0.47),(26,16,8)),
            (int(W*0.19),int(H*0.47),(14,20,8)),
            (int(W*0.30),int(H*0.47),(14,14,24)),
            (int(W*0.35),int(H*0.47),(26,16,8)),
        ]):
            self._person(surf,px2,py2,0.74,fc3,facing_right=(pi3%2==0))
        # Banner
        bp1x, bp2x, bpy2 = int(W*0.36), int(W*0.64), int(H*0.38)
        pygame.draw.line(surf,(42,28,8),(bp1x,bpy2),(bp1x,bpy2+int(H*0.12)),3)
        pygame.draw.line(surf,(42,28,8),(bp2x,bpy2),(bp2x,bpy2+int(H*0.12)),3)
        banner_pts = []
        for xi2 in range(40):
            bfrac = xi2/40
            bwx = bp1x + xi2*(bp2x-bp1x)//40
            bwy = bpy2 + int(math.sin(t*3+xi2*0.15)*4)
            banner_pts.append((bwx, bwy))
        full_banner = [(bp1x,bpy2)] + banner_pts + [(bp2x,bpy2),
                       (bp2x,bpy2+18),(bp1x,bpy2+18)]
        pygame.draw.polygon(surf,(136,16,16),full_banner)
        bns = F["tiny_b"].render("CORPS OF DISCOVERY", True, GOLD)
        surf.blit(bns, bns.get_rect(centerx=(bp1x+bp2x)//2, centery=bpy2+9))
        draw_text(surf,"Camp Dubois, Illinois  ·  Winter 1803–1804",F["small_i"],INK_FAINT,(10,H-22))

    # ── Scene 6: The vast Missouri River ─────────────────────────────────────
    def _scene_river(self, surf, W, H, t):
        self._sky_grad(surf, W, H, [(8,12,20),(12,18,30),(18,24,42),(14,20,34)],
                       h_end=int(H*0.56))
        rng6 = random.Random(99)
        for _ in range(90):
            sx6, sy6 = rng6.randint(0,W), rng6.randint(0,int(H*0.50))
            bv7 = rng6.randint(30,120)
            tw7 = int(math.sin(t*1.8+sx6*0.04)*15)
            bv8 = max(15, min(140, bv7+tw7))
            pygame.draw.circle(surf,(bv8,bv8,int(bv8*0.85)),(sx6,sy6),1)
        # Moon
        mx3, my3 = int(W*0.76), int(H*0.14)
        for mr2 in range(48,6,-8):
            g3 = min(255,12+mr2//2)
            ms = pygame.Surface((mr2*2,mr2*2),pygame.SRCALPHA)
            pygame.draw.circle(ms,(g3,g3,int(g3*0.9),70),(mr2,mr2),mr2)
            surf.blit(ms,(mx3-mr2,my3-mr2))
        pygame.draw.circle(surf,(212,206,148),(mx3,my3),32)
        pygame.draw.circle(surf,(12,18,30),(mx3+14,my3-12),20)
        # Bluffs
        bluff_pts2 = [(0,H)]
        for bx3 in range(0,W+4,4):
            by3 = int(H*0.47+math.sin(bx3*0.005)*28+math.sin(bx3*0.018)*14)
            bluff_pts2.append((bx3,by3))
        bluff_pts2.append((W,H))
        pygame.draw.polygon(surf,(14,20,8),bluff_pts2)
        # Missouri River — lower half
        for ri4 in range(int(H*0.46),H):
            sh4 = math.sin(ri4*0.07+t*1.6)*0.4+0.55
            depth2 = (ri4-H*0.46)/(H*0.54)
            rr2=int((12+sh4*22)*(1-depth2*0.25))
            gg2=int((28+sh4*18)*(1-depth2*0.25))
            bb2=int((44+sh4*24)*(1-depth2*0.20))
            pygame.draw.line(surf,(max(0,min(255,rr2)),max(0,min(255,gg2)),max(0,min(255,bb2))),(0,ri4),(W,ri4))
        # Moon road on water
        for mr3 in range(10):
            mry2 = int(H*0.52+mr3*14)
            msx2 = int(mx3+math.sin(t*0.8+mr3*0.3)*(mr3*4))
            mw4  = max(2,int(18-mr3))
            pygame.draw.ellipse(surf,(30,30,22),(msx2-mw4,mry2-4,mw4*2,8))
        # Three boats
        for bi3,(bfx2,bfy2,bsc3) in enumerate([(W*0.15,H*0.48,0.55),(W*0.46,H*0.50,0.80),(W*0.70,H*0.49,0.65)]):
            bx4 = int(bfx2+math.sin(t*0.4+bi3)*5); by4=int(bfy2)
            hw4=int(55*bsc3); hh4=int(11*bsc3)
            pygame.draw.polygon(surf,(8,12,6),
                                [(bx4-hw4,by4),(bx4-int(38*bsc3),by4-hh4),(bx4+hw4,by4-hh4),(bx4+int(62*bsc3),by4)])
            pygame.draw.line(surf,(14,18,8),(bx4+int(5*bsc3),by4-hh4),(bx4+int(5*bsc3),by4-hh4-int(50*bsc3)),max(1,int(2*bsc3)))
            tpx2 = bx4-int(42*bsc3); tpy2=by4-hh4
            self._flame(surf,tpx2,tpy2,t,seed=bi3*100)
        # Native fires on banks
        for nfx2,nfy2 in [(int(W*0.04),int(H*0.47)),(int(W*0.10),int(H*0.46)),
                           (int(W*0.88),int(H*0.47)),(int(W*0.94),int(H*0.46))]:
            pygame.draw.ellipse(surf,(16,10,4),(nfx2-10,nfy2-4,20,12))
            self._flame(surf,nfx2,nfy2,t,seed=nfx2)
            self._person(surf,nfx2+14,nfy2+2,0.42,(8,12,6),seated=True,facing_right=(nfx2<W//2))
        draw_text(surf,"The Louisiana Territory  ·  2,341 miles of river",F["small_i"],INK_FAINT,(10,H-22))

    # ── Scene 7: Dawn departure ───────────────────────────────────────────────
    def _scene_departure(self, surf, W, H, t):
        dawn_stops = [(10,8,6),(22,14,6),(52,32,8),(90,58,10),(136,88,14),(176,116,18),
                      (200,140,22),(176,116,18),(136,88,14)]
        self._sky_grad(surf, W, H, dawn_stops, h_end=int(H*0.50))
        # Sun
        sun_x, sun_y = W//2, int(H*0.44+math.sin(t*0.12)*4)
        for ray2 in range(24):
            ang5 = math.radians(ray2*15)
            length3 = 88+int(math.sin(t*2+ray2)*16)
            ex3 = sun_x+int(math.cos(ang5)*length3); ey3=sun_y+int(math.sin(ang5)*length3)
            pygame.draw.line(surf,(88,48,8),(sun_x,sun_y),(ex3,ey3),1)
        for sr2 in range(60,2,-10):
            frac2 = (60-sr2)/60
            rr3 = min(255,int(160*frac2+40)); gg3=min(255,int(72*frac2+12))
            pygame.draw.circle(surf,(rr3,gg3,0),(sun_x,sun_y),sr2)
        # River — gold shimmer
        for ri5 in range(int(H*0.45),H):
            sh5=math.sin(ri5*0.07+t*2.5)*0.45+0.52
            rr4=min(255,int(32+sh5*42)); gg4=min(255,int(24+sh5*22)); bb3=min(255,int(8+sh5*14))
            pygame.draw.line(surf,(rr4,gg4,bb3),(0,ri5),(W,ri5))
        # Treeline
        tree_pts2 = [(0,H)]
        for tx4 in range(0,W+6,6):
            ty4 = int(H*0.44+math.sin(tx4*0.018)*8+math.sin(tx4*0.06)*4)
            tree_pts2.append((tx4,ty4))
        tree_pts2.append((W,H))
        pygame.draw.polygon(surf,(6,8,6),tree_pts2)
        # Keelboat — animated
        kx3 = int((W*0.22+t*10*FPS/60*0.4)%(W*1.2))-int(W*0.1)
        ky3 = int(H*0.49)
        pygame.draw.polygon(surf,(8,10,6),
                            [(kx3-86,ky3),(kx3-58,ky3-18),(kx3+86,ky3-18),(kx3+94,ky3)])
        pygame.draw.rect(surf,(20,16,8),(kx3-22,ky3-44,60,26))
        for cw2 in [kx3-12,kx3+8,kx3+28,kx3+44]:
            pygame.draw.rect(surf,(192,120,16),(cw2,ky3-40,8,18))
        pygame.draw.line(surf,(30,22,8),(kx3+10,ky3-18),(kx3+10,ky3-96),5)
        pygame.draw.line(surf,(30,22,8),(kx3-22,ky3-80),(kx3+44,ky3-80),2)
        for fi5 in range(6):
            fx4=kx3+10+fi5*10; fy5=ky3-96+fi5*3+int(math.sin(t*4.5+fi5*0.7)*6)
            fc4=(136,16,16) if fi5%2==0 else (200,184,136)
            pygame.draw.rect(surf,fc4,(fx4,ky3-96,10,16))
        # Two pirogues
        for pirx, pird in [(kx3-122,-1),(kx3+112,1)]:
            px3 = pirx+int(math.sin(t*0.5+pirx)*4); py3=int(H*0.50)
            pygame.draw.polygon(surf,(12,14,10),
                                [(px3-28,py3),(px3-18,py3-8),(px3+28,py3-8),(px3+32,py3)])
            self._person(surf,px3+8*pird,py3-10,0.46,(14,12,8),seated=True,facing_right=(pird>0))
        # Crowd waving
        crowd_y2 = int(H*0.44)
        for pi4 in range(30):
            px4 = pi4*48+8; wave4=math.sin(t*3.2+pi4)*8
            c5  = (10,14,8)
            pygame.draw.rect(surf,c5,(px4-5,crowd_y2-18,10,18))
            pygame.draw.circle(surf,c5,(px4,crowd_y2-20),6)
            pygame.draw.line(surf,c5,(px4+5,crowd_y2-12),(px4+int(16*math.sin(t*3+pi4)),crowd_y2-12-int(abs(wave4))),3)
        # Shore flag
        pygame.draw.line(surf,(30,22,8),(int(W*0.88),crowd_y2),(int(W*0.88),crowd_y2-52),3)
        for fi6 in range(4):
            fx5=int(W*0.88)+fi6*10; fy6=crowd_y2-52+fi6*3+int(math.sin(t*4+fi6*0.8)*5)
            fc5=(136,16,16) if fi6%2==0 else (200,184,136)
            pygame.draw.rect(surf,fc5,(fx5,crowd_y2-52,10,14))
        # Date stamp
        dt2 = F["title"].render("MAY 14, 1804  ·  4 O'CLOCK IN THE AFTERNOON", True, GOLD)
        surf.blit(dt2, dt2.get_rect(centerx=W//2, bottom=H-32))
        ds2 = F["body_i"].render("Camp Dubois  ·  The Adventure Begins", True, PARCH_EDGE)
        surf.blit(ds2, ds2.get_rect(centerx=W//2, bottom=H-14))

    def handle(self, event):
        if event.type == pygame.KEYDOWN:
            if event.key in (pygame.K_RETURN, pygame.K_SPACE, pygame.K_RIGHT):
                if self.idx < len(CINE_SCENES)-1: self.advance()
                else: self.on_done()
            elif event.key == pygame.K_LEFT: self.retreat()
            elif event.key == pygame.K_ESCAPE: self.on_done()

        if self.next_btn.handle(event): self.advance()
        if self.back_btn.handle(event): self.retreat()
        if self.skip_btn.handle(event): self.on_done()
        if self.begin_btn.handle(event): self.on_done()

# ═══════════════════════════════════════════════════════════════════════════════
#  TITLE SCREEN
# ═══════════════════════════════════════════════════════════════════════════════
class TitleScreen:
    def __init__(self, on_start, on_load):
        self.on_start  = on_start
        self.on_load   = on_load
        self.frame     = 0
        self.start_btn = Button((SW//2-160, SH-180, 320, 54),
                                "⚑  BEGIN EXPEDITION  ⚑",
                                fill=GOLD, fill_h=GOLD2, text_col=INK, text_h=INK,
                                font=F["btn_lg"])
        self.load_btn  = Button((SW//2-120, SH-112, 240, 38),
                                "Load Saved Expedition",
                                fill=UI_CARD2, text_col=PARCH_DARK)

    def draw(self, surf):
        f = self.frame; t = f*0.018
        self.frame += 1
        W, H = SW, SH

        # ── Parallax sky ─────────────────────────────────────────────────────
        for i in range(int(H*0.62)):
            frac = i/(H*0.62)
            r = int(12+frac*20); g=int(9+frac*14); b=int(5+frac*8)
            pygame.draw.line(surf,(r,g,b),(0,i),(W,i))

        # Stars
        rng7 = random.Random(42)
        for _ in range(130):
            sx7, sy7 = rng7.randint(0,W), rng7.randint(0,int(H*0.40))
            bv9 = rng7.randint(60,150)
            tw8 = int(math.sin(t*2.5+sx7*0.1)*20)
            bv10= max(20,min(200,bv9+tw8))
            pygame.draw.circle(surf,(bv10,bv10,int(bv10*0.85)),(sx7,sy7),1)

        # Moon
        mx4, my4 = int(W*0.80), int(H*0.14)
        pygame.draw.circle(surf,(216,204,160),(mx4,my4),38)
        pygame.draw.circle(surf,(18,18,24),(mx4+14,my4-20),26)

        # Parallax layers
        pan1 = int(math.sin(t*0.12)*8)
        for mxf, myf, mwf, mc in [(0.82,0.30,0.18,(20,16,8)),(0.60,0.26,0.16,(16,16,8)),
                                    (0.38,0.28,0.14,(20,16,8)),(0.18,0.24,0.12,(16,16,8))]:
            mx5=(mxf+pan1/W)*W; my5=myf*H; mw5=mwf*W
            pygame.draw.polygon(surf,mc,[(mx5-mw5,H*0.62),(mx5,my5),(mx5+mw5,H*0.62)])

        # River valley + foreground
        pan2 = int(math.sin(t*0.18)*12)
        riv_pts = [(0,H)]
        for rx2 in range(0,W+8,8):
            ry2 = int(H*0.58+math.sin((rx2+pan2)*0.008)*18+math.sin((rx2+pan2)*0.022)*8)
            riv_pts.append((rx2,ry2))
        riv_pts.append((W,H)); pygame.draw.polygon(surf,(26,44,16),riv_pts)
        # River shimmer
        for ri6 in range(int(H*0.60),int(H*0.66)):
            sh6 = math.sin(ri6*0.12+t*2)*0.35+0.55
            pygame.draw.line(surf,(int(16+sh6*20),int(30+sh6*14),int(40+sh6*12)),(0,ri6),(W,ri6))
        pan3 = int(math.sin(t*0.25)*16)
        fg_pts = [(0,H)]
        for rx3 in range(0,W+8,8):
            ry3 = int(H*0.68+math.sin((rx3+pan3)*0.012)*12+math.sin((rx3+pan3)*0.03)*6)
            fg_pts.append((rx3,ry3))
        fg_pts.append((W,H)); pygame.draw.polygon(surf,(14,24,8),fg_pts)

        # Campfire
        fgx, fgy = int(W*0.22), int(H*0.70)
        for gr2 in range(5,0,-1):
            gs2 = pygame.Surface((gr2*28,gr2*18),pygame.SRCALPHA)
            pygame.draw.ellipse(gs2,(24+gr2*8,12+gr2*4,2,50),(0,0,gr2*28,gr2*18))
            surf.blit(gs2,(fgx-gr2*14,fgy-gr2*8))
        for fi7 in range(4):
            fof4=fi7*6-9; flk4=int(math.sin(t*7+fi7)*5)
            pygame.draw.ellipse(surf,(208,112,16),(fgx+fof4-5+flk4,fgy-20,10,14))
            pygame.draw.ellipse(surf,(240,208,32),(fgx+fof4-3+flk4,fgy-28,6,12))
        pygame.draw.line(surf,(26,18,8),(fgx-20,fgy+2),(fgx+20,fgy-4),5)
        pygame.draw.line(surf,(26,18,8),(fgx-15,fgy-4),(fgx+25,fgy+2),5)
        for fx5,fy7,c6 in [(fgx-50,fgy-5,(10,14,8)),(fgx+42,fgy-8,(10,14,8)),(fgx-18,fgy-12,(12,16,8))]:
            pygame.draw.circle(surf,c6,(fx5,fy7-8),6)
            pygame.draw.rect(surf,c6,(fx5-8,fy7-2,16,14))

        # Keelboat silhouette
        bx5=int(W*0.65-(f*0.5)%W)
        by5=int(H*0.615)
        pygame.draw.polygon(surf,(8,12,8),[(bx5-55,by5),(bx5-38,by5-12),(bx5+55,by5-12),(bx5+62,by5)])
        pygame.draw.line(surf,(12,16,8),(bx5+8,by5-12),(bx5+8,by5-52),3)
        for fi8 in range(4):
            fx6=bx5+8+fi8*10; fy8=by5-52+fi8*2+int(math.sin(t*4+fi8*0.8)*4)
            pygame.draw.line(surf,(106,12,14) if fi8%2==0 else (160,144,112),(bx5+8,by5-52),(fx6+10,fy8),2)

        # ── Title text ────────────────────────────────────────────────────────
        rule_y = int(H*0.28)
        pygame.draw.line(surf,PARCH_EDGE,(W//2-220,rule_y),(W//2+220,rule_y),1)
        for ox in [-220,220]:
            pygame.draw.polygon(surf,GOLD,[(W//2+ox,rule_y),(W//2+ox+8,rule_y-4),
                                            (W//2+ox+16,rule_y),(W//2+ox+8,rule_y+4)])

        title_y = int(H*0.32)
        ts7 = F["huge"].render("LEWIS & CLARK", True, INK)
        surf.blit(ts7, ts7.get_rect(centerx=W//2+2, top=title_y+2))
        ts8 = F["huge"].render("LEWIS & CLARK", True, GOLD)
        surf.blit(ts8, ts8.get_rect(centerx=W//2, top=title_y))

        sub_y = title_y+58
        ts9 = F["display"].render("EXPEDITION", True, INK)
        surf.blit(ts9, ts9.get_rect(centerx=W//2+2, top=sub_y+2))
        ts10 = F["display"].render("EXPEDITION", True, GOLD2)
        surf.blit(ts10, ts10.get_rect(centerx=W//2, top=sub_y))

        tag_y = sub_y+52
        pygame.draw.line(surf,PARCH_EDGE,(W//2-160,tag_y-8),(W//2+160,tag_y-8),1)
        draw_text(surf,"Corps of Discovery  ·  1804–1806",F["year"],PARCH_EDGE,(W//2,tag_y+4),anchor="midtop")
        pygame.draw.line(surf,PARCH_EDGE,(W//2-160,tag_y+22),(W//2+160,tag_y+22),1)

        if f > 80:
            alpha3 = min(255, (f-80)*6)
            qa = min(255,alpha3)
            qc = (max(0,int(106*qa/255)),max(0,int(80*qa/255)),max(0,int(40*qa/255)))
            draw_text(surf,'"The object of your mission is to explore the Missouri River..."',
                      F["body_i"],qc,(W//2,tag_y+44),anchor="midtop")
            draw_text(surf,"— President Thomas Jefferson, 1803",
                      F["tiny"],qc,(W//2,tag_y+64),anchor="midtop")

        self.start_btn.draw(surf)
        self.load_btn.draw(surf)

    def handle(self, event, on_start, on_load):
        if self.start_btn.handle(event): on_start()
        if self.load_btn.handle(event):  on_load()


# ═══════════════════════════════════════════════════════════════════════════════
#  GAME SCREEN
# ═══════════════════════════════════════════════════════════════════════════════
class GameScreen:
    """Main gameplay screen — map + right panel."""
    PANEL_X  = 924
    PANEL_W  = SW - PANEL_X - 4
    HEADER_H = 50

    def __init__(self, state, on_menu):
        self.state    = state
        self.on_menu  = on_menu
        self.map_view = MapView()
        self.mode     = "travel"   # travel | event | trade | inventory | end
        self.pending_event  = None
        self.pending_route_choices = []  # list of Button
        self.action_btns    = []
        self.scroll_panel   = ScrollPanel(
            pygame.Rect(self.PANEL_X, self.HEADER_H+4+200, self.PANEL_W, 220))
        self.journal_panel  = ScrollPanel(
            pygame.Rect(self.PANEL_X, self.HEADER_H+4, self.PANEL_W, 192))
        self._build_travel_ui()
        self._update_journal()
        self._check_objectives()

    # ── Journal ───────────────────────────────────────────────────────────────
    def _update_journal(self):
        TAG_COLS = {
            "OBJECTIVE": GREEN2, "COMPLETE": GREEN2, "FAILED": RED2,
            "hunt": (78,180,64), "trade": TEAL2, "camp": BLUE2,
            "discover": GOLD2,
        }
        lines = []
        for entry in reversed(self.state.journal[-24:]):
            if entry.startswith("["):
                end = entry.find("]")
                lines.append((entry[:end+1], F["mono_sm"], GOLD))
                rest = entry[end+1:].strip()
                col = PARCH_DARK
                for kw, c in TAG_COLS.items():
                    if kw.lower() in rest.lower(): col = c; break
                lines.append((rest, F["mono"], col))
                lines.append(("", F["tiny"], DIM))
            else:
                lines.append((entry, F["mono"], PARCH_DARK))
        self.journal_panel.set_lines(lines)

    # ── Travel actions UI ─────────────────────────────────────────────────────
    def _build_travel_ui(self):
        self.mode = "travel"
        self.action_btns = []
        s = self.state; wp = s.current_wp
        if wp >= len(WAYPOINTS)-1:
            self._start_end_game(); return

        routes = ROUTE_OPTIONS.get((wp, wp+1), [])
        PX = self.PANEL_X+4; BW = self.PANEL_W-8; by = self.HEADER_H+4+428

        RISK_COLS = {"low":GREEN2,"medium":GOLD,"high":AMBER,"very_high":RED2}
        TAG_ICONS = {"river":"≈ ","land":"~ ","mountain":"▲ "}
        for i, route in enumerate(routes):
            rc = RISK_COLS.get(route["risk"],GOLD)
            lbl = TAG_ICONS.get(route["tag"],"  ") + route["name"]
            sub = f'{route["days"]}d  food{route["food"]:+d}  hp{route["health"]:+d}  moral{route["morale"]:+d}  [{route["risk"]}]'
            btn = Button((PX, by+i*52, BW, 44), lbl,
                         fill=UI_CARD, fill_h=darken(rc,0.4), text_col=PARCH,
                         sub=sub)
            btn._route = route
            self.action_btns.append(btn)

        by2 = by + len(routes)*52 + 8
        # Hunt
        hunt_sub = "Drouillard leads (+15 food)" if s.characters.get("drouillard",{}).get("active") else "3-4hrs · +8-18 food · risk injury"
        b_hunt = Button((PX, by2, BW//2-2, 36), "Hunt",fill=darken(GREEN2,0.5),
                        fill_h=GREEN2, text_col=PARCH, sub=hunt_sub)
        b_hunt._action = "hunt"; self.action_btns.append(b_hunt)
        # Camp
        b_camp = Button((PX+BW//2+2, by2, BW//2-2, 36), "Make Camp",
                        fill=darken(BLUE2,0.5),fill_h=BLUE2,text_col=PARCH,
                        sub="+10hp +8mor -10food · may trigger camp event")
        b_camp._action = "camp"; self.action_btns.append(b_camp)
        # Trade council if tribe present
        tk_key = TRIBE_AT_WAYPOINT.get(wp)
        if tk_key:
            tribe = TRIBES[tk_key]; rel=s.tribe_relations.get(tk_key,50)
            rt = "Friendly" if rel>=60 else "Neutral" if rel>=40 else "Tense"
            b_trade = Button((PX, by2+42, BW, 34), f"Council — {tribe['name']} Nation",
                             fill=darken(TEAL2,0.5),fill_h=TEAL2,text_col=PARCH,
                             sub=f"Relations: {rt} ({rel}/100)")
            b_trade._action = "trade"; b_trade._tribe = tk_key
            self.action_btns.append(b_trade)
        # Inventory
        b_inv = Button((PX, SH-40, BW, 34), "View Inventory",
                       fill=UI_CARD2, text_col=DIM2, font=F["small"])
        b_inv._action = "inventory"; self.action_btns.append(b_inv)

    def _build_event_ui(self, event):
        self.mode = "event"; self.action_btns = []
        chars = {k:v["active"] for k,v in self.state.characters.items()}
        PX = self.PANEL_X+4; BW = self.PANEL_W-8; by = self.HEADER_H+4+440

        TYPE_COLS = {"wildlife":GREEN2,"weather":BLUE2,"diplomacy":TEAL2,
                     "hardship":AMBER,"illness":RED2,"discovery":GOLD2}
        acc = TYPE_COLS.get(event.get("type",""),GOLD)

        # Build scroll panel content
        lines = [
            (event["title"], F["header"], acc),
            (event.get("type","event").upper(), F["tiny_b"], darken(acc,0.7)),
            ("", F["tiny"], DIM),
            (event["intro"], F["body"], PARCH_DARK),
            ("", F["tiny"], DIM),
            ("— Choose your response —", F["small_i"], DIM2),
        ]
        self.scroll_panel.set_lines(lines)

        for i, choice in enumerate(event["choices"]):
            req = choice.get("requires_char")
            has = chars.get(req,True) if req else True
            eff = choice.get("effect",{})
            effs = "  ".join(f"{'+'if v>0 else''}{v} {k}" for k,v in eff.items()
                             if isinstance(v,(int,float)) and v)
            net = sum(v for v in eff.values() if isinstance(v,(int,float)))
            if req and not has:
                fc = darken(UI_CARD,0.7); tc = DIM; dis = True
                lbl = f"[{SPECIAL_CHARACTERS[req]['name']} required]  {choice['label']}"
            elif req and has:
                fc = darken(AMBER,0.5); tc = PARCH; dis = False; lbl = choice["label"]
            else:
                ec2 = darken(GREEN2,0.5) if net>5 else darken(RED2,0.5) if net<-15 else darken(GOLD,0.5)
                fc = ec2; tc = PARCH; dis = False; lbl = choice["label"]
            btn = Button((PX, by+i*48, BW, 40), lbl, fill=fc, text_col=tc, sub=effs or None)
            btn.disabled = dis; btn._choice = i
            self.action_btns.append(btn)

    def _build_trade_ui(self, tribe_key):
        self.mode = "trade"; self.action_btns = []; self._trade_tribe = tribe_key
        s = self.state; tribe = TRIBES[tribe_key]
        rel = s.tribe_relations.get(tribe_key,50)
        chars = {k:v["active"] for k,v in s.characters.items()}
        er = min(100, rel+(20 if chars.get("sacagawea") else 0)+(10 if chars.get("york") else 0))
        PX = self.PANEL_X+4; BW = self.PANEL_W-8; by = self.HEADER_H+4+440

        rt = "Friendly" if er>=60 else "Neutral" if er>=40 else "Tense"
        wants_str = "  ·  ".join(f"{g}: {s.inventory.get(g,0)}" for g in tribe["wants"])
        offers_str = "  ·  ".join(tribe["offers"])

        lines = [
            (f"{tribe['name']} Nation — Council", F["header"], TEAL2),
            (f"Relations: {rt} ({er}/100)", F["body"], GREEN2 if er>=60 else GOLD if er>=40 else RED2),
            ("", F["tiny"], DIM),
            (f"They desire: {wants_str}", F["body"], PARCH_DARK),
            (f"They offer:  {offers_str}", F["body"], GOLD),
        ]
        self.scroll_panel.set_lines(lines)

        trade_actions = [
            ("Offer Gifts (Tobacco / Beads)", "gifts",
             s.inventory.get("Tobacco",0)+s.inventory.get("Trade Beads",0)<3),
            ("Trade for their goods", "goods", False),
            ("Present a Jefferson Peace Medal", "medal",
             s.inventory.get("Jefferson Medals",0)<1),
            ("Share maps and route knowledge","maps", False),
            ("Continue without trading", "leave", False),
        ]
        if chars.get("sacagawea"):
            btn_s = Button((PX,by,BW,38),"Sacagawea negotiates in their tongue",
                           fill=darken(AMBER,0.5),text_col=PARCH,
                           sub="Best possible outcome — full trust")
            btn_s._trade_action="sacagawea_speak"; self.action_btns.append(btn_s)
            by += 44

        for lbl,act,dis in trade_actions:
            btn = Button((PX,by,BW,36),lbl,fill=darken(TEAL2,0.5),text_col=PARCH)
            btn.disabled=dis; btn._trade_action=act; self.action_btns.append(btn)
            by += 42

    def _start_end_game(self):
        self.mode="end"; self.action_btns=[]
        s = self.state; s.game_over=True
        score = len(s.completed_objectives)
        iv    = sum(TRADE_GOOD_VALUES.get(k,1)*v for k,v in s.inventory.items() if v>0)
        if score>=6: rating,rc="LEGENDARY",GOLD2
        elif score>=5: rating,rc="TRIUMPHANT",GOLD
        elif score>=3: rating,rc="PARTIAL SUCCESS",PARCH_DARK
        else:          rating,rc="PYRRHIC",DIM
        s.add_journal(f"EXPEDITION COMPLETE — {score}/6 objectives. Rating: {rating}.")
        self._update_journal()
        PX=self.PANEL_X+4; BW=self.PANEL_W-8
        b_new=Button((PX,SH-92,BW,40),"⚑  New Expedition",fill=GOLD,fill_h=GOLD2,text_col=INK,text_h=INK,font=F["btn_lg"])
        b_new._action="new"; self.action_btns.append(b_new)
        b_save=Button((PX,SH-44,BW,36),"Save Record",fill=UI_CARD2,text_col=DIM2)
        b_save._action="save"; self.action_btns.append(b_save)

    # ── Check objectives ──────────────────────────────────────────────────────
    def _check_objectives(self):
        s=self.state
        if s.current_wp>=4 and 0 not in s.completed_objectives:
            s.completed_objectives.append(0)
            s.add_journal("OBJECTIVE COMPLETE: Wintered at Fort Mandan.")
            s.characters["sacagawea"]["active"]=True
            s.add_journal("Sacagawea joins the corps at Fort Mandan.")
        if s.current_wp>=7 and 1 not in s.completed_objectives:
            s.completed_objectives.append(1)
            s.add_journal("OBJECTIVE COMPLETE: Crossed the Continental Divide!")
        if s.current_wp>=9 and 2 not in s.completed_objectives:
            s.completed_objectives.append(2)
            s.add_journal("OBJECTIVE COMPLETE: Reached the Pacific Ocean!")
        if s.peaceful_tribes>=3 and 3 not in s.completed_objectives:
            s.completed_objectives.append(3)
            s.add_journal("OBJECTIVE COMPLETE: Peaceful relations with 3 tribes.")
        if s.discoveries>=5 and 5 not in s.completed_objectives:
            s.completed_objectives.append(5)
            s.add_journal("OBJECTIVE COMPLETE: Five discoveries documented.")
        self._update_journal()

    # ── Draw ─────────────────────────────────────────────────────────────────
    def draw(self, surf):
        s = self.state
        # Header bar
        pygame.draw.rect(surf, UI_BG, (0,0,SW,self.HEADER_H))
        pygame.draw.rect(surf, UI_BORDER, (0,0,SW,self.HEADER_H),1)
        pygame.draw.line(surf,GOLD,(0,self.HEADER_H-2),(SW,self.HEADER_H-2),2)
        draw_text(surf,"⚑  LEWIS & CLARK EXPEDITION  ·  CORPS OF DISCOVERY  ⚑",
                  F["title"],GOLD,(SW//2,self.HEADER_H//2),anchor="center")
        # Season / date right
        sc2 = SEASON_COL.get(s.season,DIM)
        draw_text(surf,f"{s.season}  ·  {s.date_str}",F["small"],sc2,(SW-8,10),anchor="topright")
        draw_text(surf,f"Waypoint {s.current_wp+1}/{len(WAYPOINTS)}",F["tiny"],DIM2,(SW-8,26),anchor="topright")

        # Map
        self.map_view.draw(surf, s)

        # Right panel background
        pygame.draw.rect(surf, UI_BG, (self.PANEL_X,self.HEADER_H,self.PANEL_W,SH-self.HEADER_H))
        pygame.draw.rect(surf, UI_BORDER,(self.PANEL_X,self.HEADER_H,self.PANEL_W,SH-self.HEADER_H),1)

        # Stat bars
        PX = self.PANEL_X+6; PW = self.PANEL_W-12
        stat_bar(surf, PX,    self.HEADER_H+8,  PW//3-2, 10, s.food,   GOLD,  "FOOD")
        stat_bar(surf, PX+PW//3+2, self.HEADER_H+8, PW//3-4,10,s.health,GREEN2,"HEALTH")
        stat_bar(surf, PX+PW*2//3+2,self.HEADER_H+8,PW//3-4,10,s.morale,BLUE2,"MORALE")

        # Character cards row
        chy = self.HEADER_H+38; chh = 58; cw = (PW-4)//3
        for ci,(key, cdata) in enumerate(s.characters.items()):
            cx2 = PX + ci*(cw+2)
            active = cdata["active"]
            base   = SPECIAL_CHARACTERS[key]
            bc     = UI_CARD if active else UI_PANEL
            pygame.draw.rect(surf, bc, (cx2,chy,cw,chh), border_radius=3)
            pygame.draw.rect(surf, GOLD if active else UI_BORDER,(cx2,chy,cw,chh),1,border_radius=3)
            nc2 = PARCH if active else DIM2
            draw_text(surf, base["name"],  F["small"],   nc2, (cx2+6, chy+6))
            draw_text(surf, base["title"][:18], F["tiny"], DIM2, (cx2+6, chy+22), max_w=cw-8)
            sc3 = GREEN2 if active else DIM
            st2 = "● Active" if active else f"Joins: wp {base['joined_at']}"
            draw_text(surf, st2, F["tiny"], sc3, (cx2+6, chy+40))

        # Journal panel
        self.journal_panel.draw(surf)

        # Action area label
        mode_labels = {"travel":"TRAVEL OPTIONS","event":"EVENT","trade":"TRADE COUNCIL",
                       "inventory":"INVENTORY","end":"EXPEDITION COMPLETE"}
        lbl2 = mode_labels.get(self.mode,"ACTIONS")
        draw_text(surf, lbl2, F["subhead"], GOLD, (PX, self.HEADER_H+4+196))

        # Scroll panel (event intro / trade info)
        if self.mode in ("event","trade"):
            self.scroll_panel.draw(surf)

        # End game summary
        if self.mode == "end":
            self._draw_end_summary(surf)

        # Action buttons
        for btn in self.action_btns:
            btn.draw(surf)

        # Objectives strip at bottom of panel
        self._draw_objectives(surf)

    def _draw_end_summary(self, surf):
        s=self.state; PX=self.PANEL_X+6; PW=self.PANEL_W-12
        score=len(s.completed_objectives)
        iv=sum(TRADE_GOOD_VALUES.get(k,1)*v for k,v in s.inventory.items() if v>0)
        QUOTES={6:'"The object of your mission is accomplished." — Lewis',
                5:'"Ocean in view! O! The joy!" — Clark',
                3:'"We have lived through extraordinary difficulties." — Lewis',
                0:'"The Missouri is a treacherous river." — Clark'}
        q=QUOTES.get(max(k for k in QUOTES if k<=score),'')
        RATINGS=[(6,GOLD2,"LEGENDARY"),(5,GOLD,"TRIUMPHANT"),(3,PARCH_DARK,"PARTIAL SUCCESS"),(0,DIM,"PYRRHIC")]
        rating,rc,rlbl=next((r,c,n) for n,c,r in [(6,GOLD2,"LEGENDARY"),(5,GOLD,"TRIUMPHANT"),(3,PARCH_DARK,"PARTIAL SUCCESS"),(0,DIM,"PYRRHIC")] if score>=n)
        ey=self.HEADER_H+4+210
        for lbl3,val,vc in [("OBJECTIVES",f"{score}/6",rc),("WAYPOINTS",f"{s.current_wp}/9",GOLD),
                              ("DISCOVERIES",str(s.discoveries),GOLD2),("TRADE VALUE",str(iv),AMBER)]:
            draw_text(surf,lbl3,F["tiny"],DIM2,(PX,ey))
            draw_text(surf,val,F["header"],vc,(PX+PW//2,ey),anchor="midtop")
            ey+=32
        draw_text(surf,rlbl,F["cine"],rc,(PX+PW//2,ey+8),anchor="midtop")
        ey+=42
        draw_text(surf,q,F["small_i"],PARCH_EDGE,(PX,ey),max_w=PW)

    def _draw_objectives(self, surf):
        s=self.state; PX=self.PANEL_X+6; PW=self.PANEL_W-12
        objs=["Fort Mandan","Divide","Clatsop",f"3 Tribes ({s.peaceful_tribes}/3)",
              "Healthy finish",f"5 Discoveries ({s.discoveries}/5)"]
        oy=SH-158
        draw_text(surf,"OBJECTIVES",F["tiny_b"],DIM2,(PX,oy)); oy+=14
        for i,txt in enumerate(objs):
            done=i in s.completed_objectives
            col=GREEN2 if done else DIM2
            sym="✓" if done else "·"
            draw_text(surf,f"{sym} {txt}",F["tiny"],col,(PX,oy)); oy+=14

    # ── Handle events ─────────────────────────────────────────────────────────
    def handle(self, event, on_new_game, on_save, on_load):
        self.journal_panel.handle(event)
        if self.mode in ("event","trade"):
            self.scroll_panel.handle(event)

        self.map_view.handle(event, self.state, self._on_hex_move)

        for btn in self.action_btns:
            if btn.handle(event):
                self._button_clicked(btn, on_new_game, on_save)

        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_s and pygame.key.get_mods() & pygame.KMOD_CTRL:
                on_save()

    def _on_hex_move(self, wp_id):
        """Player clicked a waypoint on the map."""
        s = self.state
        if wp_id == s.current_wp + 1:
            routes = ROUTE_OPTIONS.get((s.current_wp, wp_id), [])
            if routes:
                self._show_route_choices(routes)
            else:
                self._do_travel({"name":"Overland","tag":"land","food":-10,"health":-5,"morale":0,"days":14})
        elif wp_id == s.current_wp:
            event = self._pick_event()
            if event:
                self.pending_event = event
                self._build_event_ui(event)

    def _show_route_choices(self, routes):
        """Show route selection in action panel."""
        self.mode = "travel"
        self.action_btns = []
        PX = self.PANEL_X+4; BW = self.PANEL_W-8; by = self.HEADER_H+4+428
        RISK_C={"low":GREEN2,"medium":GOLD,"high":AMBER,"very_high":RED2}
        TAG_I={"river":"≈ ","land":"~ ","mountain":"▲ "}
        for route in routes:
            rc = RISK_C.get(route["risk"],GOLD)
            lbl = TAG_I.get(route["tag"],"  ") + route["name"]
            sub = f'{route["days"]}d  food{route["food"]:+d}  hp{route["health"]:+d}  mor{route["morale"]:+d}  [{route["risk"]}]'
            btn = Button((PX, by, BW, 44), lbl, fill=UI_CARD,
                         fill_h=darken(rc,0.4), text_col=PARCH, sub=sub)
            btn._route=route; self.action_btns.append(btn); by+=52
        back=Button((PX,by,BW,34),"Cancel",fill=UI_PANEL,text_col=DIM2)
        back._action="cancel_route"; self.action_btns.append(back)

    def _do_travel(self, route):
        s = self.state
        s.route_taken.append(route["name"])
        s.current_wp += 1
        s.advance_date(route.get("days",14))
        s.food   += route["food"]
        s.health += route["health"]
        s.morale += route["morale"]
        # Season modifiers
        mods={"Winter":{"health":-8,"food":-5},"Summer":{"food":-4},"Spring":{"morale":3}}
        for k,v in mods.get(s.season,{}).items(): setattr(s,k,getattr(s,k)+v)
        # Sacagawea mountain bonus
        if route.get("tag")=="mountain" and s.characters.get("sacagawea",{}).get("active"):
            s.health += 8
        wp2 = WAYPOINTS[s.current_wp]
        s.add_journal(f"Arrived at {wp2['name']} via {route['name']}.")
        s.clamp()
        self._check_objectives()
        self._update_journal()
        # Maybe trigger event
        event = self._pick_event()
        if event:
            self.pending_event = event
            self._build_event_ui(event)
        else:
            self._build_travel_ui()

    def _pick_event(self):
        s = self.state; season = s.season
        eligible = [e for e in EVENTS if e["id"] not in s.events_seen or random.random()<0.25]
        pool = [e for e in eligible if not e.get("season") or season in e["season"]]
        if not pool: pool = EVENTS
        e2 = random.choice(pool)
        if e2["id"] not in s.events_seen: s.events_seen.append(e2["id"])
        return e2

    def _resolve_event(self, choice_idx):
        ev = self.pending_event
        if not ev: return
        choice = ev["choices"][choice_idx]; s = self.state
        chars = {k:v["active"] for k,v in s.characters.items()}
        s.apply_effect(choice.get("effect",{}), chars)
        rb = choice.get("relation_bonus",0) or ev.get("relation_bonus",0)
        if rb:
            tk_key = TRIBE_AT_WAYPOINT.get(s.current_wp)
            if tk_key:
                s.tribe_relations[tk_key]=min(100,s.tribe_relations.get(tk_key,50)+rb)
        if choice.get("discovery") or ev.get("type")=="discovery": s.discoveries+=1
        for item,qty in choice.get("inventory_gain",{}).items():
            s.inventory[item]=s.inventory.get(item,0)+qty
        s.add_journal(f"{ev['title']}: {choice['text']}")
        self.pending_event=None; s.clamp()
        if s.food<=0:
            s.add_journal("The corps has starved."); self._start_end_game(); return
        if s.health<=0:
            s.add_journal("Too many men lost."); self._start_end_game(); return
        self._check_objectives(); self._update_journal(); self._build_travel_ui()

    def _do_hunt(self):
        s = self.state; has_d = s.characters.get("drouillard",{}).get("active",False)
        roll = random.random(); s.advance_date(1)
        if roll < 0.15:
            dmg=random.randint(8,18); s.health=max(0,s.health-dmg)
            s.add_journal(f"Hunting accident — lost {dmg} health.")
        elif roll < 0.45:
            gain=random.randint(5,12)+(8 if has_d else 0)
            s.food=min(100,s.food+gain)
            s.add_journal(f"Modest hunt: +{gain} food.")
        elif roll < 0.80:
            gain=random.randint(12,22)+(12 if has_d else 0)
            s.food=min(100,s.food+gain); s.morale=min(100,s.morale+6)
            s.add_journal(f"Good hunt: +{gain} food.")
        else:
            gain=random.randint(22,38)+(15 if has_d else 0)
            s.food=min(100,s.food+gain); s.morale=min(100,s.morale+14)
            s.add_journal(f"Exceptional hunt: +{gain} food!")
        s.clamp(); self._update_journal(); self._build_travel_ui()

    def _do_camp(self):
        s=self.state
        s.health=min(100,s.health+10); s.morale=min(100,s.morale+8); s.food=max(0,s.food-10)
        s.advance_date(3)
        camp_events=[
            ("Wolves at the Perimeter","Wolves circled camp all night.",0,-4,-8),
            ("Seaman's Heroics","Seaman barked an alarm, saving the corps from a buffalo stampede.",5,5,12),
            ("Cruzatte's Fiddle","Cruzatte played until midnight. The men danced under the stars.",0,3,18),
            ("Illness in Camp","Several men awoke with fever.",- 5,-12,-8),
            ("Meteor Shower","A display of shooting stars lasted for hours.",0,2,15),
            ("Native Visitors","A small band of curious natives visited camp. Friendly exchange.",8,0,10),
        ]
        s.add_journal("Made camp for three days — rested and restored spirits.")
        if random.random()<0.4:
            ev2=random.choice(camp_events)
            s.food=max(0,min(100,s.food+ev2[2]))
            s.health=max(0,min(100,s.health+ev2[3]))
            s.morale=max(0,min(100,s.morale+ev2[4]))
            s.add_journal(f"Camp event — {ev2[0]}: {ev2[1]}")
        s.clamp(); self._update_journal(); self._build_travel_ui()

    def _resolve_trade(self, action, tribe_key):
        s=self.state; tribe=TRIBES[tribe_key]
        chars={k:v["active"] for k,v in s.characters.items()}
        rel=s.tribe_relations.get(tribe_key,50)
        if action=="sacagawea_speak":
            s.tribe_relations[tribe_key]=min(100,rel+30)
            for g in tribe["offers"]: s.inventory[g]=s.inventory.get(g,0)+2
            s.add_journal(f"Sacagawea negotiated with {tribe['name']} — excellent outcome.")
            s.morale=min(100,s.morale+16)
        elif action=="gifts":
            s.inventory["Tobacco"]=max(0,s.inventory.get("Tobacco",0)-2)
            s.inventory["Trade Beads"]=max(0,s.inventory.get("Trade Beads",0)-3)
            s.tribe_relations[tribe_key]=min(100,rel+15)
            s.add_journal(f"Offered gifts to {tribe['name']}. Good will established.")
        elif action=="goods":
            for g in tribe["wants"]:
                if s.inventory.get(g,0)>0:
                    s.inventory[g]=max(0,s.inventory[g]-2)
            for g in tribe["offers"]: s.inventory[g]=s.inventory.get(g,0)+1
            s.tribe_relations[tribe_key]=min(100,rel+12)
            s.add_journal(f"Traded with {tribe['name']}.")
        elif action=="medal":
            s.inventory["Jefferson Medals"]=max(0,s.inventory.get("Jefferson Medals",0)-1)
            s.tribe_relations[tribe_key]=min(100,rel+20)
            s.add_journal(f"Presented Jefferson Medal to {tribe['name']} chief.")
        elif action=="maps":
            s.tribe_relations[tribe_key]=min(100,rel+8)
            s.add_journal(f"Shared route knowledge with {tribe['name']}.")
        if s.tribe_relations.get(tribe_key,50)>=60 and tribe_key not in s.traded_tribes:
            s.traded_tribes.append(tribe_key)
            s.peaceful_tribes=len([t for t in s.traded_tribes
                                   if s.tribe_relations.get(t,50)>=60])
        s.clamp(); self._check_objectives(); self._update_journal(); self._build_travel_ui()

    def _button_clicked(self, btn, on_new_game, on_save):
        if hasattr(btn,'_route') and not hasattr(btn,'_action'):
            self._do_travel(btn._route)
        elif hasattr(btn,'_choice'):
            self._resolve_event(btn._choice)
        elif hasattr(btn,'_trade_action'):
            self._resolve_trade(btn._trade_action, self._trade_tribe)
        elif hasattr(btn,'_action'):
            act = btn._action
            if act=="hunt":   self._do_hunt()
            elif act=="camp": self._do_camp()
            elif act=="trade":self._build_trade_ui(btn._tribe)
            elif act=="inventory": self.mode="inventory"  # TODO: inventory screen
            elif act=="cancel_route": self._build_travel_ui()
            elif act=="new":  on_new_game()
            elif act=="save": on_save()


# ═══════════════════════════════════════════════════════════════════════════════
#  APP — top-level state machine
# ═══════════════════════════════════════════════════════════════════════════════
class App:
    def __init__(self):
        self.scene = "title"
        self.title  = TitleScreen(self._start_cinematic, self._load_game)
        self.cinematic = None
        self.game_screen= None

    def _start_cinematic(self):
        self.cinematic = CinematicScreen(self._start_game)
        self.scene = "cinematic"

    def _start_game(self, state=None):
        st = state or GameState()
        if not state:
            st.add_journal("We set out from Camp Dubois. The Corps of Discovery — 33 strong — begins its great journey.")
            st.add_journal("York and Drouillard march with us. Sacagawea will join at Fort Mandan.")
        self.game_screen = GameScreen(st, self._new_game)
        self.scene = "game"

    def _new_game(self):
        self.scene = "title"
        self.title  = TitleScreen(self._start_cinematic, self._load_game)

    def _save_game(self):
        if not self.game_screen: return
        try:
            import tkinter as tk
            from tkinter import filedialog
            root = tk.Tk(); root.withdraw()
            path = filedialog.asksaveasfilename(
                defaultextension=".json",
                filetypes=[("Lewis & Clark Save","*.json")],
                initialfile="expedition_save.json",
                title="Save Expedition")
            root.destroy()
            if path:
                with open(path,"w") as f:
                    json.dump(self.game_screen.state.to_dict(), f, indent=2)
        except Exception as e:
            print("Save error:", e)

    def _load_game(self):
        try:
            import tkinter as tk
            from tkinter import filedialog
            root = tk.Tk(); root.withdraw()
            path = filedialog.askopenfilename(
                filetypes=[("Lewis & Clark Save","*.json")],
                title="Load Expedition")
            root.destroy()
            if path:
                with open(path,"r") as f:
                    data = json.load(f)
                self._start_game(state=GameState.from_dict(data))
        except Exception as e:
            print("Load error:", e)

    def run(self):
        running = True
        while running:
            dt = clock.tick(FPS)
            events = pygame.event.get()
            for event in events:
                if event.type == pygame.QUIT:
                    running = False
                if event.type == pygame.KEYDOWN and event.key == pygame.K_ESCAPE:
                    if self.scene=="game": self._new_game()
                    else: running=False

                if self.scene=="title":
                    self.title.handle(event, self._start_cinematic, self._load_game)
                elif self.scene=="cinematic" and self.cinematic:
                    self.cinematic.handle(event)
                elif self.scene=="game" and self.game_screen:
                    self.game_screen.handle(event, self._new_game, self._save_game, self._load_game)

            screen.fill(UI_BG)
            if self.scene=="title":
                self.title.draw(screen)
            elif self.scene=="cinematic" and self.cinematic:
                self.cinematic.draw(screen)
            elif self.scene=="game" and self.game_screen:
                self.game_screen.draw(screen)

            pygame.display.flip()

        pygame.quit()
        sys.exit()


if __name__ == "__main__":
    App().run()
