# ═══════════════════════════════════════════════════════════════════════════════
#  DRAW HELPERS
# ═══════════════════════════════════════════════════════════════════════════════
def draw_text(surf, text, font, colour, pos, anchor="topleft", max_w=None):
    if max_w:
        words = text.split()
        lines = []; line = ""
        for w in words:
            test = (line+" "+w).strip()
            if font.size(test)[0] <= max_w: line = test
            else: lines.append(line); line = w
        if line: lines.append(line)
        y = pos[1]
        for ln in lines:
            s = font.render(ln, True, colour)
            r = s.get_rect(**{anchor: (pos[0], y)})
            surf.blit(s, r)
            y += s.get_height() + 2
        return y
    else:
        s = font.render(text, True, colour)
        r = s.get_rect(**{anchor: pos})
        surf.blit(s, r)
        return r.bottom

def draw_panel(surf, rect, fill=UI_PANEL, border=UI_BORDER, radius=4, title=None):
    pygame.draw.rect(surf, fill, rect, border_radius=radius)
    pygame.draw.rect(surf, border, rect, 1, border_radius=radius)
    if title:
        draw_text(surf, title, F["tiny"], INK_FAINT,
                  (rect.x+8, rect.y+5), anchor="topleft")
        pygame.draw.line(surf, UI_BORDER,
                         (rect.x+4, rect.y+18), (rect.right-4, rect.y+18), 1)

def draw_button(surf, rect, label, hover=False, active=False,
                fill=UI_CARD2, fill_h=GOLD, text_col=PARCH_DARK, text_h=INK):
    col  = fill_h if hover else fill
    tcol = text_h if hover else text_col
    pygame.draw.rect(surf, col, rect, border_radius=3)
    pygame.draw.rect(surf, UI_BORDER if not hover else GOLD2, rect, 1, border_radius=3)
    draw_text(surf, label, F["btn"], tcol, rect.center, anchor="center")
    return rect

def stat_bar(surf, x, y, w, h, value, colour, label):
    # Background track
    pygame.draw.rect(surf, darken(colour, 0.25), (x, y, w, h), border_radius=2)
    # Danger zone (red wash for low values)
    if value < 25:
        pygame.draw.rect(surf, (120, 20, 20, 80), (x, y, w, h), border_radius=2)
    # Fill
    fw = max(2, int(w * value / 100))
    bar_col = RED2 if value<25 else AMBER if value<50 else colour
    pygame.draw.rect(surf, bar_col, (x, y, fw, h), border_radius=2)
    # Border
    pygame.draw.rect(surf, darken(colour, 0.6), (x, y, w, h), 1, border_radius=2)
    # Tick marks
    for t in [25, 50, 75]:
        tx = x + int(w*t/100)
        pygame.draw.line(surf, darken(colour, 0.4), (tx, y), (tx, y+h), 1)
    # Label + value
    draw_text(surf, label, F["tiny"], INK_FAINT, (x, y-11), anchor="topleft")
    draw_text(surf, str(value), F["small"], bar_col,
              (x+w, y-11), anchor="topright")

