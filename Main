        tk.Label(inf,text=base["title"],font=self.F["year"],bg=C["bg2"],fg=C["parch3"]).pack(anchor="w",pady=(0,4))
        # Active status with colored indicator
        status_frame=tk.Frame(inf,bg=C["bg2"]); status_frame.pack(anchor="w")
        ind_col=C["green2"] if active else C["dim"]
        tk.Label(status_frame,text="●",font=self.F["small"],bg=C["bg2"],fg=ind_col).pack(side="left")
        st="Active — traveling with the corps" if active else f"Joins at {WAYPOINTS[base['joined_at']]['name']}"
        tk.Label(status_frame,text=st,font=self.F["small"],bg=C["bg2"],fg=ind_col).pack(side="left",padx=4)

        # Historical quote
        quote=BIOS.get(char_key,"")
