                "desc":  text,
            }


def hex_neighbours(col, row):
    """Return valid (col, row) neighbours for pointy-top offset hexes."""
    if row % 2 == 0:
        dirs = [(1,0),(-1,0),(0,-1),(0,1),(1,-1),(1,1)]
    else:
        dirs = [(1,0),(-1,0),(0,-1),(0,1),(-1,-1),(-1,1)]
    result = []
    for dc, dr in dirs:
        nc, nr = col+dc, row+dr
        if 0 <= nc < HEX_COLS and 0 <= nr < HEX_ROWS:
            result.append((nc, nr))
    return result

def hex_to_world(col, row):
    """Convert hex (col, row) to normalised world coords (0-1)."""
    wx = col / (HEX_COLS - 1)
    wy = row / (HEX_ROWS - 1)
    return wx, wy

def world_to_hex(wx, wy):
    """Convert world coords to nearest hex."""
    col = max(0, min(HEX_COLS-1, round(wx * (HEX_COLS-1))))
    row = max(0, min(HEX_ROWS-1, round(wy * (HEX_ROWS-1))))
    return col, row

