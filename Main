# Generic label shown before a location is visited (preserves mystery)
WP_GENERIC = {
    "fort":     "Fortified Settlement",
    "camp":     "River Camp",
    "junction": "River Confluence",
    "landmark": "Natural Landmark",
    "pass":     "Mountain Pass",
    "start":    "Camp Dubois",
    "dead_end": "Unknown Territory",
}

def wp_display_name(wp_id, visited_hexes):
    """Return display name — generic until visited."""
    wp = WAYPOINTS[wp_id]
    hk = WP_HEX[wp_id]
    if wp["revealed"] or tuple(hk) in [tuple(h) for h in visited_hexes]:
        return wp["name"]
    return WP_GENERIC.get(wp["type"], "Unknown Settlement")

# ── Terrain ───────────────────────────────────────────────────────────────────
def _seg_dist(px, py, ax, ay, bx, by):
    dx, dy = bx-ax, by-ay
    if dx == 0 and dy == 0:
        return ((px-ax)**2 + (py-ay)**2)**0.5
    t = max(0.0, min(1.0, ((px-ax)*dx+(py-ay)*dy)/(dx*dx+dy*dy)))
    return ((px-ax-t*dx)**2+(py-ay-t*dy)**2)**0.5

# River corridors — each is a list of (col,row) waypoint anchors
# Paths are geographically separated to avoid visual crossing
RIVER_PATHS = [
    # Missouri River — goes northwest, row 12 down to row 5-6
    [(27,12),(23,11),(20,9),(17,8),(12,6),(9,6),(7,5),(5,7),(4,6),(2,6)],
    # Platte River — stays south, row 13-15, diverges well below Missouri
    [(27,12),(24,14),(21,14),(18,14),(15,13),(12,13),(9,14)],
    # Yellowstone — northern fork from Fort Mandan, rows 2-4
    [(12,6),(11,4),(9,3),(6,2),(3,2)],
    # Arkansas / southern mountains — row 15-17, deep south
    [(23,13),(20,15),(17,16),(13,15),(10,15),(8,14)],
]

def hex_terrain(col, row):
    """Return terrain string for hex (col, row)."""
    if col <= 2:
        return "coast"
    if row <= 2 or row >= 15:
        return "plains"
    # River corridors checked FIRST — they can pass through mountains
    for path in RIVER_PATHS:
        for i in range(len(path)-1):
            ac,ar = path[i]; bc,br = path[i+1]
            if _seg_dist(col,row,ac,ar,bc,br) <= 0.85:
                return "river"
    # Rocky Mountains — only if not on a river corridor
    if col <= 8 and 3 <= row <= 9:
        return "mountain"
    if col <= 11 and 4 <= row <= 8:
        return "forest"
    return "plains"

