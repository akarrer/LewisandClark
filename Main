# ═══════════════════════════════════════════════════════════════════════════════
#  GAME STATE
# ═══════════════════════════════════════════════════════════════════════════════
@dataclass
class GameState:
    current_wp:    int = 0
    food:          int = 80
    health:        int = 100
    morale:        int = 75
    current_month: int = 5
    current_year:  int = 1804
    journal:            List[str] = field(default_factory=list)
    completed_objectives: List[int] = field(default_factory=list)
    tribe_relations:    Dict = field(default_factory=dict)
    inventory:          Dict = field(default_factory=dict)
    characters:         Dict = field(default_factory=dict)
    discoveries:   int = 0
    peaceful_tribes: int = 0
    traded_tribes:  List[str] = field(default_factory=list)
    route_taken:    List[str] = field(default_factory=list)
    events_seen:    List[str] = field(default_factory=list)
    game_over:     bool = False
    victory:       bool = False

    def __post_init__(self):
        if not self.tribe_relations:
            self.tribe_relations = {k:v["relation"] for k,v in TRIBES.items()}
        if not self.inventory:
            self.inventory = copy.copy(STARTING_INVENTORY)
        if not self.characters:
            self.characters = copy.deepcopy(SPECIAL_CHARACTERS)

    @property
    def season(self): return get_season(self.current_month)
    @property
    def date_str(self):
        M = ["","January","February","March","April","May","June","July","August","September","October","November","December"]
        return f"{M[self.current_month]} {self.current_year}"

    def advance_date(self, days=14):
        self.current_month += 1
        if self.current_month > 12:
            self.current_month = 1; self.current_year += 1

    def add_journal(self, e):
        self.journal.append(f"[{self.date_str}] {e}")

    def clamp(self):
        self.food=max(0,min(100,self.food))
        self.health=max(0,min(100,self.health))
        self.morale=max(0,min(100,self.morale))

    def apply_effect(self, effect, chars_active):
        self.food   += effect.get("food",0)
        self.health += effect.get("health",0)
        self.morale += effect.get("morale",0)
        for item,qty in effect.get("inventory",{}).items():
            self.inventory[item]=max(0,self.inventory.get(item,0)+qty)
        for item,qty in effect.get("inventory_gain",{}).items():
            self.inventory[item]=self.inventory.get(item,0)+qty
        for ck,bonus in effect.get("char_bonus",{}).items():
            if chars_active.get(ck):
                self.food+=bonus.get("food",0); self.health+=bonus.get("health",0); self.morale+=bonus.get("morale",0)
        if chars_active.get("york"):      self.morale+=2
        if chars_active.get("sacagawea"): self.food+=3
        if chars_active.get("drouillard"):self.inventory["Furs"]=self.inventory.get("Furs",0)+1
        self.clamp()

    def to_dict(self):
        return {"current_wp":self.current_wp,"food":self.food,"health":self.health,"morale":self.morale,
                "current_month":self.current_month,"current_year":self.current_year,"journal":self.journal,
                "completed_objectives":self.completed_objectives,"tribe_relations":self.tribe_relations,
                "inventory":self.inventory,"discoveries":self.discoveries,"peaceful_tribes":self.peaceful_tribes,
                "traded_tribes":self.traded_tribes,"route_taken":self.route_taken,"events_seen":self.events_seen,
                "game_over":self.game_over,"victory":self.victory,
                "characters":{k:{"active":v["active"]} for k,v in self.characters.items()}}

    @classmethod
    def from_dict(cls, d):
        s=cls.__new__(cls)
        for attr in ["current_wp","food","health","morale","current_month","current_year","journal",
                     "completed_objectives","tribe_relations","inventory","discoveries","peaceful_tribes",
                     "traded_tribes","route_taken","game_over","victory"]:
            setattr(s,attr,d[attr])
        s.events_seen=d.get("events_seen",[])
        s.characters=copy.deepcopy(SPECIAL_CHARACTERS)
        for k,v in d.get("characters",{}).items():
            if k in s.characters: s.characters[k]["active"]=v["active"]
        return s


# ═══════════════════════════════════════════════════════════════════════════════
#  PARTICLE
# ═══════════════════════════════════════════════════════════════════════════════
class Particle:
    __slots__ = ("x","y","vx","vy","life","max_life","size")
    def __init__(self,x,y):
        self.x=x+random.uniform(-22,22); self.y=y+random.uniform(-4,4)
        self.vx=random.uniform(-0.3,0.3); self.vy=random.uniform(-1.0,-0.22)
        self.max_life=random.randint(50,100); self.life=self.max_life
        self.size=random.uniform(1.4,3.0)
    def update(self):
        self.x+=self.vx+random.uniform(-0.06,0.06); self.y+=self.vy; self.life-=1
        return self.life>0
    def color(self):
        t=self.life/self.max_life; r=min(255,int(210*t+45)); g=min(255,int(85*t))
        return f"#{r:02x}{g:02x}00"


# ═══════════════════════════════════════════════════════════════════════════════
#  SCENE RENDERER  — 7 historically accurate animated scenes
# ═══════════════════════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════════════════════
#  SCENE RENDERER v9 — Full-canvas illustrated cinematic
#  Each scene paints the entire window: bold art left, styled text right
# ═══════════════════════════════════════════════════════════════════════════════
class SceneRenderer:
    def __init__(self, canvas):
        self.canvas = canvas
        self.frame  = 0
    def tick(self): self.frame += 1

    # ── public entry point ────────────────────────────────────────────────────
    def draw_full(self, sd, cine_line, cine_char, cine_pause, fonts):
        """Draw the complete cinematic slide: art + narration on one canvas."""
        c = self.canvas; c.delete("all")
        W = c.winfo_width()  or 1280
        H = c.winfo_height() or 720
        f = self.frame; t = f * 0.022

        art_w = int(W * 0.60)   # left column: art
        txt_x = art_w + 20      # right column: text
        txt_w = W - txt_x - 16

        # ── 1. Draw scene art on left ─────────────────────────────────────
        scene_id = sd.get("scene","river_vast")
        dispatch = {
            "jefferson_writing": self._art_jefferson,
            "napoleon_sells":    self._art_napoleon,
            "lewis_packing":     self._art_lewis,
            "clark_letter":      self._art_clark,
            "camp_dubois":       self._art_camp,
            "river_vast":        self._art_river,
            "departure":         self._art_departure,
        }
        fn = dispatch.get(scene_id, self._art_river)
        fn(c, art_w, H, t)

        # ── 2. Right panel background ─────────────────────────────────────
        # Dark parchment-toned panel
        c.create_rectangle(art_w, 0, W, H, fill="#12100c", outline="")
        # Vertical gold rule separating art from text
        c.create_line(art_w, 0, art_w, H, fill=sd["accent"], width=3)
        c.create_line(art_w+4, 8, art_w+4, H-8, fill="#2a2010", width=1)

        # ── 3. Chapter / year badge ───────────────────────────────────────
        acc = sd["accent"]
        total = 7
        idx   = 0
        # find index
        # chapter badge
        c.create_rectangle(txt_x, 18, txt_x+txt_w-8, 38,
                           fill=acc, outline="")
        c.create_text(txt_x+8, 28,
                      text=f"{sd['year']}   ·   {sd['location']}",
                      font=fonts.get("tiny",("Georgia",8)),
                      fill="#0a0904", anchor="w")

        # ── 4. Title ──────────────────────────────────────────────────────
        title = sd["title"]
        c.create_text(txt_x+2, 56, text=title,
                      font=fonts.get("cine",("Georgia",15,"bold")),
                      fill="#1a1408", anchor="nw", width=txt_w-8)
        c.create_text(txt_x, 54, text=title,
                      font=fonts.get("cine",("Georgia",15,"bold")),
                      fill="#eedba8", anchor="nw", width=txt_w-8)

        # Divider
        c.create_line(txt_x, 96, txt_x+txt_w-8, 96, fill=acc, width=2)

        # ── 5. Typewriter narration ───────────────────────────────────────
        narr_lines = sd["narration"]
        ty = 108
        CHAR_H = 20
        for li, line in enumerate(narr_lines):
            if li < cine_line:
                wrapped = textwrap.fill(line, 42)
                c.create_text(txt_x, ty, text=wrapped,
                              font=fonts.get("body",("Georgia",10)),
                              fill="#ccaa60", anchor="nw",
                              width=txt_w-8, justify="left")
                ty += wrapped.count("\n")*CHAR_H + CHAR_H + 10
            elif li == cine_line:
                partial = line[:cine_char]
                if partial:
                    wrapped = textwrap.fill(partial, 42)
                    c.create_text(txt_x, ty, text=wrapped,
                                  font=fonts.get("body",("Georgia",10)),
                                  fill="#e0c880", anchor="nw",
                                  width=txt_w-8, justify="left")
                # cursor blink
                if cine_char % 20 < 11:
                    c.create_text(txt_x+4, ty+CHAR_H,
                                  text="▌", font=fonts.get("body",("Georgia",10)),
                                  fill=acc, anchor="w")
                break

        # ── 6. FACT badge ─────────────────────────────────────────────────
        fact = sd.get("fact","")
        if fact:
            fy = H - 110
            c.create_rectangle(txt_x-2, fy-4, txt_x+txt_w-6, fy+56,
                               fill="#1e1a0c", outline=acc, width=1)
            c.create_rectangle(txt_x-2, fy-4, txt_x+txt_w-6, fy+14,
                               fill=acc, outline="")
            c.create_text(txt_x+6, fy+3,
                          text="DID YOU KNOW",
                          font=fonts.get("tiny",("Georgia",8)),
                          fill="#0a0904", anchor="w")
            c.create_text(txt_x+4, fy+20,
                          text=textwrap.fill(fact, 40),
                          font=fonts.get("small",("Georgia",9)),
                          fill="#e0c870", anchor="nw",
                          width=txt_w-10, justify="left")

        # ── 7. Progress dots ──────────────────────────────────────────────
        dot_y = H - 32
        for di in range(7):
            dx2 = txt_x + di * 22
            dot_col = acc if di == self._slide_idx else \
                      "#8c7040" if di < self._slide_idx else "#2a2010"
            c.create_oval(dx2, dot_y, dx2+14, dot_y+14,
                          fill=dot_col, outline="")

        # "continue" prompt when done
        if cine_line >= len(narr_lines):
            pulse = int(abs(math.sin(f * 0.07)) * 90 + 80)
            c.create_text(txt_x + txt_w//2, H - 50,
                          text="▶  CONTINUE",
                          font=fonts.get("subhead",("Georgia",10,"bold")),
                          fill=f"#{pulse:02x}{int(pulse*0.72):02x}10",
                          anchor="center")

        # Film grain (subtle)
        if f % 5 < 2:
            for _ in range(30):
                gx = random.randint(0, art_w)
                gy = random.randint(0, H)
                c.create_rectangle(gx, gy, gx+2, gy+2,
                                   fill="#14100a", outline="")

        # Art border
        c.create_rectangle(2, 2, art_w-2, H-2,
                           outline="#4a3810", width=2, fill="")

    # current slide index (set by LewisClarkGame before calling draw_full)
    _slide_idx = 0

    # ══════════════════════════════════════════════════════════════════════════
    #  ART SCENES — bold, readable, memorable
    # ══════════════════════════════════════════════════════════════════════════

    def _sky(self, c, W, H, colors, top_frac=0.55):
        """Draw a smooth vertical sky gradient."""
        n = len(colors)
        rows = int(H * top_frac)
        for i in range(rows):
            seg = i / rows * (n-1)
            lo  = int(seg); hi2 = min(n-1, lo+1); f2 = seg - lo
            r1,g1,b1 = [int(colors[lo][j:j+2],16) for j in (1,3,5)]
            r2,g2,b2 = [int(colors[hi2][j:j+2],16) for j in (1,3,5)]
            r=int(r1+(r2-r1)*f2); g=int(g1+(g2-g1)*f2); b=int(b1+(b2-b1)*f2)
            c.create_line(0, i, W, i, fill=f"#{r:02x}{g:02x}{b:02x}")

    def _ground_poly(self, c, W, H, frac, col, freq=0.008, amp=12):
        pts = [0, H]
        for x in range(0, W+4, 4):
            y = H*frac + math.sin(x*freq)*amp + math.sin(x*freq*2.7)*amp*0.35
            pts.extend([x, int(y)])
        pts.extend([W, H])
        c.create_polygon(pts, fill=col, outline="")

    def _flame(self, c, cx, cy, t, seed=0):
        """Animated candle flame."""
        fk = math.sin(t*6.5 + seed) * 5
        # glow halos
        for r in range(28, 4, -6):
            bright = int(0x10 + (28-r)*3)
            c.create_oval(cx-r, cy-r//2, cx+r, cy+r//2,
                          fill=f"#{bright:02x}{bright//2:02x}02", outline="")
        # candle body
        c.create_rectangle(cx-4, cy, cx+4, cy+28, fill="#ddd0a0", outline="")
        # flame
        c.create_oval(cx-7+fk, cy-22, cx+7+fk, cy+2,  fill="#d88010", outline="")
        c.create_oval(cx-4+fk, cy-30, cx+4+fk, cy-14, fill="#f8e030", outline="")
        c.create_oval(cx-2+fk, cy-34, cx+2+fk, cy-22, fill="#ffffff", outline="")

    def _person(self, c, x, y, scale, body_col, seated=False, facing_right=True):
        """Simple but clear person silhouette."""
        d = 1 if facing_right else -1
        s = scale
        # legs
        if not seated:
            c.create_line(x-int(5*s), y, x-int(8*s), y+int(26*s),
                          fill=body_col, width=int(6*s))
            c.create_line(x+int(5*s), y, x+int(8*s), y+int(26*s),
                          fill=body_col, width=int(6*s))
        else:
            c.create_line(x-int(4*s), y, x+d*int(20*s), y+int(4*s),
                          fill=body_col, width=int(6*s))
        # torso
        c.create_rectangle(x-int(10*s), y-int(28*s),
                           x+int(10*s), y, fill=body_col, outline="")
        # arms
        arm_y = y - int(20*s)
        c.create_line(x-int(10*s), arm_y, x-int(24*s), arm_y+int(16*s),
                      fill=body_col, width=int(5*s))
        c.create_line(x+int(10*s), arm_y, x+int(24*s), arm_y+int(16*s),
                      fill=body_col, width=int(5*s))
        # head
        c.create_oval(x-int(10*s), y-int(50*s),
                      x+int(10*s), y-int(30*s), fill=body_col, outline="")
        # tricorn hat
        c.create_rectangle(x-int(13*s), y-int(50*s),
                           x+int(13*s), y-int(47*s), fill="#0a0806", outline="")
        c.create_rectangle(x-int(9*s), y-int(64*s),
                           x+int(9*s), y-int(50*s), fill="#0a0806", outline="")

    # ── SCENE 1: Jefferson's candlelit study ──────────────────────────────────
    def _art_jefferson(self, c, W, H, t):
        # Deep night interior — stone walls, high arched window
        c.create_rectangle(0, 0, W, H, fill="#0c0804", outline="")

        # Stone wall — warm tones, horizontal courses
        for row in range(0, H, 20):
            for col_off in range(0, W, 60 if row%40==0 else 58):
                shade = 13 + (row*7+col_off*3)%5
                c.create_rectangle(col_off, row, col_off+56, row+18,
                                   fill=f"#{shade:02x}{int(shade*0.65):02x}{int(shade*0.45):02x}",
                                   outline=f"#{shade//2:02x}{shade//3:02x}{shade//4:02x}", width=1)

        # Tall arched window (left of center) — shows night sky
        wx = int(W*0.12); wy = 30; ww = int(W*0.30); wh = int(H*0.65)
        # Window reveal (thick stone sill)
        c.create_rectangle(wx-8, wy-8, wx+ww+8, wy+wh+8,
                           fill="#181008", outline="#2a1a08", width=2)
        # Night sky through window
        c.create_rectangle(wx, wy, wx+ww, wy+wh, fill="#040812", outline="")
        # Arch
        c.create_arc(wx, wy-ww//2, wx+ww, wy+ww//2,
                     start=0, extent=180, fill="#040812", outline="")
        # Stars
        rng = random.Random(99)
        for _ in range(40):
            sx = wx + rng.randint(4, ww-4)
            sy = wy + rng.randint(4, int(wh*0.75))
            bv = rng.randint(80, 180)
            tw = int(math.sin(t*2.2 + sx*0.08) * 20)
            bv2 = max(30, min(220, bv+tw))
            c.create_oval(sx-1, sy-1, sx+1, sy+1,
                          fill=f"#{bv2:02x}{bv2:02x}{int(bv2*0.85):02x}", outline="")
        # Moon in window
        c.create_oval(wx+ww*0.6, wy+18, wx+ww*0.6+38, wy+56,
                      fill="#c8c890", outline="")
        c.create_oval(wx+ww*0.6+12, wy+12, wx+ww*0.6+44, wy+50,
                      fill="#040812", outline="")
        # Window cross-panes
        c.create_line(wx+ww//2, wy, wx+ww//2, wy+wh,
                      fill="#1a1206", width=4)
        c.create_line(wx, wy+wh//3, wx+ww, wy+wh//3,
                      fill="#1a1206", width=4)

        # Heavy writing desk, right side
        dsk_x = int(W*0.42); dsk_y = int(H*0.56)
        dsk_w = int(W*0.50)
        # Desk surface
        c.create_rectangle(dsk_x, dsk_y, dsk_x+dsk_w, dsk_y+18,
                           fill="#2e1a08", outline="#3e2a10", width=2)
        # Desk front panel
        c.create_rectangle(dsk_x, dsk_y+18, dsk_x+dsk_w, dsk_y+30,
                           fill="#221206", outline="")
        # Desk legs
        for lx in [dsk_x+12, dsk_x+dsk_w-12]:
            c.create_rectangle(lx-5, dsk_y+30, lx+5, H,
                               fill="#1a0e04", outline="")

        # Parchment paper on desk — large, detailed
        px = dsk_x + int(dsk_w*0.15)
        py = dsk_y - 72
        # Paper shadow
        c.create_rectangle(px+4, py+4, px+130, py+86,
                           fill="#0a0804", outline="")
        # Paper
        c.create_rectangle(px, py, px+130, py+84,
                           fill="#e8d870", outline="#8a6818", width=2)
        # Writing lines
        for li in range(10):
            lw = 80 + random.Random(li*3).randint(-15, 20)
            ink = "#3a2408"
            c.create_line(px+10, py+9+li*7, px+10+lw, py+9+li*7,
                          fill=ink, width=1)
        # CONFIDENTIAL stamp in red, diagonal
        c.create_text(px+65, py+42,
                      text="CONFIDENTIAL", font=("Georgia", 8, "bold"),
                      fill="#881010", angle=15, anchor="center")
        # Red wax seal bottom corner
        c.create_oval(px+100, py+62, px+122, py+82,
                      fill="#aa1010", outline="#661010", width=2)
        c.create_text(px+111, py+72, text="J", font=("Georgia", 7, "bold"),
                      fill="#cc8020", anchor="center")

        # Animated quill writing
        qx = px + 90 + math.sin(t*2)*8
        qy = py + 28 + math.cos(t*2)*6
        # Quill shaft
        c.create_line(qx, qy, qx-40, qy+60, fill="#d0b840", width=2, smooth=True)
        # Feather vane
        for fi in range(6):
            frac = fi/6
            fx2 = qx - int(frac*32)
            fy2 = qy + int(frac*48)
            c.create_line(fx2, fy2, fx2-int(8+fi*2), fy2-6,
                          fill="#c8a820", width=1)
            c.create_line(fx2, fy2, fx2+int(6+fi*2), fy2-8,
                          fill="#b89018", width=1)
        # Ink droplet at tip
        c.create_oval(qx-3, qy-3, qx+3, qy+3, fill="#0a0806", outline="")

        # Inkwell
        c.create_oval(px+118, py-8, px+140, py+18,
                      fill="#0e0c08", outline="#2a1808", width=2)

        # Three candelabras — warm amber light pools
        for cndx, cndy in [(dsk_x+int(dsk_w*0.08), dsk_y-38),
                            (dsk_x+int(dsk_w*0.82), dsk_y-36),
                            (wx+ww+int(W*0.06), int(H*0.30))]:
            # Stand
            c.create_line(cndx, cndy+10, cndx, cndy+40,
                          fill="#3a2808", width=4)
            c.create_line(cndx-15, cndy+40, cndx+15, cndy+40,
                          fill="#3a2808", width=3)
            self._flame(c, cndx, cndy, t, seed=cndx)

        # Jefferson — seated silhouette
        self._person(c, dsk_x+int(dsk_w*0.35), dsk_y+2,
                     0.85, "#0e0a06", seated=True, facing_right=False)

        # Bookshelf on far wall
        sh_x = int(W*0.82); sh_y = int(H*0.12); sh_h = int(H*0.40)
        c.create_rectangle(sh_x, sh_y, sh_x+int(W*0.16), sh_y+sh_h,
                           fill="#1a1008", outline="#2a1808")
        for shelf in range(4):
            sy2 = sh_y + shelf*int(sh_h/4)
            c.create_line(sh_x, sy2, sh_x+int(W*0.16), sy2,
                          fill="#2a1808", width=2)
            for book in range(6):
                bx2 = sh_x + 4 + book*int(W*0.025)
                book_col = ["#3a1010","#102028","#1a2808","#2a1a08","#081828","#281010"][book%6]
                c.create_rectangle(bx2, sy2+3, bx2+int(W*0.022), sy2+int(sh_h/4)-3,
                                   fill=book_col, outline="#1a1208")

        # Title of the scene — large text bottom-left
        c.create_text(10, H-28,
                      text="The White House Study  ·  January 18, 1803",
                      font=("Georgia", 9, "italic"), fill="#6a5028", anchor="w")

    # ── SCENE 2: Napoleon selling Louisiana ───────────────────────────────────
    def _art_napoleon(self, c, W, H, t):
        c.create_rectangle(0, 0, W, H, fill="#0e0a06", outline="")

        # Ornate Tuileries Palace interior — gilded columns, red drapes
        # Floor — parquet pattern
        for fx in range(0, W, 30):
            for fy in range(int(H*0.72), H, 20):
                checker = ((fx//30)+(fy//20))%2
                col = "#1a1406" if checker else "#1e1608"
                c.create_rectangle(fx, fy, fx+28, fy+18, fill=col, outline="#141006")

        # Tall columns with gilded capitals
        col_positions = [int(W*f) for f in [0.04, 0.22, 0.60, 0.78, 0.94]]
        for cx2 in col_positions:
            # Column shaft
            c.create_rectangle(cx2-10, 0, cx2+10, int(H*0.75),
                               fill="#1e1a0c", outline="#2a2410", width=1)
            # Fluting
            for fi in range(5):
                c.create_line(cx2-7+fi*3, 0, cx2-7+fi*3, int(H*0.74),
                              fill="#141006", width=1)
            # Capital
            c.create_polygon(cx2-18, int(H*0.0), cx2-10, int(H*0.06),
                             cx2+10, int(H*0.06), cx2+18, int(H*0.0),
                             fill="#2e2810", outline="#3a3412")
            # Gold leaf capital top
            c.create_line(cx2-20, 8, cx2+20, 8, fill="#7a6018", width=3)

        # Red velvet drapes between columns
        for di, (dx3, dw3) in enumerate([(int(W*0.08), int(W*0.12)),
                                          (int(W*0.47), int(W*0.12))]):
            for fold in range(5):
                fx3 = dx3 + fold * (dw3//5)
                col3 = "#4a0808" if fold%2==0 else "#380606"
                c.create_rectangle(fx3, 0, fx3+dw3//5-1, int(H*0.74),
                                   fill=col3, outline="")
            # Gilded pelmet
            c.create_rectangle(dx3-4, 0, dx3+dw3+4, 22,
                               fill="#3a2c08", outline="#6a5010", width=2)

        # Chandelier — center ceiling
        chx = W//2; chy = 20
        c.create_oval(chx-20, chy-6, chx+20, chy+6,
                      fill="#2a2408", outline="#5a4818", width=2)
        for arm_a in range(0, 360, 45):
            ax = chx + math.cos(math.radians(arm_a))*30
            ay = chy + math.sin(math.radians(arm_a))*15
            c.create_line(chx, chy+4, ax, ay, fill="#3a3010", width=2)
            self._flame(c, ax, ay, t, seed=arm_a)

        # Long mahogany treaty table — center stage
        tx = int(W*0.10); ty = int(H*0.54); tw = int(W*0.80); th = 28
        # Table shadow
        c.create_rectangle(tx+6, ty+6, tx+tw+6, ty+th+8, fill="#080604", outline="")
        # Table top
        c.create_rectangle(tx, ty, tx+tw, ty+th,
                           fill="#2e1808", outline="#4a2c10", width=3)
        # Inlaid edge
        c.create_line(tx+4, ty+4, tx+tw-4, ty+4, fill="#3e2810", width=1)
        # Table legs
        for lx4 in [tx+20, tx+tw-20]:
            c.create_rectangle(lx4-6, ty+th, lx4+6, H,
                               fill="#221406", outline="")

        # Treaty document — hero prop, center table
        doc_x = tx + int(tw*0.38); doc_y = ty - 75
        # Shadow
        c.create_rectangle(doc_x+5, doc_y+5, doc_x+145, doc_y+100,
                           fill="#080604", outline="")
        # Document
        c.create_rectangle(doc_x, doc_y, doc_x+140, doc_y+96,
                           fill="#ece880", outline="#8a6818", width=3)
        # Title text on document
        c.create_text(doc_x+70, doc_y+14,
                      text="LOUISIANA TERRITORY",
                      font=("Georgia", 7, "bold"), fill="#3a2408", anchor="center")
        c.create_line(doc_x+10, doc_y+22, doc_x+130, doc_y+22,
                      fill="#5a3c10", width=1)
        for li in range(8):
            lw4 = 85 + random.Random(li+20).randint(-10, 20)
            c.create_line(doc_x+10, doc_y+28+li*8, doc_x+10+lw4, doc_y+28+li*8,
                          fill="#4a3010", width=1)
        # Large red wax seal
        c.create_oval(doc_x+96, doc_y+62, doc_x+132, doc_y+92,
                      fill="#aa1010", outline="#661010", width=3)
        c.create_text(doc_x+114, doc_y+77, text="R", font=("Georgia",9,"bold"),
                      fill="#e8c020", anchor="center")
        # $15,000,000 notation
        c.create_text(doc_x+70, doc_y+85,
                      text="$15,000,000", font=("Georgia",7,"bold"), fill="#2a1808", anchor="center")

        # Three figures at table — Talleyrand (French), Livingston & Monroe (American)
        # Talleyrand — French uniform, standing, gesturing
        self._person(c, tx+int(tw*0.25), ty+2, 0.9, "#1a0e08",
                     seated=False, facing_right=True)
        # Blue French sash
        c.create_line(tx+int(tw*0.25)-6, ty-20, tx+int(tw*0.25)+8, ty-4,
                      fill="#0e1840", width=4)

        # Livingston — seated
        self._person(c, tx+int(tw*0.55), ty+2, 0.85, "#0e1828",
                     seated=True, facing_right=False)
        # Monroe — seated
        self._person(c, tx+int(tw*0.68), ty+2, 0.85, "#0e1828",
                     seated=True, facing_right=False)

        # Map of Louisiana on wall — key visual
        mx5 = int(W*0.30); my5 = int(H*0.06); mw5 = int(W*0.28); mh5 = int(H*0.30)
        c.create_rectangle(mx5-4, my5-4, mx5+mw5+4, my5+mh5+4,
                           fill="#1a1208", outline="#3a2a10", width=3)
        c.create_rectangle(mx5, my5, mx5+mw5, my5+mh5,
                           fill="#c8b860", outline="")
        # Simple territory outline
        terr_pts = [mx5+10,my5+mh5*0.8, mx5+20,my5+mh5*0.2,
                    mx5+mw5*0.5,my5+mh5*0.1, mx5+mw5-10,my5+mh5*0.3,
                    mx5+mw5-15,my5+mh5*0.9]
        c.create_polygon(terr_pts, fill="#8a7030", outline="#4a3010", width=2)
        c.create_text(mx5+mw5//2, my5+mh5+12,
                      text="LOUISIANA TERRITORY", font=("Georgia",7,"bold"),
                      fill="#6a5020", anchor="center")

        # Candelabras on table ends
        for cndx5 in [tx+30, tx+tw-30]:
            c.create_line(cndx5, ty-10, cndx5, ty-50,
                          fill="#3a2808", width=4)
            c.create_line(cndx5-18, ty-50, cndx5+18, ty-50,
                          fill="#3a2808", width=3)
            for arm5 in [-16, 0, 16]:
                self._flame(c, cndx5+arm5, ty-52, t, seed=arm5*10+cndx5)

        c.create_text(10, H-28,
                      text="Tuileries Palace, Paris  ·  April 30, 1803",
                      font=("Georgia", 9, "italic"), fill="#6a5028", anchor="w")

    # ── SCENE 3: Lewis packing at Harpers Ferry ────────────────────────────────
    def _art_lewis(self, c, W, H, t):
        self._sky(c, W, H, ["#0e1808","#182814","#243a1e","#1e3018"], top_frac=0.42)
        self._ground_poly(c, W, H, 0.42, "#1e2c10", freq=0.006, amp=14)
        self._ground_poly(c, W, H, 0.52, "#182408", freq=0.009, amp=10)
        self._ground_poly(c, W, H, 0.68, "#101c06", freq=0.014, amp=7)

        # Harpers Ferry Arsenal — large stone building
        bx6 = int(W*0.28); by6 = int(H*0.10); bw6 = int(W*0.64); bh6 = int(H*0.48)
        # Building shadow
        c.create_rectangle(bx6+8, by6+8, bx6+bw6+8, by6+bh6+8,
                           fill="#080c04", outline="")
        # Main walls — stone texture via horizontal bands
        for band in range(0, bh6, 14):
            shade6 = 18 + band%8
            c.create_rectangle(bx6, by6+band, bx6+bw6, by6+band+12,
                               fill=f"#{shade6:02x}{int(shade6*0.7):02x}{int(shade6*0.55):02x}",
                               outline=f"#{shade6//2:02x}{shade6//3:02x}{shade6//4:02x}", width=1)
        # Roof / parapet
        c.create_rectangle(bx6-8, by6-14, bx6+bw6+8, by6+4,
                           fill="#1a1608", outline="#2a2010", width=2)
        # Battlements
        for bm in range(bx6, bx6+bw6, 22):
            c.create_rectangle(bm, by6-22, bm+14, by6-6,
                               fill="#1a1608", outline="#2a2010")
        # Windows — tall arched, lit from inside
        for wi6 in range(bx6+30, bx6+bw6-20, 60):
            c.create_rectangle(wi6, by6+20, wi6+22, by6+bh6-10,
                               fill="#c07010", outline="#1e1808", width=2)
            c.create_arc(wi6, by6+8, wi6+22, by6+30,
                         start=0, extent=180, fill="#c07010", outline="")
            c.create_line(wi6+11, by6+20, wi6+11, by6+bh6-10,
                          fill="#1a1208", width=2)
        # Large double doors
        c.create_rectangle(bx6+bw6//2-22, by6+bh6-55,
                           bx6+bw6//2+22, by6+bh6,
                           fill="#1a1008", outline="#2a1808", width=2)
        c.create_arc(bx6+bw6//2-22, by6+bh6-70,
                     bx6+bw6//2+22, by6+bh6-50,
                     start=0, extent=180, fill="#1a1008", outline="#2a1808")

        # Equipment piled outside — barrels, crates, rifle racks
        for eq_x, eq_y, eq_w, eq_h, eq_type in [
            (int(W*0.04),int(H*0.52),38,32,"barrel"),
            (int(W*0.10),int(H*0.54),44,28,"crate"),
            (int(W*0.16),int(H*0.51),36,34,"barrel"),
            (int(W*0.03),int(H*0.50),30,40,"crate"),
        ]:
            if eq_type == "barrel":
                c.create_oval(eq_x, eq_y, eq_x+eq_w, eq_y+eq_h,
                              fill="#2a1608", outline="#3e2410", width=2)
                for stave_y in [eq_y+eq_h//4, eq_y+eq_h//2, eq_y+3*eq_h//4]:
                    c.create_arc(eq_x+2, stave_y-3, eq_x+eq_w-2, stave_y+3,
                                 start=0, extent=180, style="arc",
                                 outline="#3a2010", width=1)
            else:
                c.create_rectangle(eq_x, eq_y, eq_x+eq_w, eq_y+eq_h,
                                   fill="#241408", outline="#3a2010", width=2)
                # Crate boards
                c.create_line(eq_x, eq_y, eq_x+eq_w, eq_y+eq_h,
                              fill="#1a1008", width=1)
                c.create_line(eq_x+eq_w, eq_y, eq_x, eq_y+eq_h,
                              fill="#1a1008", width=1)

        # Rifle rack — lean-to against building wall
        rack_x = bx6 + bw6 + 12
        rack_y = int(H*0.45)
        c.create_line(rack_x, rack_y, rack_x, rack_y+int(H*0.22),
                      fill="#2a1808", width=4)
        for ri7 in range(7):
            rx7 = rack_x + ri7*7
            c.create_line(rx7, rack_y+10, rx7, rack_y+int(H*0.22),
                          fill="#2a1808", width=2)
            c.create_oval(rx7-2, rack_y+6, rx7+2, rack_y+12,
                          fill="#1a1006", outline="")

        # Lewis supervising — center foreground
        self._person(c, int(W*0.50), int(H*0.58), 0.95, "#0e1428",
                     seated=False, facing_right=False)

        # Worker with crate
        self._person(c, int(W*0.20), int(H*0.60), 0.80, "#1a1208",
                     seated=False, facing_right=True)

        # Sign: HARPERS FERRY NATIONAL ARMORY
        sx8 = int(W*0.30); sy8 = int(H*0.04)
        c.create_rectangle(sx8, sy8, sx8+int(W*0.38), sy8+20,
                           fill="#1a1206", outline="#3a2a10", width=1)
        c.create_text(sx8+int(W*0.19), sy8+10,
                      text="HARPERS FERRY NATIONAL ARMORY",
                      font=("Georgia",7,"bold"), fill="#8a7020", anchor="center")

        # Inventory list chalked on wall
        list_x = bx6 + 10; list_y = by6 + 30
        c.create_text(list_x, list_y,
                      text="SUPPLIES:\n193 lbs portable soup\n30 gal whiskey\n15 rifles\n4,600 needles",
                      font=("Courier",7), fill="#6a5818",
                      anchor="nw", justify="left")

        c.create_text(10, H-28,
                      text="Harpers Ferry Arsenal  ·  Summer 1803",
                      font=("Georgia",9,"italic"), fill="#6a5028", anchor="w")

    # ── SCENE 4: Clark reads Lewis's letter ───────────────────────────────────
    def _art_clark(self, c, W, H, t):
        self._sky(c, W, H, ["#0a0c14","#141828","#1c2434","#162038"], top_frac=0.50)
        # Stars
        rng9 = random.Random(55)
        for _ in range(50):
            sx9 = rng9.randint(0,W); sy9 = rng9.randint(0,int(H*0.46))
            bv9 = rng9.randint(50,140)
            tw9 = int(math.sin(t*2+sx9*0.06)*18)
            bv9b = max(20, min(180, bv9+tw9))
            c.create_oval(sx9-1,sy9-1,sx9+1,sy9+1,
                          fill=f"#{bv9b:02x}{bv9b:02x}{int(bv9b*0.8):02x}",outline="")
        # Rolling Indiana hills
        self._ground_poly(c, W, H, 0.50, "#1c2c0e", freq=0.005, amp=18)
        self._ground_poly(c, W, H, 0.62, "#162208", freq=0.008, amp=12)
        self._ground_poly(c, W, H, 0.78, "#101a04", freq=0.013, amp=7)

        # Log farmhouse — right background
        fhx = int(W*0.48); fhy = int(H*0.22); fhw = int(W*0.40); fhh = int(H*0.34)
        # Shadow
        c.create_rectangle(fhx+6,fhy+6,fhx+fhw+6,fhy+fhh+8,fill="#060806",outline="")
        # Walls — log cabin texture
        for log in range(0, fhh, 10):
            c.create_rectangle(fhx, fhy+log, fhx+fhw, fhy+log+8,
                               fill="#1c1008" if log%20==0 else "#181008",
                               outline="#0e0804", width=1)
        # Roof — steep gable
        c.create_polygon(fhx-10, fhy,
                         fhx+fhw//2, fhy-45,
                         fhx+fhw+10, fhy,
                         fill="#141008", outline="#1e1608", width=2)
        # Chimney with smoke
        c.create_rectangle(fhx+fhw*0.65, fhy-55, fhx+fhw*0.65+18, fhy+4,
                           fill="#1a1208", outline="#2a1808")
        # Smoke puff
        for sp in range(4):
            smoke_x = fhx+fhw*0.65+9 + math.sin(t*1.5+sp)*8
            smoke_y = fhy - 55 - sp*18 - math.cos(t+sp)*5
            alpha = int(0x20 + (3-sp)*0x0a)
            c.create_oval(smoke_x-10, smoke_y-8, smoke_x+10, smoke_y+8,
                          fill=f"#{alpha:02x}{alpha:02x}{int(alpha*0.9):02x}", outline="")
        # Lit windows
        for wxi in [fhx+18, fhx+fhw-46]:
            c.create_rectangle(wxi, fhy+20, wxi+22, fhy+46,
                               fill="#d08010", outline="#1e1208", width=2)
            c.create_line(wxi+11,fhy+20,wxi+11,fhy+46,fill="#1a1208",width=1)
            c.create_line(wxi,fhy+33,wxi+22,fhy+33,fill="#1a1208",width=1)
        # Door
        c.create_rectangle(fhx+fhw//2-12, fhy+fhh-38, fhx+fhw//2+12, fhy+fhh,
                           fill="#0e0804", outline="#1e1008", width=1)

        # Split-rail fence — foreground
        for fx10 in range(0, W, 60):
            fy10 = int(H*0.62) + random.Random(fx10).randint(-4,4)
            c.create_line(fx10, fy10, fx10+58, fy10+random.Random(fx10+1).randint(-3,3),
                          fill="#1a1208", width=3)
            c.create_line(fx10+6, fy10-10, fx10+6, fy10+14,
                          fill="#1a1208", width=4)

        # Clark — foreground, reading letter by lantern light
        clark_x = int(W*0.22); clark_y = int(H*0.64)
        # Lantern light glow
        for lr in range(5, 0, -1):
            g2 = int(0x14 + lr*12)
            c.create_oval(clark_x-lr*20, clark_y-lr*16,
                          clark_x+lr*20, clark_y+lr*12,
                          fill=f"#{g2:02x}{g2//2:02x}02", outline="")
        # Hanging lantern
        lnx = clark_x + 48; lny = clark_y - 55
        c.create_line(lnx, lny-20, lnx, lny, fill="#2a1808", width=2)
        c.create_rectangle(lnx-8, lny, lnx+8, lny+22, fill="#2a1808", outline="#3a2810")
        self._flame(c, lnx, lny, t, seed=100)

        # Clark figure
        self._person(c, clark_x, clark_y, 0.95, "#0e1428",
                     seated=False, facing_right=True)

        # Letter in hands — held up, lit
        lx11 = clark_x + 22; ly11 = clark_y - 46
        # Letter glow
        c.create_rectangle(lx11-4, ly11-4, lx11+60, ly11+48,
                           fill="#181206", outline="")
        c.create_rectangle(lx11, ly11, lx11+56, ly11+44,
                           fill="#e4d868", outline="#7a5e14", width=2)
        # Lines
        for li2 in range(6):
            lw11 = 32 + random.Random(li2+30).randint(-5,10)
            c.create_line(lx11+5, ly11+6+li2*6, lx11+5+lw11, ly11+6+li2*6,
                          fill="#3a2808", width=1)
        # Highlighted phrase
        c.create_rectangle(lx11+4, ly11+12, lx11+50, ly11+20,
                           fill="#c8a020", outline="")
        c.create_text(lx11+27, ly11+16,
                      text="equal pleasure", font=("Georgia",5,"italic"),
                      fill="#1a0e04", anchor="center")

        # Horse tied to fence post — background atmosphere
        hx12 = int(W*0.76); hy12 = int(H*0.56)
        # Body
        c.create_oval(hx12-30, hy12-20, hx12+30, hy12+10,
                      fill="#1a1208", outline="")
        # Head
        c.create_oval(hx12+22, hy12-32, hx12+44, hy12-12,
                      fill="#1a1208", outline="")
        # Legs
        for lx13 in [hx12-18, hx12-6, hx12+10, hx12+20]:
            c.create_line(lx13, hy12+10, lx13+2, hy12+35,
                          fill="#1a1208", width=4)
        # Tie rope
        c.create_line(hx12+44, hy12-22, hx12+70, hy12-40,
                      fill="#2a1808", width=1)

        c.create_text(10, H-28,
                      text="Clarksville, Indiana Territory  ·  June 19, 1803",
                      font=("Georgia",9,"italic"), fill="#6a5028", anchor="w")

    # ── SCENE 5: Camp Dubois winter training ──────────────────────────────────
    def _art_camp(self, c, W, H, t):
        self._sky(c, W, H, ["#080c12","#0e1420","#141e2c","#101828"], top_frac=0.50)
        # Milky Way band
        for _ in range(80):
            mx14 = random.randint(0,W); my14 = random.randint(0,int(H*0.44))
            bv14 = random.randint(30,100)
            c.create_oval(mx14-1,my14-1,mx14+1,my14+1,
                          fill=f"#{bv14:02x}{bv14:02x}{int(bv14*0.9):02x}",outline="")
        self._ground_poly(c, W, H, 0.50, "#1a280e", freq=0.006, amp=12)
        self._ground_poly(c, W, H, 0.62, "#162008", freq=0.010, amp=8)

        # Missouri River — wide band across middle
        for ri14 in range(int(H*0.46), int(H*0.58)):
            sh14 = math.sin(ri14*0.10+t*1.8)*0.35+0.55
            rr14=int(0x0e+sh14*0x14); gg14=int(0x1c+sh14*0x10); bb14=int(0x28+sh14*0x10)
            c.create_line(0,ri14,W,ri14,
                          fill=f"#{min(255,rr14):02x}{min(255,gg14):02x}{min(255,bb14):02x}")

        # Moon reflected on river
        c.create_oval(W*0.72-22, int(H*0.46),
                      W*0.72+22, int(H*0.56),
                      fill="#1e1e18", outline="")
        # Moon in sky
        c.create_oval(W*0.75-26,int(H*0.10),W*0.75+26,int(H*0.10)+52,
                      fill="#c8c490",outline="")
        c.create_oval(W*0.75+10,int(H*0.08),W*0.75+40,int(H*0.10)+30,
                      fill="#0e1428",outline="")

        # Camp tents — row across middle ground
        tent_y = int(H*0.43)
        for ti, tx15 in enumerate([int(W*f) for f in [0.04,0.14,0.24,0.36,0.52,0.65,0.76,0.88]]):
            tent_col = "#3a2c14" if ti%2==0 else "#342814"
            c.create_polygon(tx15-18, tent_y+14,
                             tx15, tent_y-20,
                             tx15+18, tent_y+14,
                             fill=tent_col, outline="#4a3c1e", width=1)
            c.create_line(tx15, tent_y-20, tx15, tent_y-32,
                          fill="#4a3818", width=2)
            # Guy ropes
            c.create_line(tx15, tent_y-20, tx15-24, tent_y+8,
                          fill="#2a2010", width=1)
            c.create_line(tx15, tent_y-20, tx15+24, tent_y+8,
                          fill="#2a2010", width=1)

        # Three large campfires
        for cfx, cfy in [(int(W*0.20),int(H*0.46)),
                          (int(W*0.48),int(H*0.45)),
                          (int(W*0.74),int(H*0.46))]:
            # Ash circle
            c.create_oval(cfx-22, cfy-10, cfx+22, cfy+8,
                          fill="#100c06", outline="")
            # Log cross
            c.create_line(cfx-18, cfy+2, cfx+18, cfy-4,
                          fill="#1e1208", width=5)
            c.create_line(cfx-14, cfy-6, cfx+14, cfy+4,
                          fill="#1e1208", width=5)
            # Flames
            for fi3 in range(5):
                fof3 = fi3*8-16
                flk3 = math.sin(t*5+fi3*1.2+cfx)*5
                r3 = 6-fi3
                c.create_oval(cfx+fof3-r3+flk3, cfy-18-fi3*4,
                              cfx+fof3+r3+flk3, cfy-4-fi3*4,
                              fill="#c86010" if fi3<3 else "#e8c020", outline="")
            # Fire glow on ground
            for gr2 in range(4,0,-1):
                g3 = int(0x10 + gr2*8)
                c.create_oval(cfx-gr2*16, cfy-gr2*8,
                              cfx+gr2*16, cfy+gr2*6,
                              fill=f"#{g3:02x}{g3//3:02x}02",
                              outline="", stipple="gray25" if gr2==4 else "")

        # Keelboat at right — massive, detailed
        kx = int(W*0.50); ky = int(H*0.50)
        # Hull shadow
        c.create_polygon(kx-82,ky+6, kx-58,ky-12, kx+80,ky-12, kx+88,ky+6,
                         fill="#060804", outline="")
        # Hull
        c.create_polygon(kx-80,ky, kx-56,ky-14, kx+78,ky-14, kx+86,ky,
                         fill="#0e0e08", outline="#1a1808", width=2)
        # Cabin
        c.create_rectangle(kx-20, ky-38, kx+42, ky-14,
                           fill="#141008", outline="#201808", width=1)
        # Cabin windows
        for cwx in [kx-10, kx+10, kx+28]:
            c.create_rectangle(cwx, ky-34, cwx+8, ky-20,
                               fill="#a06008", outline="#1e1208")
        # Mast
        c.create_line(kx+8, ky-14, kx+8, ky-82, fill="#1a1208", width=4)
        c.create_line(kx-18, ky-68, kx+38, ky-68, fill="#1a1208", width=2)
        # American flag — animated wave
        flag_pts = [kx+8, ky-68]
        for fi4 in range(8):
            fx16 = kx+8 + fi4*6
            fy16 = ky-68 + fi4*2 + int(math.sin(t*4+fi4*0.6)*4)
            flag_pts.extend([fx16, fy16])
        flag_pts.extend([kx+8+7*6, ky-68+7*2+16, kx+8, ky-68+16])
        c.create_polygon(flag_pts, fill="#881010", outline="")
        # Stripes
        for fs in range(3):
            c.create_line(kx+8, ky-68+4+fs*5, kx+8+38, ky-68+10+fs*5,
                          fill="#c8c0a0", width=2)
        # Swivel gun on bow
        c.create_rectangle(kx-72, ky-18, kx-56, ky-8,
                           fill="#1a1808", outline="#2a2010")
        c.create_line(kx-72, ky-13, kx-90, ky-20, fill="#1a1808", width=4)

        # Corps figures — drilling on bank
        for pi3, (px17,py17,fc17) in enumerate([
            (int(W*0.08),int(H*0.48),"#0e1028"),
            (int(W*0.14),int(H*0.48),"#1a1008"),
            (int(W*0.19),int(H*0.48),"#0e1028"),
            (int(W*0.30),int(H*0.48),"#0e0e18"),
            (int(W*0.35),int(H*0.48),"#1a1008"),
        ]):
            self._person(c, px17, py17, 0.72, fc17,
                         seated=False, facing_right=(pi3%2==0))

        # "CORPS OF DISCOVERY" banner between two poles
        bp1x = int(W*0.36); bp2x = int(W*0.64); bpy = int(H*0.38)
        c.create_line(bp1x, bpy, bp1x, bpy+int(H*0.12), fill="#2a1808", width=3)
        c.create_line(bp2x, bpy, bp2x, bpy+int(H*0.12), fill="#2a1808", width=3)
        wave_y = [bpy + int(math.sin(t*3+x*0.15)*5) for x in range(40)]
        banner_pts = [bp1x, bpy]
        for xi in range(40):
            banner_pts.extend([bp1x+xi*(bp2x-bp1x)//40, wave_y[xi]])
        banner_pts.extend([bp2x, bpy, bp2x, bpy+18,
                           bp1x+(bp2x-bp1x)//2, bpy+18+int(math.sin(t*3+20*0.15)*5),
                           bp1x, bpy+18])
        c.create_polygon(banner_pts, fill="#881010", outline="#aa2020")
        c.create_text((bp1x+bp2x)//2, bpy+9,
                      text="CORPS OF DISCOVERY",
                      font=("Georgia",8,"bold"), fill="#e8d060", anchor="center")

        c.create_text(10, H-28,
                      text="Camp Dubois, Illinois  ·  Winter 1803–1804",
                      font=("Georgia",9,"italic"), fill="#6a5028", anchor="w")

    # ── SCENE 6: The vast Missouri River ─────────────────────────────────────
    def _art_river(self, c, W, H, t):
        self._sky(c, W, H, ["#080c14","#0c1220","#121c30","#0e1828","#0a1420"], top_frac=0.55)
        # Milky Way
        for _ in range(100):
            sx18=random.randint(0,W); sy18=random.randint(0,int(H*0.50))
            bv18=random.randint(20,110)
            twk18=int(math.sin(t*1.8+sx18*0.04)*15)
            bv18b=max(15,min(130,bv18+twk18))
            c.create_oval(sx18-1,sy18-1,sx18+1,sy18+1,
                          fill=f"#{bv18b:02x}{bv18b:02x}{int(bv18b*0.85):02x}",outline="")

        # Full moon — large, dramatic
        mx19=int(W*0.74); my19=int(H*0.14)
        # Moon glow
        for mr19 in range(50,6,-8):
            g19=int(0x0c+mr19*0.4)
            c.create_oval(mx19-mr19,my19-mr19,mx19+mr19,my19+mr19,
                          fill=f"#{g19:02x}{g19:02x}{int(g19*0.9):02x}",outline="")
        # Moon disk
        c.create_oval(mx19-32,my19-32,mx19+32,my19+32,fill="#d4cE90",outline="")
        # Maria (dark patches)
        for mpx,mpy,mpr in [(mx19-10,my19-8,8),(mx19+8,my19+10,6),(mx19-8,my19+12,5)]:
            c.create_oval(mpx-mpr,mpy-mpr,mpx+mpr,mpy+mpr,fill="#b8b270",outline="")
        c.create_oval(mx19+12,my19-22,mx19+36,my19+4,fill="#0e1828",outline="")

        # Distant bluffs / cliffs — dramatic silhouettes
        bluff_pts=[0,H]
        for bx20 in range(0,W+4,4):
            by20 = H*0.46 + math.sin(bx20*0.005)*30 + math.sin(bx20*0.018)*15
            if random.Random(bx20).random()<0.02:
                by20 -= random.Random(bx20+1).randint(15,40)
            bluff_pts.extend([bx20,int(by20)])
        bluff_pts.extend([W,H])
        c.create_polygon(bluff_pts,fill="#0e1408",outline="")

        # Missouri River — the entire lower half
        for ri20 in range(int(H*0.46),H):
            sh20=math.sin(ri20*0.07+t*1.6)*0.4+0.55
            depth=(ri20-H*0.46)/(H*0.54)
            rr20=int((0x0c+sh20*0x16)*(1-depth*0.25))
            gg20=int((0x1e+sh20*0x12)*(1-depth*0.25))
            bb20=int((0x2c+sh20*0x18)*(1-depth*0.20))
            c.create_line(0,ri20,W,ri20,
                          fill=f"#{max(0,min(255,rr20)):02x}{max(0,min(255,gg20)):02x}{max(0,min(255,bb20)):02x}")

        # Moon road on water
        for mr21 in range(12):
            mry21=int(H*0.50+mr21*14)
            msx21=int(mx19+math.sin(t*0.8+mr21*0.3)*(mr21*4))
            mw21=max(2,int(20-mr21))
            c.create_oval(msx21-mw21,mry21-4,msx21+mw21,mry21+4,fill="#1e1e14",outline="")

        # Three boats — different distances for depth
        for bi22,(bfx22,bfy22,bscale22) in enumerate([
            (W*0.15, H*0.48, 0.55),
            (W*0.44, H*0.50, 0.80),
            (W*0.68, H*0.49, 0.65),
        ]):
            bx22=int(bfx22+math.sin(t*0.4+bi22)*5)
            by22=int(bfy22)
            s22=bscale22
            hw22=int(55*s22); hh22=int(11*s22)
            c.create_polygon(bx22-hw22,by22, bx22-int(38*s22),by22-hh22,
                             bx22+hw22,by22-hh22, bx22+int(62*s22),by22,
                             fill="#080c06",outline="#14180c",width=1)
            # Mast
            c.create_line(bx22+int(5*s22),by22-hh22,
                          bx22+int(5*s22),by22-hh22-int(50*s22),
                          fill="#0e1208",width=int(2*s22))
            # Torch or lantern at prow
            tpx=bx22-int(42*s22); tpy=by22-hh22
            lnsize=int(6*s22)
            c.create_oval(tpx-lnsize,tpy-lnsize*3,tpx+lnsize,tpy,
                          fill="#2a1408",outline="#3a1e08")
            fk23=math.sin(t*5+bi22*2)*2
            c.create_oval(tpx-2+fk23,tpy-lnsize*3-6,tpx+2+fk23,tpy-lnsize*2,
                          fill="#d07010",outline="")

        # Native fires on both banks — both shores are inhabited
        for nfx24,nfy24 in [(int(W*0.04),int(H*0.47)),(int(W*0.10),int(H*0.46)),
                             (int(W*0.88),int(H*0.47)),(int(W*0.94),int(H*0.46))]:
            c.create_oval(nfx24-10,nfy24-4,nfx24+10,nfy24+4,fill="#0e0a04",outline="")
            fk24=math.sin(t*5.5+nfx24)*3
            c.create_oval(nfx24-4+fk24,nfy24-12,nfx24+4+fk24,nfy24-2,fill="#b04808",outline="")
            c.create_oval(nfx24-2+fk24,nfy24-16,nfx24+2+fk24,nfy24-8,fill="#e8b010",outline="")
            # Small figure by fire
            self._person(c, nfx24+14, nfy24+2, 0.40, "#080c06",
                         seated=True, facing_right=(nfx24<W//2))

        # "THE MISSOURI RIVER" label in big cartouche
        cart_x=int(W*0.28); cart_y=int(H*0.58)
        c.create_oval(cart_x-70,cart_y-14,cart_x+70,cart_y+14,
                      fill="#0a1020",outline="#1e3050",width=2)
        c.create_text(cart_x,cart_y,text="THE MISSOURI RIVER",
                      font=("Georgia",9,"bold italic"),fill="#3a6080",anchor="center")

        c.create_text(10,H-28,
                      text="The Louisiana Territory  ·  2,341 miles of river",
                      font=("Georgia",9,"italic"),fill="#6a5028",anchor="w")

    # ── SCENE 7: Dawn departure ───────────────────────────────────────────────
    def _art_departure(self, c, W, H, t):
        # Golden dawn — the most joyful scene
        dawn = ["#0a0806","#160e06","#221406","#342008","#462c0a","#583a0c","#6a480e",
                "#7a5610","#8a6614","#7a5610","#6a480e"]
        n25=len(dawn)
        rows25=int(H*0.52)
        for i25 in range(rows25):
            seg25=i25/rows25*(n25-1); lo25=int(seg25); hi25=min(n25-1,lo25+1); f25=seg25-lo25
            r25,g25,b25=[int(dawn[lo25][j:j+2],16) for j in (1,3,5)]
            r25b,g25b,b25b=[int(dawn[hi25][j:j+2],16) for j in (1,3,5)]
            r25c=int(r25+(r25b-r25)*f25); g25c=int(g25+(g25b-g25)*f25); b25c=int(b25+(b25b-b25)*f25)
            c.create_line(0,i25,W,i25,fill=f"#{r25c:02x}{g25c:02x}{b25c:02x}")

        # Sun — just cresting the horizon, rays flooding sky
        sun_y=int(H*0.44+math.sin(t*0.12)*4); sun_x=W//2
        # Sun rays first (behind everything)
        for ray25 in range(24):
            ang25=ray25*15; length25=int(90+math.sin(t*2+ray25)*18)
            rx25=sun_x+int(math.cos(math.radians(ang25))*length25)
            ry25=sun_y+int(math.sin(math.radians(ang25))*length25)
            ray_alpha=max(0,int((1-length25/120)*80))
            c.create_line(sun_x,sun_y,rx25,ry25,fill="#5a3008",width=1)
        # Sun disk
        for sr25 in range(60,2,-10):
            frac25=(60-sr25)/60
            rr25=min(255,int(0xa0*frac25+0x28)); gg25=min(255,int(0x48*frac25+0x0c))
            c.create_oval(sun_x-sr25,sun_y-sr25,sun_x+sr25,sun_y+sr25,
                          fill=f"#{rr25:02x}{gg25:02x}00",outline="")

        # River — shimmering gold
        for ri26 in range(int(H*0.44),H):
            depth26=(ri26-H*0.44)/(H*0.56)
            sh26=math.sin(ri26*0.07+t*2.5)*0.45+0.52
            rr26=min(255,int(0x20+sh26*0x2a+depth26*8))
            gg26=min(255,int(0x18+sh26*0x16+depth26*4))
            bb26=min(255,int(0x08+sh26*0x0c))
            c.create_line(0,ri26,W,ri26,fill=f"#{rr26:02x}{gg26:02x}{bb26:02x}")

        # South bank treeline
        tree_pts26=[0,H]
        for tx27 in range(0,W+6,6):
            ty27=int(H*0.44+math.sin(tx27*0.018)*8+math.sin(tx27*0.06)*4)
            tree_pts26.extend([tx27,ty27])
        tree_pts26.extend([W,H]); c.create_polygon(tree_pts26,fill="#060806",outline="")

        # KEELBOAT — large hero boat, moving right, fully detailed
        kx28=int(W*0.22+t*10)%int(W*1.2)-int(W*0.1)
        ky28=int(H*0.48)
        # Hull shadow
        c.create_polygon(kx28-88,ky28+8, kx28-60,ky28-16,
                         kx28+88,ky28-16, kx28+96,ky28+8,
                         fill="#0a0c08",outline="")
        # Hull — brown
        c.create_polygon(kx28-86,ky28, kx28-58,ky28-18,
                         kx28+86,ky28-18, kx28+94,ky28,
                         fill="#1a1008",outline="#2a1a08",width=2)
        # Cabin
        c.create_rectangle(kx28-22,ky28-44,kx28+48,ky28-18,
                           fill="#141008",outline="#201808",width=1)
        for cw29 in [kx28-12,kx28+8,kx28+28,kx28+44]:
            c.create_rectangle(cw29,ky28-40,cw29+8,ky28-24,fill="#c07810",outline="#1a1208")
        # Mast
        c.create_line(kx28+10,ky28-18,kx28+10,ky28-96,fill="#1e1408",width=5)
        c.create_line(kx28-22,ky28-80,kx28+44,ky28-80,fill="#1e1408",width=2)
        # Large American flag — animated
        for fi30 in range(6):
            fx30=kx28+10+fi30*10
            fy30=ky28-96+fi30*3+int(math.sin(t*4.5+fi30*0.7)*6)
            col30="#881010" if fi30%2==0 else "#c8b890"
            c.create_rectangle(fx30,ky28-96,fx30+10,ky28-80,fill=col30,outline="")
        # Swivel gun
        c.create_rectangle(kx28-78,ky28-22,kx28-60,ky28-10,fill="#1a1808",outline="#2a2010")
        c.create_line(kx28-78,ky28-16,kx28-96,ky28-24,fill="#1a1808",width=5)

        # Two pirogues — smaller, flanking keelboat
        for pirogue_x, pirogue_facing in [(kx28-120, -1),(kx28+110, 1)]:
            px31=pirogue_x+int(math.sin(t*0.5+pirogue_x)*4)
            py31=int(H*0.49)
            hw31=int(38*0.7); hh31=int(8*0.7)
            c.create_polygon(px31-hw31,py31, px31-int(26*0.7),py31-hh31,
                             px31+hw31,py31-hh31, px31+int(42*0.7),py31,
                             fill="#0e0e0a",outline="#1a1808",width=1)
            # Paddler
            self._person(c, px31+int(10*pirogue_facing), py31-int(hh31*1.5),
                         0.45, "#0e0c08", seated=True, facing_right=(pirogue_facing>0))

        # Crowd on south bank — large, varied silhouettes
        crowd_y=int(H*0.44)
        for pi32 in range(28):
            px33=pi32*46+8
            wave33=math.sin(t*3.2+pi32)*8
            col33=["#0a0e06","#080c08","#0c0e06"][pi32%3]
            # Body
            c.create_rectangle(px33-5,crowd_y-18,px33+5,crowd_y,fill=col33,outline="")
            # Head
            c.create_oval(px33-5,crowd_y-30,px33+5,crowd_y-18,fill=col33,outline="")
            # Waving arm
            c.create_line(px33+5,crowd_y-14,px33+int(16*math.sin(t*3+pi32)),
                          crowd_y-14-int(abs(wave33)),fill=col33,width=3)

        # American flag on shore — planted
        c.create_line(int(W*0.88),crowd_y,int(W*0.88),crowd_y-52,fill="#1e1808",width=3)
        for fi34 in range(4):
            fx35=int(W*0.88)+fi34*10
            fy35=crowd_y-52+fi34*3+int(math.sin(t*4+fi34*0.8)*5)
            c.create_rectangle(fx35,crowd_y-52,fx35+10,crowd_y-38,
                               fill="#881010" if fi34%2==0 else "#c8b870",outline="")

        # DATE stamp — dramatic
        c.create_text(W//2, H-40,
                      text="MAY 14, 1804  ·  4 O'CLOCK IN THE AFTERNOON",
                      font=("Georgia",11,"bold"), fill="#d4941a", anchor="center")
        c.create_text(W//2, H-22,
                      text="Camp Dubois, Illinois Territory  ·  The Adventure Begins",
                      font=("Georgia",9,"italic"), fill="#8a6828", anchor="center")



class LewisClarkGame:
    W,H = 1280,830

    def __init__(self, root: tk.Tk):
        self.root=root
        self.root.title("Lewis & Clark — Corps of Discovery  1804")
        self.root.configure(bg=C["bg"])
        self.root.geometry(f"{self.W}x{self.H}")
        self.root.resizable(False,False)
        self.state: Optional[GameState]=None
        self.pending_event=None
        self._cine_idx=0; self._cine_line=0; self._cine_char=0; self._cine_pause=0
        self._cine_anim_id=None    # cinematic animation loop
        self._part_anim_id=None    # particle/map animation loop
        self._particles:list=[]
        self._hover_wp:Optional[int]=None
        self._zoom=1.0; self._pan_x=0.0; self._pan_y=0.0
        self._show_territories=True
        self._scene_renderer:Optional[SceneRenderer]=None
        self._build_fonts()
        self._show_title()

    # ══════════════════════════════════════════════════════════════════════════
    #  ANIMATED TITLE SCREEN
    # ══════════════════════════════════════════════════════════════════════════
    def _show_title(self):
        self._cancel_anim()
        for w in self.root.winfo_children(): w.destroy()
        W,H = self.W,self.H

        self.title_canvas = tk.Canvas(self.root,width=W,height=H,bg=C["bg"],highlightthickness=0)
        self.title_canvas.place(x=0,y=0)

        # Buttons placed above canvas
        btn_y = H-70
        tk.Button(self.root,text="⚑   BEGIN EXPEDITION   ⚑",font=self.F["btn_lg"],
                  bg=C["gold"],fg=C["ink"],activebackground=C["gold2"],activeforeground=C["ink"],
                  relief="flat",bd=0,cursor="hand2",padx=32,pady=12,
                  command=self._show_cinematic).place(x=W//2-160,y=btn_y)
        tk.Button(self.root,text="Load Saved Expedition",font=self.F["btn"],
                  bg=C["card2"],fg=C["parch2"],activebackground=C["card"],activeforeground=C["parch"],
                  relief="flat",bd=0,cursor="hand2",padx=16,pady=7,
                  command=self._title_load).place(x=W//2-90,y=btn_y+58)

        self._title_frame = 0
        self._animate_title()

    def _animate_title(self):
        if not hasattr(self,'title_canvas') or not self.title_canvas.winfo_exists(): return
        c = self.title_canvas
        c.delete("all")
        W,H = self.W,self.H
        f = self._title_frame
        t = f * 0.018

        # ── Parallax sky layers ────────────────────────────────────────────
        # Deep sky gradient
        for i in range(int(H*0.62)):
            frac = i/(H*0.62)
            rr = int(0x0c + frac*0x14)
            gg = int(0x09 + frac*0x0e)
            bb = int(0x05 + frac*0x08)
            c.create_line(0,i,W,i,fill=f"#{rr:02x}{gg:02x}{bb:02x}")

        # Stars (fixed)
        rng = random.Random(42)
        for _ in range(120):
            sx=rng.randint(0,W); sy=rng.randint(0,int(H*0.40))
            bright = rng.randint(60,140)
            twinkle = int(math.sin(t*2.5+sx*0.1)*20)
            bv = min(255,max(20,bright+twinkle))
            c.create_oval(sx-1,sy-1,sx+1,sy+1,fill=f"#{bv:02x}{bv:02x}{int(bv*0.85):02x}",outline="")

        # Moon
        mx,my = W*0.80,H*0.14
        c.create_oval(mx-38,my-38,mx+38,my+38,fill="#d8cca0",outline="")
        c.create_oval(mx+12,my-28,mx+46,my+10,fill="#1a1208",outline="")  # shadow crescent

        # Distant mountains (parallax layer 1 — slowest)
        pan1 = math.sin(t*0.12)*8
        for mi,(mxf,myf,mwf,mcol) in enumerate([
            (0.82,0.30,0.18,"#141008"),(0.60,0.26,0.16,"#101008"),
            (0.38,0.28,0.14,"#141008"),(0.18,0.24,0.12,"#101008"),
        ]):
            mx2,my2 = (mxf+pan1/W)*W, myf*H; mw2=mwf*W
            c.create_polygon(mx2-mw2,H*0.62, mx2,my2, mx2+mw2,H*0.62,
                             fill=mcol,outline="",smooth=True)

        # River valley (layer 2 — mid speed)
        pan2 = math.sin(t*0.18)*12
        river_pts = [0,H]
        for rx in range(0,W+8,8):
            ry = H*0.58 + math.sin((rx+pan2)*0.008)*18 + math.sin((rx+pan2)*0.022)*8
            river_pts.extend([rx,int(ry)])
        river_pts.extend([W,H])
        c.create_polygon(river_pts,fill="#1a2c10",outline="")

        # Foreground hills (layer 3 — fastest)
        pan3 = math.sin(t*0.25)*16
        fg_pts = [0,H]
        for rx in range(0,W+8,8):
            ry = H*0.68 + math.sin((rx+pan3)*0.012)*12 + math.sin((rx+pan3)*0.03)*6
            fg_pts.extend([rx,int(ry)])
        fg_pts.extend([W,H])
        c.create_polygon(fg_pts,fill="#0e1808",outline="")

        # River shimmer
        rv_y = int(H*0.60)
        for ri in range(20):
            ry2 = rv_y + ri*4
            sh = math.sin(ry2*0.12+t*2)*0.4+0.55
            rr2 = min(255,int(0x10+sh*0x14)); gg2 = min(255,int(0x20+sh*0x0e)); bb2 = min(255,int(0x2c+sh*0x0c))
            c.create_line(0,ry2,W,ry2,fill=f"#{rr2:02x}{gg2:02x}{bb2:02x}")

        # Campfire glow (left foreground)
        fgx,fgy = W*0.22,H*0.70
        for gr in range(5,0,-1):
            glow_col = int(0x18+gr*8)
            c.create_oval(fgx-gr*14,fgy-gr*8,fgx+gr*14,fgy+gr*4,
                          fill=f"#{glow_col:02x}{int(glow_col*0.5):02x}04",outline="")
        for fi in range(4):
            fof = fi*6-9; flick = math.sin(t*7+fi)*5
            c.create_oval(fgx+fof-4+flick,fgy-18,fgx+fof+4+flick,fgy-2,fill="#d07010",outline="")
            c.create_oval(fgx+fof-2+flick,fgy-24,fgx+fof+2+flick,fgy-12,fill="#f0d020",outline="")
        # Logs
        c.create_line(fgx-20,fgy+2,fgx+20,fgy-4,fill="#1a1208",width=5)
        c.create_line(fgx-15,fgy-4,fgx+25,fgy+2,fill="#1a1208",width=5)

        # Silhouette figures around fire
        for fx2,fy2,col2 in [(fgx-50,fgy-5,"#0a0e08"),(fgx+42,fgy-8,"#0a0e08"),(fgx-18,fgy-12,"#0c1008")]:
            c.create_oval(fx2-6,fy2-16,fx2+6,fy2-4,fill=col2,outline="")
            c.create_rectangle(fx2-8,fy2-4,fx2+8,fy2+14,fill=col2,outline="")

        # Keelboat silhouette on river (moves slowly left)
        bx = W*0.65 - (f*0.5)%W
        by = int(H*0.615)
        pts = [bx-55,by, bx-38,by-12, bx+55,by-12, bx+62,by]
        c.create_polygon(pts,fill="#080c08",outline="")
        c.create_line(bx+8,by-12,bx+8,by-52,fill="#0c1008",width=3)
        # Flag
        for fi2 in range(4):
            fx3 = bx+8+fi2*10
            fy3 = by-52+fi2*2+int(math.sin(t*4+fi2*0.8)*4)
            c.create_line(fx3,by-52,fx3+10,fy3,fill="#6a0c0e" if fi2%2==0 else "#a09070",width=2)

        # ── Title text ────────────────────────────────────────────────────
        # Decorative rule above title
        rule_y = int(H*0.28)
        c.create_line(W//2-220,rule_y,W//2+220,rule_y,fill=C["bgold"],width=1)
        # Diamond ornaments
        for ox in [-220,220]:
            c.create_polygon(W//2+ox,rule_y, W//2+ox+8,rule_y-4,
                             W//2+ox+16,rule_y, W//2+ox+8,rule_y+4,
                             fill=C["gold"],outline="")

        # Main title — drop shadow then gold
        title_y = int(H*0.32)
        c.create_text(W//2+3,title_y+3,text="LEWIS & CLARK",font=self.F["display"],fill="#050302",anchor="center")
        c.create_text(W//2,  title_y,  text="LEWIS & CLARK",font=self.F["display"],fill=C["gold"],anchor="center")

        subtitle_y = title_y+46
        c.create_text(W//2+2,subtitle_y+2,text="EXPEDITION",font=self.F["display"],fill="#050302",anchor="center")
        c.create_text(W//2,  subtitle_y,  text="EXPEDITION",font=self.F["display"],fill=C["gold2"],anchor="center")

        # Subtitle tagline
        tag_y = subtitle_y+48
        c.create_line(W//2-160,tag_y-8,W//2+160,tag_y-8,fill=C["bgold"],width=1)
        c.create_text(W//2,tag_y+4,text="Corps of Discovery  ·  1804–1806",
                      font=self.F["year"],fill=C["parch3"],anchor="center")
        c.create_line(W//2-160,tag_y+18,W//2+160,tag_y+18,fill=C["bgold"],width=1)

        # Jefferson quote (fades in after frame 60)
        if f > 60:
            alpha = min(1.0,(f-60)/40)
            r3=int(0x6a*alpha); g3=int(0x50*alpha); b3=int(0x28*alpha)
            quote_col = f"#{r3:02x}{g3:02x}{b3:02x}"
            c.create_text(W//2,tag_y+44,
                          text='"The object of your mission is to explore the Missouri River..."',
                          font=self.F["small"],fill=quote_col,anchor="center")
            c.create_text(W//2,tag_y+60,text="— President Thomas Jefferson, 1803",
                          font=self.F["tiny"],fill=quote_col,anchor="center")

        # Film grain
        if f%4<2:
            for _ in range(40):
                gx=random.randint(0,W); gy=random.randint(0,H)
                c.create_rectangle(gx,gy,gx+2,gy+2,fill=C["bg2"],outline="")

        self._title_frame += 1
        self._cine_anim_id = self.root.after(40, self._animate_title)

    def _title_load(self):
        self._cancel_anim()
        path=filedialog.askopenfilename(filetypes=[("Lewis & Clark Save","*.json"),("All Files","*.*")],title="Load Expedition")
        if not path: self._show_title(); return
        try:
            with open(path,"r") as f: data=json.load(f)
            self._start_game(state=GameState.from_dict(data))
        except Exception as e:
            messagebox.showerror("Error",str(e)); self._show_title()

    # ── Fonts ──────────────────────────────────────────────────────────────────
    def _build_fonts(self):
        fams=tkfont.families()
        serif=next((f for f in ["Palatino Linotype","Palatino","Book Antiqua","Georgia"] if f in fams),"Georgia")
        mono=next((f for f in ["Consolas","Lucida Console","Courier New","Courier"] if f in fams),"Courier")
        self.F={
            "display":  tkfont.Font(family=serif,size=28,weight="bold"),
            "title":    tkfont.Font(family=serif,size=17,weight="bold"),
            "cine":     tkfont.Font(family=serif,size=16,weight="bold"),
            "year":     tkfont.Font(family=serif,size=11,slant="italic"),
            "loc":      tkfont.Font(family=serif,size=10,slant="italic"),
            "header":   tkfont.Font(family=serif,size=11,weight="bold"),
            "subhead":  tkfont.Font(family=serif,size=10,weight="bold"),
            "body":     tkfont.Font(family=serif,size=10),
            "narration":tkfont.Font(family=serif,size=11),
            "small":    tkfont.Font(family=serif,size=9),
            "tiny":     tkfont.Font(family=serif,size=8),
            "mono":     tkfont.Font(family=mono, size=9),
            "mono_sm":  tkfont.Font(family=mono, size=8),
            "btn":      tkfont.Font(family=serif,size=10,weight="bold"),
            "btn_lg":   tkfont.Font(family=serif,size=13,weight="bold"),
            "map_lbl":  tkfont.Font(family=mono, size=7),
            "huge":     tkfont.Font(family=serif,size=48,weight="bold"),
        }

    # ══════════════════════════════════════════════════════════════════════════
    #  CINEMATIC — Full illustrated animated presentation
    # ══════════════════════════════════════════════════════════════════════════
    def _show_cinematic(self):
        self._cancel_anim()
        for w in self.root.winfo_children(): w.destroy()
        self._cine_char=0; self._cine_line=0; self._cine_pause=0

        W,H=self.W,self.H

        # ONE full-window canvas — scene art + narration drawn together
        self.scene_canvas=tk.Canvas(self.root,width=W,height=H,
                                    bg="#0a0806",highlightthickness=0)
        self.scene_canvas.place(x=0,y=0)
        self._scene_renderer=SceneRenderer(self.scene_canvas)
        self._scene_renderer._slide_idx=self._cine_idx

        # Navigation buttons float above canvas
        nav_y=H-52
        if self._cine_idx>0:
            tk.Button(self.root,text="◀  BACK",font=self.F["btn"],
                      bg="#1a1208",fg=C["dim2"],activebackground=C["card"],
                      activeforeground=C["parch"],relief="flat",bd=0,cursor="hand2",
                      padx=14,pady=7,command=self._cine_back).place(x=W*3//5+20,y=nav_y)

        if self._cine_idx<len(CINE_SCENES)-1:
            tk.Button(self.root,text="NEXT CHAPTER  ▶",font=self.F["btn"],
                      bg=C["card2"],fg=C["gold2"],activebackground=C["gold"],
                      activeforeground=C["ink"],relief="flat",bd=0,cursor="hand2",
                      padx=16,pady=7,command=self._cine_next).place(x=W*3//5+140,y=nav_y)
        else:
            tk.Button(self.root,text="⚑   BEGIN THE EXPEDITION   ⚑",
                      font=self.F["btn_lg"],bg=C["gold"],fg=C["ink"],
                      activebackground=C["gold2"],activeforeground=C["ink"],
                      relief="flat",bd=0,cursor="hand2",padx=24,pady=10,
                      command=self._start_game).place(x=W*3//5+100,y=nav_y-4)

        tk.Button(self.root,text="Skip All",font=self.F["small"],
                  bg="#0a0806",fg=C["dim"],activebackground="#0a0806",
                  activeforeground=C["dim2"],relief="flat",bd=0,cursor="hand2",
                  command=self._start_game).place(x=W-70,y=H-18)

        self._animate_cine()

    def _animate_cine(self):
        if not hasattr(self,'scene_canvas') or not self.scene_canvas.winfo_exists(): return
        sd=CINE_SCENES[self._cine_idx]
        self._scene_renderer._slide_idx=self._cine_idx
        # Draw entire frame — art + narration on one canvas
        self._scene_renderer.draw_full(
            sd, self._cine_line, self._cine_char, self._cine_pause, self.F)
        self._scene_renderer.tick()
        # Advance typewriter state
        narr=sd["narration"]
        if self._cine_pause>0:
            self._cine_pause-=1
        elif self._cine_line<len(narr):
            self._cine_char+=3
            if self._cine_char>=len(narr[self._cine_line]):
                self._cine_line+=1; self._cine_char=0; self._cine_pause=22
        self._cine_anim_id=self.root.after(40,self._animate_cine)

    def _cine_next(self):
        self._cancel_anim(); self._cine_idx=min(len(CINE_SCENES)-1,self._cine_idx+1); self._show_cinematic()
    def _cine_back(self):
        self._cancel_anim(); self._cine_idx=max(0,self._cine_idx-1); self._show_cinematic()
    def _cancel_anim(self):
        for attr in ('_cine_anim_id','_part_anim_id'):
            aid=getattr(self,attr,None)
            if aid:
                try: self.root.after_cancel(aid)
                except: pass
                setattr(self,attr,None)

    # ══════════════════════════════════════════════════════════════════════════
    #  MAIN GAME UI
    # ══════════════════════════════════════════════════════════════════════════
    def _start_game(self, state: Optional[GameState]=None):
        self._cancel_anim()
        for w in self.root.winfo_children(): w.destroy()
        self.state=state or GameState()
        self._particles=[]; self._hover_wp=None
        self._zoom=1.0; self._pan_x=0.0; self._pan_y=0.0
        self._build_ui()
        if not state:
            self.state.add_journal("We set out from Camp Dubois. The Corps of Discovery — 33 strong — begins its great journey.")
            self.state.add_journal("York and Drouillard march with us. Sacagawea will join at Fort Mandan.")
        self._refresh()
        self._show_travel_actions()
        # Start particle loop only after UI is built
        self.root.after(200, self._particle_tick)

    def _build_ui(self):
        W,H=self.W,self.H
        # Menu
        menubar=tk.Menu(self.root,bg=C["bg2"],fg=C["parch2"],activebackground=C["gold"],activeforeground=C["ink"],tearoff=0)
        fm=tk.Menu(menubar,bg=C["panel"],fg=C["parch2"],activebackground=C["gold"],activeforeground=C["ink"],tearoff=0)
        fm.add_command(label="  Save Expedition",command=self._save_game)
        fm.add_command(label="  Load Expedition",command=self._load_game)
        fm.add_separator()
        fm.add_command(label="  New Expedition",command=self._new_game)
        fm.add_command(label="  Watch Intro",command=self._rewatch_intro)
        menubar.add_cascade(label=" Expedition ",menu=fm)
        self.root.config(menu=menubar)

        # BG
        self.bg_c=tk.Canvas(self.root,width=W,height=H,bg=C["bg"],highlightthickness=0)
        self.bg_c.place(x=0,y=0)
        for i in range(0,W+H,22): self.bg_c.create_line(i,0,max(0,i-H),min(H,i),fill=C["bg2"],width=1)

        # Header
        hdr=tk.Frame(self.root,bg=C["bg2"],height=46)
        hdr.place(x=0,y=0,width=W)
        tk.Frame(hdr,bg=C["gold"],height=2).pack(fill="x",side="top")
        tk.Label(hdr,text="⚑   LEWIS & CLARK EXPEDITION   ·   CORPS OF DISCOVERY   ⚑",
                 font=self.F["title"],bg=C["bg2"],fg=C["gold"]).pack(side="left",padx=18,pady=4)
        self.season_lbl=tk.Label(hdr,text="",font=self.F["small"],bg=C["bg2"],fg=C["parch3"])
        self.season_lbl.pack(side="right",padx=18)
        tk.Frame(hdr,bg=C["border"],height=1).pack(fill="x",side="bottom")

        # ── Map panel (large, left) ───────────────────────────────────────────
        mx,my,mw,mh=8,50,750,440
        self._panel(mx,my,mx+mw,my+mh,"LOUISIANA TERRITORY  ·  1804–1806")
        # Zoom controls
        tk.Button(self.root,text="+",font=self.F["btn"],bg=C["card2"],fg=C["gold"],
                  relief="flat",cursor="hand2",width=2,command=self._zoom_in
                  ).place(x=mx+mw-58,y=my+26)
        tk.Button(self.root,text="−",font=self.F["btn"],bg=C["card2"],fg=C["gold"],
                  relief="flat",cursor="hand2",width=2,command=self._zoom_out
                  ).place(x=mx+mw-36,y=my+26)
        tk.Button(self.root,text="⊡",font=self.F["tiny"],bg=C["card2"],fg=C["parch3"],
                  relief="flat",cursor="hand2",width=2,command=self._zoom_reset
                  ).place(x=mx+mw-14,y=my+28)
        # Territory toggle
        self.terr_var=tk.BooleanVar(value=True)
        tk.Checkbutton(self.root,text="Territories",variable=self.terr_var,
                       font=self.F["tiny"],bg=C["bg2"],fg=C["parch3"],
                       selectcolor=C["card"],activebackground=C["bg2"],
                       command=self._toggle_territories
                       ).place(x=mx+8,y=my+26)
        self.map_canvas=tk.Canvas(self.root,width=mw-14,height=mh-42,
                                  bg=C["water"],highlightthickness=0,cursor="crosshair")
        self.map_canvas.place(x=mx+7,y=my+42)
        self.map_canvas.bind("<Motion>",self._map_hover)
        self.map_canvas.bind("<Leave>",lambda e:self._map_unhover())
        self.map_canvas.bind("<Button-1>",self._map_click)
        self.map_canvas.bind("<Button-4>",lambda e:self._zoom_in())
        self.map_canvas.bind("<Button-5>",lambda e:self._zoom_out())
        self.map_canvas.bind("<MouseWheel>",lambda e:self._zoom_in() if e.delta>0 else self._zoom_out())
        self.map_canvas.bind("<ButtonPress-2>",self._pan_start)
        self.map_canvas.bind("<B2-Motion>",self._pan_move)
        self._pan_last=None

        # ── Stat bars ─────────────────────────────────────────────────────────
        sx,sy,sh=mx,my+mh+4,118
        self._panel(sx,sy,sx+mw,sy+sh,"EXPEDITION STATUS")
        self._build_stats(sx+10,sy+26,mw-20)

        # ── Corps panel ───────────────────────────────────────────────────────
        chx,chy,chh=mx,sy+sh+4,100
        self._panel(chx,chy,chx+mw,chy+chh,"CORPS MEMBERS")
        self._build_chars(chx+10,chy+24,mw-20,chh-32)

        # ── Right column ──────────────────────────────────────────────────────
        rpx=mx+mw+6; rpw=W-rpx-8
        jy,jh=50,360
        self._panel(rpx,jy,rpx+rpw,jy+jh,"EXPEDITION JOURNAL")
        self.journal_text=tk.Text(self.root,wrap="word",bg=C["ink"],fg=C["parch"],
                                  font=self.F["mono"],bd=0,padx=8,pady=6,state="disabled")
        self.journal_text.place(x=rpx+6,y=jy+24,width=rpw-12,height=jh-32)

        ay,ah=jy+jh+4,246
        self._panel(rpx,ay,rpx+rpw,ay+ah,"ACTIONS  ·  DECISIONS")
        self.action_frame=tk.Frame(self.root,bg=C["panel"])
        self.action_frame.place(x=rpx+6,y=ay+24,width=rpw-12,height=ah-32)

        oy=ay+ah+4; oh=H-oy-8
        self._panel(rpx,oy,rpx+rpw,oy+oh,"EXPEDITION OBJECTIVES")
        self.obj_frame=tk.Frame(self.root,bg=C["panel"])
        self.obj_frame.place(x=rpx+6,y=oy+24,width=rpw-12,height=oh-32)

    def _panel(self,x1,y1,x2,y2,title=""):
        c=self.bg_c
        c.create_rectangle(x1,y1,x2,y2,fill=C["panel"],outline="")
        c.create_rectangle(x1,y1,x2,y2,fill="",outline=C["border"],width=1)
        c.create_line(x1+2,y1+20,x2-2,y1+20,fill=C["bgold"],width=1)
        for cx,cy in [(x1,y1),(x2,y1),(x1,y2),(x2,y2)]:
            dx=1 if cx==x1 else -1; dy=1 if cy==y1 else -1
            c.create_line(cx,cy,cx+dx*8,cy,fill=C["gold"],width=2)
            c.create_line(cx,cy,cx,cy+dy*8,fill=C["gold"],width=2)
        if title: c.create_text(x1+10,y1+10,text=title,font=self.F["tiny"],fill=C["parch3"],anchor="w")

    def _build_stats(self,x,y,w):
        self.stat_bars={}
        bw=(w-28)//3
        STAT_META = [
            ("FOOD",   "food",   C["gold"],   "⬡", "Provisions remaining"),
            ("HEALTH", "health", C["green2"], "✦", "Corps health & fitness"),
            ("MORALE", "morale", C["blue2"],  "◈", "Expedition spirit"),
        ]
        for i,(lbl,key,col,icon,tip) in enumerate(STAT_META):
            bx=x+i*(bw+12)
            # Icon + label row
            il=tk.Frame(self.root,bg=C["panel"]); il.place(x=bx,y=y,width=bw)
            tk.Label(il,text=icon,font=self.F["tiny"],bg=C["panel"],fg=col).pack(side="left")
            tk.Label(il,text=lbl,font=self.F["tiny"],bg=C["panel"],fg=C["parch3"]).pack(side="left",padx=2)
            # Track
            track=tk.Canvas(self.root,width=bw,height=18,bg=C["bg2"],highlightthickness=0); track.place(x=bx,y=y+16)
            # Tick marks at 25/50/75
            for n in [1,2,3]: nx=int(bw*n/4); track.create_line(nx,0,nx,18,fill=C["bg3"],width=1)
            # Danger zone (0-25) overlay
            track.create_rectangle(0,0,int(bw*0.25),18,fill=C["red"],outline="",stipple="gray25")
            fill=tk.Canvas(self.root,width=bw-2,height=16,bg=col,highlightthickness=0); fill.place(x=bx+1,y=y+17)
            vl=tk.Label(self.root,text="80",font=self.F["tiny"],bg=C["panel"],fg=col); vl.place(x=bx,y=y+38)
            self.stat_bars[key]=(track,fill,vl,col,bw)

    def _build_chars(self,x,y,w,h):
        self.char_widgets={}
        cw=(w-20)//3
        PORTRAITS = {
            "york":       ("#d08030","◆","#2a1a0a"),   # warm amber skin, dark clothes
            "drouillard": ("#a87840","⬟","#1a1408"),   # tawny, buckskin
            "sacagawea":  ("#c09060","★","#2a1808"),   # warm tan, decorated robe
        }
        for i,key in enumerate(["york","drouillard","sacagawea"]):
            cx=x+i*(cw+8); base=SPECIAL_CHARACTERS[key]
            skin_col, sym, cloth_col = PORTRAITS[key]

            # Outer frame
            fr=tk.Frame(self.root,bg=C["card"],width=cw,height=h,cursor="hand2")
            fr.place(x=cx,y=y); fr.pack_propagate(False)

            # Portrait canvas (left side)
            pc=tk.Canvas(fr,width=48,height=h-4,bg=C["card2"],highlightthickness=0)
            pc.pack(side="left",padx=(2,0),pady=2)
            self._draw_portrait(pc,48,h-4,skin_col,cloth_col,sym,base["active"])

            # Text info (right side)
            inf=tk.Frame(fr,bg=C["card"]); inf.pack(side="left",fill="both",expand=True,padx=4,pady=3)
            nl=tk.Label(inf,text=base["name"],font=self.F["subhead"],bg=C["card"],fg=C["parch"],anchor="w"); nl.pack(fill="x")
            tl=tk.Label(inf,text=base["title"],font=self.F["tiny"],bg=C["card"],fg=C["dim2"],anchor="w",wraplength=cw-58); tl.pack(fill="x")
            sl=tk.Label(inf,text="",font=self.F["tiny"],bg=C["card"],fg=C["green2"],anchor="w"); sl.pack(fill="x")

            for ww in [fr,pc,nl,tl,inf]:
                ww.bind("<Button-1>",lambda e,k=key:self._show_char_detail(k))

            self.char_widgets[key]=(fr,pc,nl,tl,sl)

        # Inventory button
        inv_x=x+3*(cw+8)+2
        tk.Button(self.root,text="🎒 Inventory",font=self.F["tiny"],bg=C["card2"],fg=C["parch2"],
                  activebackground=C["gold"],activeforeground=C["ink"],relief="flat",cursor="hand2",
                  command=self._show_inventory,padx=7,pady=3).place(x=inv_x,y=y+h//2-14)

    def _draw_portrait(self,canvas,W,H,skin,cloth,sym,active):
        """Draw a simple illustrated character portrait silhouette."""
        c=canvas; bg=C["card2"] if active else C["bg2"]
        c.configure(bg=bg)
        cx=W//2; head_y=H//4; body_y=H//2

        if not active:
            # Ghost/locked portrait — silhouette only
            c.create_oval(cx-10,head_y-10,cx+10,head_y+10,fill=C["dim"],outline="")
            c.create_rectangle(cx-12,body_y-10,cx+12,body_y+20,fill=C["dim"],outline="")
            c.create_text(cx,H-10,text="?",font=self.F["small"],fill=C["dim2"],anchor="center")
            return

        # Body clothing
        c.create_rectangle(cx-12,body_y-8,cx+12,body_y+22,fill=cloth,outline="")
        # Arms
        c.create_line(cx-12,body_y-4,cx-20,body_y+10,fill=cloth,width=5)
        c.create_line(cx+12,body_y-4,cx+20,body_y+10,fill=cloth,width=5)
        # Head
        c.create_oval(cx-10,head_y-10,cx+10,head_y+10,fill=skin,outline="")
        # Hair/hat detail (small)
        c.create_rectangle(cx-11,head_y-12,cx+11,head_y-6,fill=C["bg"],outline="")  # hat brim
        c.create_rectangle(cx-7,head_y-22,cx+7,head_y-11,fill=C["bg"],outline="")   # hat crown
        # Character symbol badge
        c.create_rectangle(cx-8,H-18,cx+8,H-4,fill=C["card"],outline=C["bgold"],width=1)
        c.create_text(cx,H-11,text=sym,font=self.F["tiny"],fill=C["gold"],anchor="center")

    # ══════════════════════════════════════════════════════════════════════════
    #  EU4-STYLE MAP WITH ZOOM/PAN + TERRITORY OVERLAY
    # ══════════════════════════════════════════════════════════════════════════
    def _world_to_screen(self,wx,wy,W,H):
        """Convert normalized world coords to screen coords with zoom/pan."""
        sx=(wx+self._pan_x)*self._zoom*W
        sy=(wy+self._pan_y)*self._zoom*H
        return int(sx),int(sy)

    def _screen_to_world(self,sx,sy,W,H):
        wx=sx/(self._zoom*W)-self._pan_x
        wy=sy/(self._zoom*H)-self._pan_y
        return wx,wy

    def _zoom_in(self):
        self._zoom=min(4.0,self._zoom*1.25); self._draw_map()
    def _zoom_out(self):
        self._zoom=max(0.5,self._zoom/1.25); self._draw_map()
    def _zoom_reset(self):
        self._zoom=1.0; self._pan_x=0.0; self._pan_y=0.0; self._draw_map()
    def _toggle_territories(self):
        self._show_territories=self.terr_var.get(); self._draw_map()
    def _pan_start(self,event): self._pan_last=(event.x,event.y)
    def _pan_move(self,event):
        if self._pan_last:
            W=self.map_canvas.winfo_width() or 736; H=self.map_canvas.winfo_height() or 398
            dx=(event.x-self._pan_last[0])/(self._zoom*W)
            dy=(event.y-self._pan_last[1])/(self._zoom*H)
            self._pan_x+=dx; self._pan_y+=dy
            self._pan_last=(event.x,event.y); self._draw_map()

    def _draw_map(self):
        c=self.map_canvas; c.delete("all")
        W=c.winfo_width() or 736; H=c.winfo_height() or 398
        s=self.state; z=self._zoom

        def ws(wx,wy): return self._world_to_screen(wx,wy,W,H)

        # ═══════════════════════════════════════════════════════════════
        #  CARTOGRAPHIC CANVAS — Aged 1800s expedition map aesthetic
        #  Parchment base · sepia ink · watercolor washes · hatch terrain
        # ═══════════════════════════════════════════════════════════════

        # ── 1. Parchment base ─────────────────────────────────────────
        # Warm aged linen / parchment ground colour
        PARCH_BASE  = "#e8d8a8"
        PARCH_DARK  = "#c8b878"
        PARCH_EDGE  = "#b89858"
        INK         = "#3a2808"
        INK_LIGHT   = "#6a4820"
        INK_FAINT   = "#9a7848"
        WATER_WASH  = "#b8c8d8"   # pale blue watercolour wash
        WATER_DEEP  = "#8898a8"
        LAND_WASH   = "#c8b878"   # raw-umber land wash
        LAND_HATCH  = "#a89858"
        MTN_INK     = "#5a3818"
        RIVER_INK   = "#6888a8"
        PATH_INK    = "#883010"
        RED_INK     = "#8a2010"

        c.create_rectangle(0,0,W,H,fill=PARCH_BASE,outline="")

        # Linen texture — subtle diagonal hatching
        for i in range(0,W+H,18):
            c.create_line(i,0,max(0,i-H),min(H,i),
                          fill=PARCH_DARK,width=1,stipple="gray12" if i%36==0 else "")
        for i in range(-H,W,18):
            c.create_line(max(0,i),0,min(W,i+H),min(H,H),
                          fill=PARCH_DARK,width=1,stipple="gray12" if i%36==0 else "")

        # Aged vignette edges — darker parchment toward borders
        for vi in range(20):
            t2=vi/20; alpha=int(t2*t2*80)
            shade_r=max(0,0xe8-alpha*2); shade_g=max(0,0xd8-alpha*2); shade_b=max(0,0xa8-alpha*3)
            c.create_rectangle(vi*4,vi*4,W-vi*4,H-vi*4,
                               outline=f"#{shade_r:02x}{shade_g:02x}{shade_b:02x}",width=4)

        # ── 2. Lat/lon grid lines ──────────────────────────────────────
        # 5-degree grid across the territory
        for gx in range(0,W,max(20,int(W//10))):
            c.create_line(gx,0,gx,H,fill=INK_FAINT,width=1,dash=(2,6))
        for gy in range(0,H,max(20,int(H//8))):
            c.create_line(0,gy,W,gy,fill=INK_FAINT,width=1,dash=(2,6))

        # ── 3. Water — pale blue wash ──────────────────────────────────
        # Ocean / Gulf areas (outside land polygon)
        # Fill entire canvas with water wash first, land painted over
        c.create_rectangle(0,0,W,H,fill=WATER_WASH,outline="")

        # Water texture — fine parallel lines
        for wi in range(0,H,6):
            c.create_line(0,wi,W,wi,fill=WATER_DEEP,width=1,
                          dash=(int(4+random.Random(wi).random()*6),
                                int(3+random.Random(wi+1).random()*4)))

        # ── 4. Territory land polygons ────────────────────────────────
        if self._show_territories:
            TERR_WASHES = {
                "Illinois":  "#d4c888","Missouri":  "#ccc080","Iowa":     "#c8bc78",
                "Nebraska":  "#c4b870","Kansas":    "#c0b468","Dakota":   "#bcb068",
                "Montana":   "#b8ac60","Idaho":     "#b4a858","Oregon":   "#b0a450",
                "Washington":"#b4a858",
            }
            for terr in TERRITORIES:
                poly=terr["poly"]
                screen_pts=[]
                for pi in range(0,len(poly),2):
                    sx2,sy2=ws(poly[pi],poly[pi+1]); screen_pts.extend([sx2,sy2])
                if len(screen_pts)>=6:
                    wash=TERR_WASHES.get(terr["name"],LAND_WASH)
                    # Land fill
                    c.create_polygon(screen_pts,fill=wash,outline="")
                    # Territory border — hand-drawn ink line style
                    c.create_polygon(screen_pts,fill="",outline=INK_LIGHT,width=max(1,int(z)))
                    # Inner hatch for land texture (every other territory)
                    if TERRITORIES.index(terr)%2==0:
                        c.create_polygon(screen_pts,fill="",outline=LAND_HATCH,
                                         width=1,dash=(3,5),stipple="gray25")
                # Territory name — serif, italic, ink
                if z>=0.7:
                    lx,ly=ws(terr["label_x"],terr["label_y"])
                    # Drop shadow for legibility
                    c.create_text(lx+1,ly+1,text=terr["name"].upper(),
                                  font=('Georgia',max(6,int(8*z)),'italic'),
                                  fill=PARCH_BASE,anchor="center")
                    c.create_text(lx,ly,text=terr["name"].upper(),
                                  font=('Georgia',max(6,int(8*z)),'italic'),
                                  fill=INK_LIGHT,anchor="center")
        else:
            # Single land mass
            lp=[ws(0.06,0.10),ws(0.20,0.08),ws(0.45,0.06),ws(0.68,0.08),ws(0.92,0.10),
                ws(0.92,0.90),ws(0.68,0.90),ws(0.20,0.90),ws(0.06,0.90),ws(0.02,0.50)]
            flat=[v for pair in lp for v in pair]
            c.create_polygon(flat,fill=LAND_WASH,outline=INK_LIGHT,width=2,smooth=True)

        # ── 5. Rocky Mountains — hand-drawn hachure style ─────────────
        # Series of small ink chevrons / hatch marks — classic cartographic mountains
        ridge=[
            (0.13,0.48),(0.14,0.40),(0.15,0.34),(0.16,0.28),(0.17,0.22),
            (0.18,0.26),(0.19,0.20),(0.20,0.24),(0.21,0.17),(0.22,0.21),
            (0.23,0.26),(0.24,0.30),(0.25,0.36),(0.26,0.42),(0.26,0.50),
        ]
        # Draw individual mountain symbols along the ridge
        for ri,(mx,my) in enumerate(ridge[::2]):
            sx2,sy2=ws(mx,my)
            sz=max(6,int(10*z))
            # Classic cartographic mountain: two overlapping triangles
            c.create_polygon(sx2-sz,sy2+sz//2,sx2,sy2-sz,sx2+sz,sy2+sz//2,
                             fill=PARCH_BASE,outline=MTN_INK,width=max(1,int(z)))
            c.create_polygon(sx2-sz//2,sy2+sz//2,sx2+sz//3,sy2-sz//3,sx2+sz*1.2,sy2+sz//2,
                             fill=PARCH_BASE,outline=MTN_INK,width=max(1,int(z)),dash=(2,1))
            # Snow cap dot
            c.create_oval(sx2-2,sy2-sz-2,sx2+2,sy2-sz+2,fill=PARCH_BASE,outline=MTN_INK)

        # Label
        if z>=0.8:
            rx,ry=ws(0.20,0.38)
            c.create_text(rx+1,ry+1,text="ROCKY MOUNTAINS",
                          font=('Georgia',max(5,int(7*z)),'italic'),fill=PARCH_BASE,anchor="center")
            c.create_text(rx,ry,text="ROCKY MOUNTAINS",
                          font=('Georgia',max(5,int(7*z)),'italic'),fill=MTN_INK,anchor="center")

        # ── 6. Pacific NW — stylised forest symbols ────────────────────
        for tx,ty in [(0.07,0.25),(0.09,0.28),(0.11,0.26),(0.06,0.30),(0.08,0.32)]:
            sx2,sy2=ws(tx,ty); sz2=max(4,int(7*z))
            # Classic map tree: triangle on stick
            c.create_line(sx2,sy2,sx2,sy2+int(sz2*1.4),fill=INK_LIGHT,width=max(1,int(z)))
            c.create_polygon(sx2-sz2,sy2,sx2,sy2-int(sz2*1.6),sx2+sz2,sy2,
                             fill=LAND_WASH,outline=INK_LIGHT,width=max(1,int(z)))

        # ── 7. Missouri River — double-line with blue ink wash ─────────
        rp=[]
        for wp in WAYPOINTS: sx2,sy2=ws(wp["x"],wp["y"]); rp.extend([sx2,sy2])
        rw=max(2,int(4*z))
        # Outer blue wash
        c.create_line(rp,fill=WATER_WASH,width=rw+6,smooth=True,capstyle="round",joinstyle="round")
        # Left bank ink
        c.create_line(rp,fill=RIVER_INK,width=rw+2,smooth=True,capstyle="round")
        # Right bank ink (offset slightly)
        c.create_line(rp,fill=RIVER_INK,width=rw-1,smooth=True,capstyle="round",dash=(6,2))
        # Centre channel line
        c.create_line(rp,fill=WATER_DEEP,width=max(1,rw-2),smooth=True,capstyle="round")

        # River name label
        if z>=0.8:
            mid=len(WAYPOINTS)//2; wp_mid=WAYPOINTS[mid]
            rlx,rly=ws(wp_mid["x"]-0.04,wp_mid["y"]-0.04)
            c.create_text(rlx+1,rly+1,text="Missouri R.",
                          font=('Georgia',max(6,int(8*z)),'italic'),fill=PARCH_BASE,anchor="w")
            c.create_text(rlx,rly,text="Missouri R.",
                          font=('Georgia',max(6,int(8*z)),'italic'),fill=RIVER_INK,anchor="w")

        # ── 8. Expedition route — red ink dotted line ──────────────────
        for i in range(s.current_wp):
            sx1,sy1=ws(WAYPOINTS[i]["x"],WAYPOINTS[i]["y"])
            sx2,sy2=ws(WAYPOINTS[i+1]["x"],WAYPOINTS[i+1]["y"])
            pw=max(2,int(3*z))
            # Thick red ink dashed route
            c.create_line(sx1,sy1,sx2,sy2,fill=PATH_INK,width=pw+1,
                          smooth=True,dash=(int(6*z),int(4*z)),capstyle="round")

        # ── 9. Waypoints — hand-drawn fort / camp symbols ─────────────
        for i,wp in enumerate(WAYPOINTS):
            sx2,sy2=ws(wp["x"],wp["y"])
            is_cur=i==s.current_wp; is_vis=i<s.current_wp; is_hov=i==self._hover_wp
            sz=max(5,int(8*z))

            if is_cur:
                # Current position: filled red circle with cross (surveyor mark)
                c.create_oval(sx2-sz-2,sy2-sz-2,sx2+sz+2,sy2+sz+2,
                              fill=PARCH_BASE,outline=RED_INK,width=2)
                c.create_oval(sx2-sz,sy2-sz,sx2+sz,sy2+sz,
                              fill=RED_INK,outline="")
                c.create_line(sx2-sz-6,sy2,sx2+sz+6,sy2,fill=RED_INK,width=2)
                c.create_line(sx2,sy2-sz-6,sx2,sy2+sz+6,fill=RED_INK,width=2)
            elif is_vis:
                # Visited: small solid ink circle
                c.create_oval(sx2-sz+1,sy2-sz+1,sx2+sz-1,sy2+sz-1,
                              fill=INK,outline="")
            else:
                # Future: open circle
                col2=INK if is_hov else INK_FAINT
                c.create_oval(sx2-sz+1,sy2-sz+1,sx2+sz-1,sy2+sz-1,
                              fill=PARCH_BASE,outline=col2,width=max(1,int(z)))

            # Labels — cartographic serif style
            ly2=sy2-int(14*z) if sy2>50 else sy2+int(16*z)
            if is_hov or is_cur or z>=1.8:
                # Full cartouche label box
                lw2=max(55,len(wp["name"])*int(5*z)+10)
                c.create_rectangle(sx2-lw2//2,ly2-8,sx2+lw2//2,ly2+4,
                                   fill=PARCH_BASE,outline=INK_LIGHT,width=1)
                c.create_text(sx2,ly2-2,text=wp["name"],
                              font=('Georgia',max(6,int(7*z)),'bold'),
                              fill=INK,anchor="center")
                if z>=1.4 or is_cur:
                    c.create_text(sx2,ly2+8,text=wp["desc"][:24],
                                  font=('Georgia',max(5,int(6*z)),'italic'),
                                  fill=INK_FAINT,anchor="center")
            elif z>=0.7:
                c.create_text(sx2+1,ly2+1,text=wp["name"],
                              font=('Georgia',max(5,int(6*z)),),
                              fill=PARCH_BASE,anchor="center")
                c.create_text(sx2,ly2,text=wp["name"],
                              font=('Georgia',max(5,int(6*z)),),
                              fill=INK if is_vis else INK_FAINT,anchor="center")

        # ── 10. Ornate compass rose ────────────────────────────────────
        cr2=max(32,int(44*min(z,1.5)))
        cx3=W-cr2-14; cy3=H-cr2-14
        # Outer decorative ring
        c.create_oval(cx3-cr2-4,cy3-cr2-4,cx3+cr2+4,cy3+cr2+4,
                      fill=PARCH_BASE,outline=INK_LIGHT,width=2)
        c.create_oval(cx3-cr2,cy3-cr2,cx3+cr2,cy3+cr2,
                      fill=PARCH_DARK,outline=INK,width=1)
        # 16-point wind rose
        for pt in range(16):
            ang2=pt*22.5
            length2=(cr2-4) if pt%4==0 else (cr2-8) if pt%2==0 else (cr2-12)
            x2=cx3+math.sin(math.radians(ang2))*length2
            y2=cy3-math.cos(math.radians(ang2))*length2
            c.create_line(cx3,cy3,x2,y2,fill=INK,width=1 if pt%4!=0 else 2)
        # Cardinal points — classic fleur-de-lis N
        for lbl2,ang3 in [("N",0),("E",90),("S",180),("W",270)]:
            lx3=cx3+math.sin(math.radians(ang3))*(cr2-10)
            ly3=cy3-math.cos(math.radians(ang3))*(cr2-10)
            c.create_text(lx3+1,ly3+1,text=lbl2,
                          font=('Georgia',max(7,int(9*z)),'bold'),fill=PARCH_BASE,anchor="center")
            c.create_text(lx3,ly3,text=lbl2,
                          font=('Georgia',max(7,int(9*z)),'bold'),
                          fill=RED_INK if lbl2=="N" else INK,anchor="center")
        # Centre dot
        c.create_oval(cx3-3,cy3-3,cx3+3,cy3+3,fill=INK,outline="")

        # ── 11. Cartouche title ────────────────────────────────────────
        # Ornate title box — bottom left
        cart_x=6; cart_y=H-80; cart_w=180; cart_h=70
        c.create_rectangle(cart_x,cart_y,cart_x+cart_w,cart_y+cart_h,
                           fill=PARCH_DARK,outline=INK,width=2)
        # Double-line border
        c.create_rectangle(cart_x+4,cart_y+4,cart_x+cart_w-4,cart_y+cart_h-4,
                           fill="",outline=INK_LIGHT,width=1)
        # Corner flourishes
        for cx4,cy4,dx2,dy2 in [(cart_x+4,cart_y+4,8,8),(cart_x+cart_w-4,cart_y+4,-8,8),
                                  (cart_x+4,cart_y+cart_h-4,8,-8),(cart_x+cart_w-4,cart_y+cart_h-4,-8,-8)]:
            c.create_line(cx4,cy4,cx4+dx2,cy4,fill=INK,width=2)
            c.create_line(cx4,cy4,cx4,cy4+dy2,fill=INK,width=2)
        c.create_text(cart_x+cart_w//2,cart_y+14,
                      text="MAP of the",font=('Georgia',max(7,int(8*z)),'italic'),fill=INK_LIGHT,anchor="center")
        c.create_text(cart_x+cart_w//2,cart_y+28,
                      text="LOUISIANA TERRITORY",font=('Georgia',max(8,int(9*z)),'bold'),fill=INK,anchor="center")
        c.create_text(cart_x+cart_w//2,cart_y+42,
                      text="Explored by Capts LEWIS & CLARK",font=('Georgia',max(5,int(6*z)),'italic'),fill=INK_FAINT,anchor="center")
        c.create_text(cart_x+cart_w//2,cart_y+54,
                      text="By order of the President  MDCCCIV",font=('Georgia',max(5,int(6*z)),'italic'),fill=INK_FAINT,anchor="center")
        c.create_text(cart_x+cart_w//2,cart_y+66,
                      text=f"Season: {s.season}   Anno Domini {s.date_str}",
                      font=('Georgia',max(5,int(6*z)),),fill=INK_LIGHT,anchor="center")

        # ── 12. Legend ────────────────────────────────────────────────
        leg_x=6; leg_y=6; leg_w=160; leg_h=78
        c.create_rectangle(leg_x,leg_y,leg_x+leg_w,leg_y+leg_h,fill=PARCH_DARK,outline=INK,width=2)
        c.create_rectangle(leg_x+3,leg_y+3,leg_x+leg_w-3,leg_y+leg_h-3,fill="",outline=INK_LIGHT,width=1)
        c.create_text(leg_x+leg_w//2,leg_y+11,text="REFERENCES",
                      font=('Georgia',max(6,int(7*z)),'bold italic'),fill=INK,anchor="center")
        for dy3,fill3,txt3 in [
            (24,RED_INK,"Present Camp"),
            (38,INK,"Camp Visited"),
            (52,INK_FAINT,"Camp Ahead"),
            (66,PATH_INK,"Route of Expedition"),
        ]:
            if fill3==PATH_INK:
                c.create_line(leg_x+10,leg_y+dy3,leg_x+26,leg_y+dy3,
                              fill=PATH_INK,width=2,dash=(4,2))
            else:
                c.create_oval(leg_x+13,leg_y+dy3-5,leg_x+23,leg_y+dy3+5,
                              fill=fill3,outline=INK)
            c.create_text(leg_x+30,leg_y+dy3,text=txt3,
                          font=('Georgia',max(6,int(7*z)),),fill=INK,anchor="w")

        # ── 13. Scale bar ──────────────────────────────────────────────
        scale_x=W//2-60; scale_y=H-18
        c.create_line(scale_x,scale_y,scale_x+120,scale_y,fill=INK,width=2)
        c.create_line(scale_x,scale_y-5,scale_x,scale_y+5,fill=INK,width=2)
        c.create_line(scale_x+60,scale_y-3,scale_x+60,scale_y+3,fill=INK,width=1)
        c.create_line(scale_x+120,scale_y-5,scale_x+120,scale_y+5,fill=INK,width=2)
        c.create_text(scale_x+60,scale_y-10,text="SCALE OF MILES",
                      font=('Georgia',max(5,int(6*z)),'italic'),fill=INK_FAINT,anchor="center")
        c.create_text(scale_x,scale_y+8,text="0",
                      font=('Georgia',max(5,int(6*z)),),fill=INK_FAINT,anchor="center")
        c.create_text(scale_x+120,scale_y+8,text="500",
                      font=('Georgia',max(5,int(6*z)),),fill=INK_FAINT,anchor="center")

        # ── 14. Zoom badge ─────────────────────────────────────────────
        if z!=1.0:
            c.create_text(W-8,6,text=f"×{z:.1f}",
                          font=('Georgia',max(6,int(7*z)),),fill=INK_FAINT,anchor="ne")

        # ── 15. Particles (embers at current position) ─────────────────
        for p in self._particles:
            col3=p.color()
            c.create_oval(p.x-p.size,p.y-p.size,p.x+p.size,p.y+p.size,fill=col3,outline="")

    def _particle_tick(self):
        if not self.state or not hasattr(self,'map_canvas') or not self.map_canvas.winfo_exists():
            return
        W=self.map_canvas.winfo_width() or 736; H=self.map_canvas.winfo_height() or 398
        wp=WAYPOINTS[self.state.current_wp]
        sx,sy=self._world_to_screen(wp["x"],wp["y"],W,H)
        if random.random()<0.38: self._particles.append(Particle(sx,sy))
        if random.random()<0.12: self._particles.append(Particle(sx,sy))
        self._particles=[p for p in self._particles if p.update()]
        self._draw_map()
        self._part_anim_id=self.root.after(66,self._particle_tick)  # ~15fps is plenty for particles

    def _map_hover(self,event):
        W=self.map_canvas.winfo_width() or 736; H=self.map_canvas.winfo_height() or 398
        for i,wp in enumerate(WAYPOINTS):
            sx,sy=self._world_to_screen(wp["x"],wp["y"],W,H)
            r=max(12,int(12*self._zoom))
            if abs(event.x-sx)<r and abs(event.y-sy)<r:
                if self._hover_wp!=i: self._hover_wp=i; self._draw_map()
                return
        if self._hover_wp is not None: self._hover_wp=None; self._draw_map()

    def _map_unhover(self):
        if self._hover_wp is not None: self._hover_wp=None; self._draw_map()

    def _map_click(self,event):
        """Click a waypoint on the map to open its detail popup."""
        W=self.map_canvas.winfo_width() or 736; H=self.map_canvas.winfo_height() or 398
        for i,wp in enumerate(WAYPOINTS):
            sx,sy=self._world_to_screen(wp["x"],wp["y"],W,H)
            r=max(14,int(14*self._zoom))
            if abs(event.x-sx)<r and abs(event.y-sy)<r:
                self._show_waypoint_popup(i); return

    def _show_waypoint_popup(self,wp_idx):
        wp=WAYPOINTS[wp_idx]; s=self.state
        win=tk.Toplevel(self.root); win.title(wp["name"])
        win.configure(bg=C["bg"]); win.geometry("420x340")
        win.resizable(False,False); win.grab_set()

        # Header strip
        hdr=tk.Frame(win,bg=C["bg2"]); hdr.pack(fill="x")
        tk.Frame(hdr,bg=C["gold"],height=2).pack(fill="x",side="top")
        status = "CURRENT LOCATION" if wp_idx==s.current_wp else \
                 "VISITED" if wp_idx<s.current_wp else "AHEAD"
        status_col = C["red2"] if wp_idx==s.current_wp else C["gold"] if wp_idx<s.current_wp else C["dim"]
        tk.Label(hdr,text=status,font=self.F["tiny"],bg=C["bg2"],fg=status_col,pady=3).pack(side="right",padx=10)
        tk.Label(hdr,text=wp["name"],font=self.F["header"],bg=C["bg2"],fg=C["parch"],pady=8).pack(side="left",padx=12)

        # Mini illustrated scene canvas
        scene_c=tk.Canvas(win,width=420,height=130,bg=C["water"],highlightthickness=0)
        scene_c.pack()
        self._draw_waypoint_scene(scene_c,wp,wp_idx,s)

        # Info panel
        info=tk.Frame(win,bg=C["card"],padx=16,pady=10); info.pack(fill="x",padx=0)
        tk.Label(info,text=wp["desc"],font=self.F["body"],bg=C["card"],fg=C["parch2"],
                 wraplength=370,justify="left").pack(anchor="w",pady=(0,6))

        # Stats grid
        grid=tk.Frame(info,bg=C["card"]); grid.pack(fill="x")
        cols=[("Region",wp["region"],C["parch2"]),
              ("Season",get_season(wp["month"]),SC[get_season(wp["month"])]),
              ("Year",str(wp["year"]),C["parch3"])]
        if wp_idx<=s.current_wp:
            tribe_key=TRIBE_AT_WAYPOINT.get(wp_idx)
            if tribe_key:
                rel=s.tribe_relations.get(tribe_key,50)
                rt="Friendly" if rel>=60 else "Neutral" if rel>=40 else "Tense"
                cols.append((TRIBES[tribe_key]["name"],f"{rt} ({rel})",
                             C["green2"] if rel>=60 else C["gold"] if rel>=40 else C["red2"]))
        for col_i,(label,val,fg) in enumerate(cols):
            cf=tk.Frame(grid,bg=C["card2"],padx=8,pady=4); cf.grid(row=0,column=col_i,padx=3,sticky="ew")
            tk.Label(cf,text=label.upper(),font=self.F["tiny"],bg=C["card2"],fg=C["dim2"]).pack(anchor="w")
            tk.Label(cf,text=val,font=self.F["subhead"],bg=C["card2"],fg=fg).pack(anchor="w")

        tk.Button(win,text="Close",font=self.F["btn"],bg=C["card2"],fg=C["parch2"],
                  activebackground=C["gold"],activeforeground=C["ink"],
                  relief="flat",cursor="hand2",pady=5,command=win.destroy).pack(pady=8)

    def _draw_waypoint_scene(self,c,wp,wp_idx,s):
        """Draw a small illustrated thumbnail scene for each waypoint."""
        W=420; H=130
        region=wp["region"].lower()

        # Sky
        sky_col = {"winter":"#0a1020","autumn":"#1a1008","spring":"#0e1a10","summer":"#100e06"}.get(get_season(wp["month"]).lower(),"#0e1208")
        c.create_rectangle(0,0,W,H,fill=sky_col,outline="")

        # Stars for winter/night
        if get_season(wp["month"])=="Winter":
            rng=random.Random(wp_idx*7)
            for _ in range(30):
                c.create_oval(rng.randint(0,W)-1,rng.randint(0,H//2)-1,
                              rng.randint(0,W)+1,rng.randint(0,H//2)+1,fill="#8090a0",outline="")

        # Terrain based on region
        if "montana" in region or "idaho" in region:
            # Mountains
            for mi,(mxf,myf,mw) in enumerate([(0.3,0.35,80),(0.5,0.25,100),(0.7,0.35,70),(0.85,0.40,60)]):
                mx2,my2=mxf*W,myf*H
                c.create_polygon(mx2-mw,H,mx2,my2,mx2+mw,H,fill=C["mtn"],outline=C["mtn2"],width=1)
                c.create_polygon(mx2-14,my2+16,mx2,my2,mx2+14,my2+16,fill=C["snow"],outline="")
        elif "oregon" in region or "washington" in region:
            # Pacific NW dense forest
            for tx in range(0,W,24):
                th = 30+random.Random(tx).randint(0,20)
                c.create_line(tx+12,H,tx+12,H-th,fill=C["land2"],width=4)
                c.create_polygon(tx,H-th,tx+12,H-th-20,tx+24,H-th,fill=C["land3"],outline="")
        elif "dakota" in region:
            # Wide open plains
            c.create_rectangle(0,H//2,W,H,fill=C["land"],outline="")
            for hx in range(0,W+8,8):
                hy=H//2+int(math.sin(hx*0.04)*6)
                c.create_line(hx,hy,hx,hy+4,fill=C["land2"],width=1)
        else:
            # Rolling prairie/river
            for hi,(base,col,amp) in enumerate([(0.52,C["land"],8),(0.65,C["land2"],5)]):
                pts=[0,H]
                for hx in range(0,W+4,4):
                    hy=H*base+math.sin(hx*0.015+hi)*amp; pts.extend([hx,int(hy)])
                pts.extend([W,H]); c.create_polygon(pts,fill=col,outline="")

        # River band
        rv_y=int(H*0.56)
        c.create_rectangle(0,rv_y,W,rv_y+18,fill=C["water2"],outline="")
        for ri in range(3):
            c.create_line(random.Random(ri*10).randint(0,W//2),rv_y+ri*5,
                          random.Random(ri*11).randint(W//2,W),rv_y+ri*5+4,
                          fill=C["water3"],width=1,smooth=True)

        # Status indicator
        if wp_idx==s.current_wp:
            # Current camp fire
            c.create_oval(W*0.18-20,H*0.50-8,W*0.18+20,H*0.50+6,fill="#1a0e04",outline="")
            c.create_oval(W*0.18-4,H*0.50-14,W*0.18+4,H*0.50,fill="#d07010",outline="")
            c.create_text(W//2,H-16,text=f"★  Corps camped here  ·  {s.date_str}",
                          font=self.F["map_lbl"],fill=C["gold"],anchor="center")
        elif wp_idx<s.current_wp:
            c.create_text(W//2,H-16,text=f"Visited  ·  {wp['month']}/{wp['year']}",
                          font=self.F["map_lbl"],fill=C["parch3"],anchor="center")
        else:
            c.create_text(W//2,H-16,text="Not yet reached",
                          font=self.F["map_lbl"],fill=C["dim2"],anchor="center")

    # ══════════════════════════════════════════════════════════════════════════
    #  REFRESH
    # ══════════════════════════════════════════════════════════════════════════
    def _refresh(self):
        self._draw_map(); self._update_stats(); self._update_journal()
        self._update_objectives(); self._update_chars(); self._update_season_label()
        self._check_objectives()

    def _update_season_label(self):
        s=self.state; self.season_lbl.configure(
            text=f"{s.season}  ·  {s.date_str}  ·  Waypoint {s.current_wp+1}/{len(WAYPOINTS)}",fg=SC[s.season])

    def _update_stats(self):
        for key,(track,fill,vl,col,bw) in self.stat_bars.items():
            val=getattr(self.state,key); fw=max(2,int((val/100)*(bw-2))); fill.configure(width=fw)
            uc=C["red2"] if val<25 else C["gold"] if val<50 else col
            fill.configure(bg=uc); vl.configure(text=str(val),fg=uc)

    def _update_journal(self):
        jt=self.journal_text; jt.configure(state="normal"); jt.delete("1.0","end")
        jt.tag_configure("date",     foreground=C["gold"],    font=self.F["mono_sm"])
        jt.tag_configure("text",     foreground=C["parch2"],  font=self.F["mono"])
        jt.tag_configure("obj",      foreground=C["green2"],  font=self.F["mono"])
        jt.tag_configure("bad",      foreground=C["red2"],    font=self.F["mono"])
        jt.tag_configure("hunt",     foreground=C["green"],   font=self.F["mono"])
        jt.tag_configure("trade",    foreground=C["teal2"],   font=self.F["mono"])
        jt.tag_configure("camp",     foreground=C["blue2"],   font=self.F["mono"])
        jt.tag_configure("discover", foreground=C["gold2"],   font=self.F["mono"])

        TAG_RULES = [
            ("obj",      ["OBJECTIVE COMPLETE","EXPEDITION COMPLETE"]),
            ("bad",      ["EXPEDITION FAILED","DISASTER","starved","Too many men"]),
            ("hunt",     ["hunt","Hunt","Drouillard","elk","buffalo","game"]),
            ("trade",    ["trade","Trade","council","Council","tribe","Nation","Medal","gift"]),
            ("camp",     ["made camp","Camp event","Cruzatte","fiddle","meteor","Seaman","wolves"]),
            ("discover", ["Discovery","discovery","species","Vista","prairie dog","mound","astronomical"]),
        ]

        def pick_tag(text):
            for tag,keywords in TAG_RULES:
                if any(kw in text for kw in keywords): return tag
            return "text"

        for entry in reversed(self.state.journal):
            if entry.startswith("["):
                end=entry.find("]")
                jt.insert("end", entry[:end+1]+"\n", "date")
                rest=entry[end+1:].strip()
                tag=pick_tag(rest)
                jt.insert("end", textwrap.fill(rest,42)+"\n\n", tag)
            else:
                jt.insert("end", textwrap.fill(entry,42)+"\n\n", "text")

        jt.configure(state="disabled")
        jt.see("1.0")  # scroll to newest (top, since we insert reversed)

    def _update_objectives(self):
        for w in self.obj_frame.winfo_children(): w.destroy()

        # Progress bar — waypoints completed
        s=self.state
        prog_frame=tk.Frame(self.obj_frame,bg=C["bg3"],padx=6,pady=4); prog_frame.pack(fill="x",pady=(0,3))
        total_wp=len(WAYPOINTS)-1; done_wp=s.current_wp
        prog_pct=done_wp/total_wp if total_wp else 0
        tk.Label(prog_frame,text="EXPEDITION PROGRESS",font=self.F["tiny"],bg=C["bg3"],fg=C["dim2"]).pack(anchor="w")
        bar_row=tk.Frame(prog_frame,bg=C["bg3"]); bar_row.pack(fill="x")
        bar_bg=tk.Frame(bar_row,bg=C["bg2"],height=6); bar_bg.pack(side="left",fill="x",expand=True,pady=2)
        bar_bg.update_idletasks()
        fill_w=max(2,int((bar_bg.winfo_width() or 200)*prog_pct))
        prog_col=C["green2"] if prog_pct>0.66 else C["gold"] if prog_pct>0.33 else C["blue2"]
        tk.Frame(bar_bg,bg=prog_col,height=6,width=fill_w).place(x=0,y=0)
        tk.Label(bar_row,text=f"{done_wp}/{total_wp}",font=self.F["tiny"],bg=C["bg3"],fg=C["parch3"],padx=4).pack(side="left")

        # Objective rows
        checks=["Winter at Fort Mandan","Cross the Continental Divide","Reach Fort Clatsop",
                 f"Peaceful relations: 3 tribes ({s.peaceful_tribes}/3)",
                 "Health > 40 at journey's end",f"Discoveries: 5 total ({s.discoveries}/5)"]
        for i,text in enumerate(checks):
            done=i in s.completed_objectives
            row=tk.Frame(self.obj_frame,bg=C["card"] if done else C["panel"]); row.pack(fill="x",pady=1)
            # Checkbox-style indicator
            check_c=tk.Canvas(row,width=14,height=14,bg=row["bg"],highlightthickness=0)
            check_c.pack(side="left",padx=(5,3),pady=3)
            if done:
                check_c.create_rectangle(1,1,13,13,fill=C["green2"],outline=C["green"])
                check_c.create_line(3,7,6,11,11,3,fill=C["ink"],width=2)
            else:
                check_c.create_rectangle(1,1,13,13,fill="",outline=C["dim"])
            tk.Label(row,text=text,font=self.F["tiny"],bg=row["bg"],
                     fg=C["parch"] if done else C["parch3"],anchor="w").pack(side="left",fill="x",pady=2)

    def _update_chars(self):
        PORTRAITS = {
            "york":       ("#d08030","◆","#2a1a0a"),
            "drouillard": ("#a87840","⬟","#1a1408"),
            "sacagawea":  ("#c09060","★","#2a1808"),
        }
        for key,(fr,pc,nl,tl,sl) in self.char_widgets.items():
            active=self.state.characters[key]["active"]
            bg=C["card"] if active else C["panel"]
            fr.configure(bg=bg); nl.configure(bg=bg,fg=C["parch"] if active else C["dim2"])
            tl.configure(bg=bg)
            sl.configure(bg=bg,fg=C["green2"] if active else C["dim"],
                         text="● Active" if active else f"Joins: {WAYPOINTS[SPECIAL_CHARACTERS[key]['joined_at']]['name']}")
            # Redraw portrait
            skin_col,sym,cloth_col=PORTRAITS[key]
            pc.configure(bg=C["card2"] if active else C["bg2"])
            pc.delete("all")
            self._draw_portrait(pc,48,pc.winfo_height() or 90,skin_col,cloth_col,sym,active)

    def _check_objectives(self):
        s=self.state; changed=False
        if s.current_wp>=4 and 0 not in s.completed_objectives:
            s.completed_objectives.append(0); s.add_journal("OBJECTIVE COMPLETE: Wintered at Fort Mandan.")
            s.characters["sacagawea"]["active"]=True; s.add_journal(SPECIAL_CHARACTERS["sacagawea"]["journal_intro"]); changed=True
        if s.current_wp>=7 and 1 not in s.completed_objectives:
            s.completed_objectives.append(1); s.add_journal("OBJECTIVE COMPLETE: Crossed the Continental Divide!"); changed=True
        if s.current_wp>=9 and 2 not in s.completed_objectives:
            s.completed_objectives.append(2); s.add_journal("OBJECTIVE COMPLETE: We have reached the Pacific Ocean!"); changed=True
        if s.peaceful_tribes>=3 and 3 not in s.completed_objectives:
            s.completed_objectives.append(3); s.add_journal("OBJECTIVE COMPLETE: Peaceful relations established."); changed=True
        if s.discoveries>=5 and 5 not in s.completed_objectives:
            s.completed_objectives.append(5); s.add_journal("OBJECTIVE COMPLETE: Five discoveries documented."); changed=True
        if changed: self._update_objectives(); self._update_chars(); SFX["objective"]()

    def _active_chars(self): return {k:v["active"] for k,v in self.state.characters.items()}

    # ══════════════════════════════════════════════════════════════════════════
    #  ACTION PANEL HELPERS
    # ══════════════════════════════════════════════════════════════════════════
    def _clear_actions(self):
        for w in self.action_frame.winfo_children(): w.destroy()

    def _albl(self,text,fg=None,font=None,wrap=352):
        tk.Label(self.action_frame,text=text,font=font or self.F["small"],
                 bg=C["panel"],fg=fg or C["parch2"],wraplength=wrap,justify="left",anchor="w"
                 ).pack(fill="x",padx=4,pady=1)

    def _adiv(self):
        tk.Frame(self.action_frame,bg=C["border"],height=1).pack(fill="x",padx=4,pady=3)

    def _abtn(self,text,cmd,color=None,disabled=False,star=False,sub=None):
        color=color or C["gold"]
        pfx="★ " if star else ""
        fr=tk.Frame(self.action_frame,bg=C["card2"],cursor="hand2" if not disabled else "arrow")
        fr.pack(fill="x",padx=4,pady=2)
        lbl=tk.Label(fr,text=pfx+text,font=self.F["btn"],bg=C["card2"],
                     fg=C["dim"] if disabled else color,anchor="w",padx=8,pady=4)
        lbl.pack(fill="x")
        if sub:
            sub_lbl=tk.Label(fr,text=sub,font=self.F["tiny"],bg=C["card2"],fg=C["dim2"],anchor="w",padx=12)
            sub_lbl.pack(fill="x")
        if not disabled:
            def enter(e): fr.configure(bg=C["card"]); lbl.configure(bg=C["card"]); (sub_lbl.configure(bg=C["card"]) if sub else None)
            def leave(e): fr.configure(bg=C["card2"]); lbl.configure(bg=C["card2"]); (sub_lbl.configure(bg=C["card2"]) if sub else None)
            fr.bind("<Enter>",enter); lbl.bind("<Enter>",enter)
            fr.bind("<Leave>",leave); lbl.bind("<Leave>",leave)
            fr.bind("<Button-1>",lambda e:cmd()); lbl.bind("<Button-1>",lambda e:cmd())
            if sub: sub_lbl.bind("<Enter>",enter); sub_lbl.bind("<Leave>",leave); sub_lbl.bind("<Button-1>",lambda e:cmd())

    def _route_card(self,route,callback):
        effs=[]
        for k,v in [("Food",route["food"]),("Health",route["health"]),("Morale",route["morale"])]:
            if v: effs.append(f"{'+'if v>0 else ''}{v} {k}")
        risk_col={"low":C["green2"],"medium":C["gold"],"high":C["amber"],"very_high":C["red2"]}.get(route.get("risk","medium"),C["gold"])
        ec=C["green2"] if any(route[k]>0 for k in ["food","health","morale"]) else C["dim2"]

        card=tk.Frame(self.action_frame,bg=C["card"],cursor="hand2"); card.pack(fill="x",padx=4,pady=2)

        # Left: terrain thumbnail
        thumb=tk.Canvas(card,width=52,height=52,bg=C["bg2"],highlightthickness=0)
        thumb.pack(side="left",padx=(4,0),pady=4)
        self._draw_route_thumb(thumb,route.get("tag","river"),52,52)

        # Right: info
        right=tk.Frame(card,bg=C["card"]); right.pack(side="left",fill="both",expand=True,padx=6)

        top=tk.Frame(right,bg=C["card"]); top.pack(fill="x",pady=(4,0))
        route_icons={"river":"⛵ ","land":"🥾 ","mountain":"⛰ "}
        icon=route_icons.get(route.get("tag","river"),"▶ ")
        tk.Label(top,text=f"{icon}{route['name']}",font=self.F["subhead"],bg=C["card"],fg=C["gold"]).pack(side="left")
        risk_lbl=route.get("risk","").replace("_"," ").upper()
        tk.Label(top,text=risk_lbl,font=self.F["tiny"],bg=C["card"],fg=risk_col).pack(side="right",padx=4)
        tk.Label(top,text=f"{route.get('days',14)}d",font=self.F["tiny"],bg=C["card"],fg=C["dim2"]).pack(side="right")

        tk.Label(right,text=route["desc"],font=self.F["small"],bg=C["card"],fg=C["parch3"],
                 wraplength=280,justify="left",anchor="w").pack(fill="x",pady=(0,2))
        if effs:
            tk.Label(right,text="  ".join(effs),font=self.F["tiny"],bg=C["card"],fg=ec,anchor="w").pack(fill="x",pady=(0,4))

        def enter(e):
            for w in [card,right,top,thumb]+list(right.winfo_children())+list(top.winfo_children()):
                try: w.configure(bg=C["card2"])
                except: pass
        def leave(e):
            for w in [card,right,top]+list(right.winfo_children())+list(top.winfo_children()):
                try: w.configure(bg=C["card"])
                except: pass
            thumb.configure(bg=C["bg2"])
        def click(e): callback(route)
        for w in [card,right,top,thumb]+list(right.winfo_children())+list(top.winfo_children()):
            w.bind("<Enter>",enter); w.bind("<Leave>",leave); w.bind("<Button-1>",click)

    def _draw_route_thumb(self,c,tag,W,H):
        """Draw a small terrain thumbnail for a route card."""
        if tag=="river":
            c.create_rectangle(0,0,W,H,fill="#0e1a10",outline="")
            # Water band
            for ri in range(int(H*0.35),int(H*0.65)):
                sh=math.sin(ri*0.3)*0.3+0.6
                rr=int(0x0c+sh*0x14); gg=int(0x1e+sh*0x0e); bb=int(0x2a+sh*0x0c)
                c.create_line(0,ri,W,ri,fill=f"#{rr:02x}{gg:02x}{bb:02x}")
            # Banks
            pts_t=[0,H//2-10]+[x for x in range(0,W+3,3) for _ in ()]+[W,H//2-10]
            c.create_polygon(0,0,W,0,W,int(H*0.35),0,int(H*0.35),fill=C["land2"],outline="")
            c.create_polygon(0,int(H*0.65),W,int(H*0.65),W,H,0,H,fill=C["land2"],outline="")
            # Boat silhouette
            bx=W//2; by=H//2
            c.create_polygon(bx-14,by,bx-10,by-6,bx+14,by-6,bx+16,by,fill="#0a0e08",outline="")
            c.create_line(bx,by-6,bx,by-20,fill="#0e1208",width=2)
        elif tag=="land":
            c.create_rectangle(0,0,W,H,fill="#0e1608",outline="")
            # Prairie rolling hills
            for hi,(base,col) in enumerate([(0.4,C["land"]),(0.6,C["land2"]),(0.8,C["bg3"])]):
                pts=[0,H]
                for hx in range(0,W+3,3):
                    hy=H*base+math.sin(hx*0.15+hi)*5+math.sin(hx*0.04+hi)*3
                    pts.extend([hx,int(hy)])
                pts.extend([W,H]); c.create_polygon(pts,fill=col,outline="")
            # Walking figure
            fx,fy=W*0.55,H*0.42
            c.create_oval(fx-3,fy-12,fx+3,fy-6,fill=C["parch3"],outline="")
            c.create_rectangle(fx-4,fy-6,fx+4,fy+6,fill=C["dim"],outline="")
        elif tag=="mountain":
            c.create_rectangle(0,0,W,H,fill="#0a0c10",outline="")
            # Mountain peaks
            for mx2,my2,mw2 in [(W*0.3,H*0.35,18),(W*0.55,H*0.22,22),(W*0.78,H*0.38,16)]:
                c.create_polygon(mx2-mw2,H,mx2,my2,mx2+mw2,H,fill=C["mtn"],outline=C["mtn2"],width=1)
                c.create_polygon(mx2-6,my2+7,mx2,my2,mx2+6,my2+7,fill=C["snow"],outline="")

    # ══════════════════════════════════════════════════════════════════════════
    #  RPG TRAVEL FLOW
    # ══════════════════════════════════════════════════════════════════════════
    def _show_travel_actions(self):
        self._clear_actions()
        s=self.state; wp=s.current_wp
        if wp>=len(WAYPOINTS)-1: self._end_game(); return
        nwp=WAYPOINTS[wp+1]

        # Current location header
        cur=WAYPOINTS[wp]
        loc_frame=tk.Frame(self.action_frame,bg=C["bg2"]); loc_frame.pack(fill="x",padx=0,pady=(0,3))
        tk.Label(loc_frame,text=f"  📍 {cur['name']}",font=self.F["subhead"],
                 bg=C["bg2"],fg=C["parch"],pady=5).pack(side="left")
        tk.Label(loc_frame,text=SC[s.season],bg=C["bg2"],
                 font=self.F["tiny"],fg=SC[s.season],padx=8).pack(side="right")

        self._albl(f"▶ NEXT  ·  {nwp['name']}  —  {nwp['desc']}",fg=C["parch2"])
        note={"Winter":"⚠ Winter: heavy health costs, blizzard risk",
              "Spring":"🌱 Spring: Missouri in flood, beware the current",
              "Summer":"☀ Summer: heat, drought, rattlesnakes ahead",
              "Autumn":"🍂 Autumn: early frost in the mountain passes"}.get(s.season,"")
        if note: self._albl(note,fg=SC[s.season])
        self._adiv()

        # Route cards
        for route in ROUTE_OPTIONS.get((wp,wp+1),[]):
            self._route_card(route,self._travel)

        # ── RPG Action Bar ────────────────────────────────────────────────
        self._adiv()
        self._albl("ACTIONS AT CAMP:",fg=C["dim2"],font=self.F["tiny"])

        # Trade council if tribe present
        tk_key=TRIBE_AT_WAYPOINT.get(wp)
        if tk_key:
            tribe=TRIBES[tk_key]; rel=s.tribe_relations.get(tk_key,50)
            rt="Friendly" if rel>=60 else "Neutral" if rel>=40 else "Tense"
            rel_col=C["green2"] if rel>=60 else C["gold"] if rel>=40 else C["red2"]
            self._abtn(f"🤝 Council — {tribe['name']} Nation",
                       lambda k=tk_key:self._trade_screen(k),color=rel_col,
                       sub=f"Relations: {rt}  ({rel}/100)  ·  Click to open trade")

        # Hunting — better with Drouillard
        hunt_sub = "Drouillard leads (+15 food)" if s.characters.get("drouillard",{}).get("active") else "3–4 hrs, +8–18 food, risk of injury"
        self._abtn("🦌 Send Hunting Party",self._go_hunting,color=C["green2"],sub=hunt_sub)

        # Scout ahead — Drouillard only
        if s.characters.get("drouillard",{}).get("active"):
            self._abtn("⬟ Scout Ahead (Drouillard)",self._go_scouting,color=C["amber"],
                       sub="Reveals next event · costs 1 day food")
        # Make camp
        self._abtn("🏕 Make Camp — rest 3 days",self._make_camp,color=C["blue2"],
                   sub="+10 health, +8 morale, −10 food · may trigger camp event")
        # Inventory
        self._abtn("🎒 Expedition Inventory",self._show_inventory,color=C["dim2"])

    def _travel(self,route):
        SFX["travel"]()
        s=self.state; s.route_taken.append(route["name"]); s.current_wp+=1
        s.advance_date(route.get("days",14))
        s.food+=route["food"]; s.health+=route["health"]; s.morale+=route["morale"]
        mods={"Winter":{"health":-8,"food":-5},"Summer":{"food":-4,"morale":2},"Autumn":{"health":-3},"Spring":{"morale":3}}
        for k,v in mods.get(s.season,{}).items(): setattr(s,k,getattr(s,k)+v)
        # Route-type specific character bonuses
        if route.get("tag")=="mountain" and s.characters.get("sacagawea",{}).get("active"): s.health+=8
        wp2=WAYPOINTS[s.current_wp]
        s.add_journal(f"Arrived at {wp2['name']} via {route['name']}. The {s.season.lower()} shapes our progress.")
        s.clamp(); event=self._pick_event()
        if event:
            if s.characters.get("drouillard",{}).get("active") and random.random()<0.45:
                self._show_event_preview(event)
            else:
                self.pending_event=event; self._show_event(event)
        else:
            self._refresh(); self._show_travel_actions()

    def _make_camp(self):
        s=self.state
        s.health=min(100,s.health+10); s.morale=min(100,s.morale+8); s.food=max(0,s.food-10)
        s.advance_date(3)
        s.add_journal("We made camp for three days — rested, repaired equipment, and restored spirits.")
        s.clamp()
        # 40% chance of a camp event
        if random.random()<0.40:
            camp_events=[
                {"title":"Wolves at the Perimeter","text":"Wolves circled camp all night. The men slept poorly.","food":0,"health":-4,"morale":-8},
                {"title":"Seaman's Heroics","text":"Lewis's dog Seaman barked an alarm, saving the corps from a buffalo stampede.","food":5,"health":5,"morale":12},
                {"title":"Private Cruzatte's Fiddle","text":"Cruzatte played the fiddle long into the night. The men danced. Spirits soared.","food":0,"health":3,"morale":18},
                {"title":"Illness in Camp","text":"Several men awoke with fever. Clark administered medicines.","food":-5,"health":-12,"morale":-8},
                {"title":"Remarkable Meteor Shower","text":"A display of shooting stars lasted for hours. The corps watched in silent wonder.","food":0,"health":2,"morale":15},
                {"title":"Local Tribes Visit","text":"A small band of curious natives visited camp. Friendly exchange of gifts.","food":8,"health":0,"morale":10},
                {"title":"Equipment Repairs","text":"The blacksmith spent two days repairing tools and weapons. Everything is ready.","food":-3,"health":2,"morale":6},
            ]
            evt=random.choice(camp_events)
            s.food=max(0,min(100,s.food+evt["food"]))
            s.health=max(0,min(100,s.health+evt["health"]))
            s.morale=max(0,min(100,s.morale+evt["morale"]))
            s.add_journal(f"Camp event — {evt['title']}: {evt['text']}")
        self._refresh(); self._show_travel_actions()

    def _go_hunting(self):
        s=self.state
        has_drouillard=s.characters.get("drouillard",{}).get("active",False)
        roll=random.random()
        s.advance_date(1)
        if roll<0.15:
            # Bad hunt — injury
            dmg=random.randint(8,18)
            s.health=max(0,s.health-dmg); s.food=max(0,s.food-3)
            s.add_journal(f"Hunting accident — a man took a bad fall. Lost {dmg} health, game spooked.")
        elif roll<0.45:
            # Poor hunt
            gain=random.randint(5,12)+( 8 if has_drouillard else 0)
            s.food=min(100,s.food+gain); s.morale=min(100,s.morale+2)
            s.add_journal(f"Modest hunt: +{gain} food. The country is lean here.")
        elif roll<0.80:
            # Good hunt
            gain=random.randint(12,22)+( 12 if has_drouillard else 0)
            s.food=min(100,s.food+gain); s.morale=min(100,s.morale+6)
            leader="Drouillard" if has_drouillard else "the hunters"
            s.add_journal(f"Good hunt led by {leader}: +{gain} food. Several elk and deer brought in.")
        else:
            # Exceptional hunt
            gain=random.randint(22,35)+( 15 if has_drouillard else 0)
            s.food=min(100,s.food+gain); s.morale=min(100,s.morale+14)
            leader="Drouillard" if has_drouillard else "Colter"
            s.add_journal(f"Exceptional hunt — {leader} at his finest: +{gain} food. The corps feasts.")
        s.clamp(); self._refresh(); self._show_travel_actions()

    def _go_scouting(self):
        s=self.state
        s.food=max(0,s.food-4); s.advance_date(1)
        event=self._pick_event()
        if event:
            s.add_journal(f"Drouillard scouts ahead and reports: {event['title']}. We know what lies ahead.")
            self._show_event_preview(event)
        else:
            s.add_journal("Drouillard scouts ahead. The way is clear for now.")
            self._refresh(); self._show_travel_actions()

    def _pick_event(self):
        s=self.state; season=s.season
        eligible=[e for e in EVENTS if e["id"] not in s.events_seen or random.random()<0.28]
        pool=[e for e in eligible if not e.get("season") or season in e["season"]]
        if not pool: pool=EVENTS
        event=random.choice(pool)
        if event["id"] not in s.events_seen: s.events_seen.append(event["id"])
        return event

    def _show_event_preview(self,event):
        self._clear_actions()
        self._albl("⬟  DROUILLARD SCOUTS AHEAD",fg=C["amber"],font=self.F["subhead"])
        self._albl(f"He reports: {event['symbol']}  {event['title']}",fg=C["parch"],font=self.F["body"])
        self._albl("You know what lies ahead. Prepare your response carefully.",fg=C["dim2"])
        self._adiv()
        self._abtn("Advance and face the encounter →",lambda:[setattr(self,'pending_event',event),self._show_event(event)],color=C["gold"])

    def _show_event(self,event):
        SFX["event"]()
        self._clear_actions(); chars=self._active_chars()

        # ── Type color and icon ───────────────────────────────────────────
        TYPE_STYLE = {
            "wildlife":  (C["green2"],  "#0e2a14", "WILDLIFE"),
            "weather":   (C["blue2"],   "#0a1e2c", "WEATHER"),
            "diplomacy": (C["teal2"],   "#0a201c", "DIPLOMACY"),
            "hardship":  (C["amber"],   "#2a1a04", "HARDSHIP"),
            "illness":   (C["red2"],    "#2a0a0a", "ILLNESS"),
            "discovery": (C["gold"],    "#2a1e04", "DISCOVERY"),
        }
        fg_col, bg_col, type_lbl = TYPE_STYLE.get(event.get("type",""), (C["dim2"], C["bg2"], "EVENT"))

        # ── Illustrated event header card ─────────────────────────────────
        card = tk.Canvas(self.action_frame, width=360, height=72,
                         bg=bg_col, highlightthickness=1,
                         highlightbackground=fg_col)
        card.pack(fill="x", padx=0, pady=(0,4))

        # Draw scene sketch inside card
        self._draw_event_sketch(card, event, 360, 72, fg_col)

        # Type badge
        badge_w = len(type_lbl)*7+16
        card.create_rectangle(360-badge_w-4, 4, 360-4, 22,
                              fill=fg_col, outline="")
        card.create_text(360-badge_w//2-4, 13, text=type_lbl,
                         font=self.F["tiny"], fill=C["ink"], anchor="center")
        # Symbol + title
        card.create_text(10, 36, text=event["symbol"],
                         font=self.F["header"], fill=fg_col, anchor="w")
        card.create_text(40, 29, text=event["title"],
                         font=self.F["subhead"], fill=C["parch"], anchor="w")
        # Intro text (truncated)
        intro_short = event["intro"][:90]+"…" if len(event["intro"])>90 else event["intro"]
        card.create_text(40, 48, text=intro_short,
                         font=self.F["tiny"], fill=C["parch3"], anchor="nw",
                         width=312, justify="left")

        self._albl("— Choose your response —", fg=C["dim2"])

        # ── Choices ───────────────────────────────────────────────────────
        for i,choice in enumerate(event["choices"]):
            req = choice.get("requires_char"); has = chars.get(req,True) if req else True
            eff = choice.get("effect",{})
            effs = [f"{'+'if v>0 else ''}{v} {k.capitalize()}"
                    for k,v in eff.items() if isinstance(v,(int,float)) and v]
            sub_text = "  ".join(effs) if effs else None

            if req and not has:
                char_name = SPECIAL_CHARACTERS[req]["name"]
                self._abtn(f"🔒 [{char_name} required]  {choice['label']}",
                           lambda:None, color=C["dim"], disabled=True)
            elif req and has:
                self._abtn(choice["label"],
                           lambda idx=i: self._resolve_event(idx),
                           color=C["amber"], star=True, sub=sub_text)
            else:
                net = sum(v for v in eff.values() if isinstance(v,(int,float)))
                ec = C["green2"] if net>5 else C["red2"] if net<-15 else C["gold"]
                self._abtn(choice["label"],
                           lambda idx=i: self._resolve_event(idx),
                           color=ec, sub=sub_text)

    def _draw_event_sketch(self, canvas, event, W, H, accent):
        """Quick illustrative sketch inside event card based on event type."""
        t = math.sin(self._summary_frame*0.08 if hasattr(self,'_summary_frame') else 0)
        etype = event.get("type","")
        # Right-side mini illustration (40px wide strip)
        ix = W-52
        if etype == "wildlife":
            # Animal silhouette
            canvas.create_oval(ix,H//2-14,ix+28,H//2+14,fill=C["land2"],outline="")
            canvas.create_oval(ix+22,H//2-18,ix+34,H//2-6,fill=C["land2"],outline="")
            # Legs
            for lx in [ix+4,ix+10,ix+18,ix+24]:
                canvas.create_line(lx,H//2+14,lx,H//2+26,fill=C["land2"],width=3)
        elif etype == "weather":
            # Cloud
            for cx2,cy2,cr2 in [(ix+10,H//2-8,10),(ix+22,H//2-12,12),(ix+34,H//2-8,9)]:
                canvas.create_oval(cx2-cr2,cy2-cr2//2,cx2+cr2,cy2+cr2//2,fill="#1a2838",outline="")
            # Rain lines
            for rx in range(ix+4,ix+44,8):
                canvas.create_line(rx,H//2+4,rx-4,H//2+20,fill=C["blue2"],width=1)
        elif etype == "diplomacy":
            # Two figures facing each other
            for fx,fc in [(ix+8,C["parch3"]),(ix+32,C["gold"])]:
                canvas.create_oval(fx-5,H//2-18,fx+5,H//2-8,fill=fc,outline="")
                canvas.create_rectangle(fx-7,H//2-8,fx+7,H//2+10,fill=fc,outline="")
            # Peace pipe between them
            canvas.create_line(ix+14,H//2-4,ix+26,H//2-4,fill=C["amber"],width=3)
        elif etype == "hardship":
            # Mountain silhouette
            canvas.create_polygon(ix,H-4,ix+20,H//2-8,ix+40,H-4,fill=C["mtn"],outline="")
            canvas.create_polygon(ix+12,H//2+2,ix+20,H//2-8,ix+28,H//2+2,fill=C["snow"],outline="")
        elif etype == "illness":
            # Cross symbol
            canvas.create_rectangle(ix+14,H//2-18,ix+20,H//2+14,fill=C["red2"],outline="")
            canvas.create_rectangle(ix+6,H//2-8,ix+28,H//2-2,fill=C["red2"],outline="")
        elif etype == "discovery":
            # Starburst
            for ang in range(0,360,45):
                rx = ix+20+math.cos(math.radians(ang))*14
                ry = H//2+math.sin(math.radians(ang))*14
                canvas.create_line(ix+20,H//2,rx,ry,fill=accent,width=2)
            canvas.create_oval(ix+14,H//2-6,ix+26,H//2+6,fill=accent,outline="")

    def _resolve_event(self,choice_idx):
        event=self.pending_event
        if not event: return
        choice=event["choices"][choice_idx]; s=self.state
        s.apply_effect(choice.get("effect",{}),self._active_chars())
        # Sound feedback
        eff=choice.get("effect",{})
        net=eff.get("food",0)+eff.get("health",0)+eff.get("morale",0)
        if choice.get("discovery") or event.get("type")=="discovery": SFX["discovery"]()
        elif net>=10: SFX["good"]()
        elif net<=-20: SFX["bad"]()
        else: SFX["click"]()
        rb=choice.get("relation_bonus",0) or event.get("relation_bonus",0)
        if rb:
            tk_key=TRIBE_AT_WAYPOINT.get(s.current_wp)
            if tk_key: s.tribe_relations[tk_key]=min(100,s.tribe_relations.get(tk_key,50)+rb)
        if choice.get("discovery") or event.get("type")=="discovery": s.discoveries+=1
        for item,qty in choice.get("inventory_gain",{}).items(): s.inventory[item]=s.inventory.get(item,0)+qty
        s.add_journal(f"{event['title']}: {choice['text']}")
        self.pending_event=None; s.clamp()
        if s.food<=0: s.add_journal("The corps has starved."); self._end_game(failure="starvation"); return
        if s.health<=0: s.add_journal("Too many men lost."); self._end_game(failure="illness"); return
        self._refresh(); self._show_travel_actions()

    # ══════════════════════════════════════════════════════════════════════════
    #  TRADE / COUNCIL
    # ══════════════════════════════════════════════════════════════════════════
    def _trade_screen(self,tribe_key):
        SFX["trade"]()
        self._clear_actions(); s=self.state; tribe=TRIBES[tribe_key]
        rel=s.tribe_relations.get(tribe_key,50); chars=self._active_chars()
        er=min(100,rel+(20 if chars.get("sacagawea") else 0)+(10 if chars.get("york") else 0))
        rc=C["green2"] if er>=60 else C["parch2"] if er>=40 else C["red2"]
        rt="Friendly" if er>=60 else "Neutral" if er>=40 else "Tense"

        # ── Council header ────────────────────────────────────────────────
        hdr=tk.Frame(self.action_frame,bg=C["teal"],); hdr.pack(fill="x",pady=(0,4))
        tk.Label(hdr,text=f"  🤝  {tribe['name']} Nation",font=self.F["subhead"],
                 bg=C["teal"],fg=C["parch"],pady=6).pack(side="left")
        # Relation dial
        rel_bar_w=80; rel_fill=int(rel_bar_w*er/100)
        rframe=tk.Frame(hdr,bg=C["teal"]); rframe.pack(side="right",padx=8,pady=6)
        tk.Label(rframe,text=f"{rt}",font=self.F["tiny"],bg=C["teal"],fg=rc).pack(anchor="e")
        rb_bg=tk.Frame(rframe,bg=C["bg2"],width=rel_bar_w,height=6); rb_bg.pack(anchor="e")
        rb_fill=tk.Frame(rb_bg,bg=rc,height=6,width=rel_fill); rb_fill.place(x=0,y=0)

        # Character bonuses
        if chars.get("sacagawea"):
            self._albl("★ Sacagawea translates — +20 to all relations",fg=C["amber"])
        if chars.get("york"):
            self._albl("◆ York's presence — +10 to all relations",fg=C["amber"])

        # ── Visual goods grid ─────────────────────────────────────────────
        goods_frame=tk.Frame(self.action_frame,bg=C["card"]); goods_frame.pack(fill="x",padx=4,pady=4)

        # They want
        want_lbl=tk.Frame(goods_frame,bg=C["card"]); want_lbl.pack(fill="x",padx=6,pady=(4,0))
        tk.Label(want_lbl,text="They desire:",font=self.F["tiny"],bg=C["card"],fg=C["dim2"]).pack(side="left")
        want_grid=tk.Frame(goods_frame,bg=C["card"]); want_grid.pack(fill="x",padx=6,pady=(0,4))
        for gi,good in enumerate(tribe["wants"]):
            have=s.inventory.get(good,0)
            g_frame=tk.Frame(want_grid,bg=C["card2"] if have>0 else C["bg2"],
                             padx=6,pady=3,relief="flat")
            g_frame.grid(row=0,column=gi,padx=2,sticky="ew")
            tk.Label(g_frame,text=good,font=self.F["tiny"],bg=g_frame["bg"],
                     fg=C["parch"] if have>0 else C["dim2"]).pack(anchor="w")
            tk.Label(g_frame,text=f"×{have}",font=self.F["subhead"],bg=g_frame["bg"],
                     fg=C["gold"] if have>0 else C["red2"]).pack(anchor="w")

        # They offer
        offer_lbl=tk.Frame(goods_frame,bg=C["card"]); offer_lbl.pack(fill="x",padx=6)
        tk.Label(offer_lbl,text="They offer:",font=self.F["tiny"],bg=C["card"],fg=C["dim2"]).pack(side="left")
        offer_grid=tk.Frame(goods_frame,bg=C["card"]); offer_grid.pack(fill="x",padx=6,pady=(0,6))
        for gi,good in enumerate(tribe["offers"]):
            g_frame=tk.Frame(offer_grid,bg=C["teal"],padx=6,pady=3)
            g_frame.grid(row=0,column=gi,padx=2,sticky="ew")
            tk.Label(g_frame,text=good,font=self.F["tiny"],bg=C["teal"],fg=C["parch2"]).pack()

        self._adiv()
        # Actions
        if chars.get("sacagawea") and SPECIAL_CHARACTERS["sacagawea"]["abilities"]["language"].get("unlock_trade"):
            self._abtn("★ Sacagawea negotiates in their tongue",
                       lambda k=tribe_key:self._resolve_trade("sacagawea_speak",k),
                       color=C["amber"],star=True,sub="Best possible outcome — full trust established")

        can_gifts=s.inventory.get("Tobacco",0)+s.inventory.get("Trade Beads",0)>=3
        can_medal=s.inventory.get("Jefferson Medals",0)>=1
        for lbl,act,col,dis in [
            ("Offer Gifts  (Tobacco / Beads)","gifts",C["blue2"],not can_gifts),
            ("Trade for their goods","goods",C["green2"],False),
            ("Present a Jefferson Peace Medal","medal",C["gold"],not can_medal),
            ("Share route maps & knowledge","maps",C["teal2"],False),
            ("Decline and continue the march","leave",C["dim2"],False),
        ]:
            self._abtn(lbl,lambda a=act,k=tribe_key:self._resolve_trade(a,k),color=col,disabled=dis)

    def _resolve_trade(self,action,tribe_key):
        s=self.state; tribe=TRIBES[tribe_key]; rel=s.tribe_relations.get(tribe_key,50)
        if action=="sacagawea_speak":
            s.tribe_relations[tribe_key]=min(100,rel+30)
            if tribe["offers"]: g=tribe["offers"][0]; s.inventory[g]=s.inventory.get(g,0)+2; s.add_journal(f"Sacagawea negotiated with the {tribe['name']}. They gave us {g}.")
            s.morale=min(100,s.morale+15)
        elif action=="gifts":
            for g in ["Tobacco","Trade Beads"]:
                if s.inventory.get(g,0)>=2: s.inventory[g]-=2; break
            s.tribe_relations[tribe_key]=min(100,rel+15); s.add_journal(f"We presented gifts to the {tribe['name']}."); s.morale=min(100,s.morale+5)
        elif action=="goods":
            for w2 in tribe["wants"]:
                if s.inventory.get(w2,0)>=1: s.inventory[w2]-=1; break
            if tribe["offers"]: g=random.choice(tribe["offers"]); s.inventory[g]=s.inventory.get(g,0)+1
            s.tribe_relations[tribe_key]=min(100,rel+10)
            if any(o in ["Corn","Dried Meat","Salmon"] for o in tribe["offers"]): s.food=min(100,s.food+15)
            s.add_journal(f"We traded goods with the {tribe['name']}.")
        elif action=="medal":
            s.inventory["Jefferson Medals"]-=1; s.tribe_relations[tribe_key]=min(100,rel+25)
            s.add_journal(f"We presented a Jefferson Medal to the {tribe['name']} chief."); s.morale=min(100,s.morale+10)
        elif action=="maps":
            s.tribe_relations[tribe_key]=min(100,rel+20)
            if "Maps" in " ".join(tribe["offers"]): s.inventory["Mountain Maps"]=s.inventory.get("Mountain Maps",0)+1
            s.add_journal(f"We shared maps with the {tribe['name']}."); s.morale=min(100,s.morale+5)
        elif action=="leave":
            s.add_journal(f"We passed the {tribe['name']} without council.")
        if action!="leave" and s.tribe_relations.get(tribe_key,0)>=60 and tribe_key not in s.traded_tribes:
            s.traded_tribes.append(tribe_key); s.peaceful_tribes+=1
        s.clamp(); self._refresh(); self._show_travel_actions()

    # ══════════════════════════════════════════════════════════════════════════
    #  POPUPS
    # ══════════════════════════════════════════════════════════════════════════
    def _show_inventory(self):
        SFX["click"]()
        win=tk.Toplevel(self.root); win.title("Expedition Inventory"); win.configure(bg=C["bg"])
        win.geometry("560x620"); win.resizable(False,False); win.grab_set()

        # Header
        tk.Frame(win,bg=C["gold"],height=2).pack(fill="x")
        hdr=tk.Frame(win,bg=C["bg2"]); hdr.pack(fill="x")
        tk.Label(hdr,text="🎒  CORPS INVENTORY",font=self.F["header"],bg=C["bg2"],fg=C["gold"],pady=8).pack(side="left",padx=14)
        inv=self.state.inventory
        total=sum(TRADE_GOOD_VALUES.get(k,1)*v for k,v in inv.items() if v>0)
        tk.Label(hdr,text=f"Total Value: {total}",font=self.F["subhead"],bg=C["bg2"],fg=C["amber"],padx=14).pack(side="right",pady=8)
        tk.Frame(win,bg=C["border"],height=1).pack(fill="x")

        # Wealth meter
        meter_frame=tk.Frame(win,bg=C["bg3"],padx=14,pady=6); meter_frame.pack(fill="x")
        tk.Label(meter_frame,text="EXPEDITION WEALTH",font=self.F["tiny"],bg=C["bg3"],fg=C["dim2"]).pack(anchor="w")
        max_val=120
        bar_bg=tk.Frame(meter_frame,bg=C["bg2"],height=8,width=520); bar_bg.pack(anchor="w",pady=2)
        fill_w=min(520,int(520*total/max_val))
        bar_col=C["gold2"] if total>60 else C["gold"] if total>30 else C["amber"]
        tk.Frame(bar_bg,bg=bar_col,height=8,width=fill_w).place(x=0,y=0)
        for marker in [30,60,90]:
            mx=int(520*marker/max_val)
            tk.Frame(bar_bg,bg=C["bg"],width=1,height=8).place(x=mx,y=0)

        # Scrollable content
        outer=tk.Frame(win,bg=C["bg"]); outer.pack(fill="both",expand=True,padx=10,pady=6)

        CAT_ICONS = {
            "Trade Beads":"○","Tobacco":"~","Whiskey":"▽","Iron Tools":"⚒",
            "Mirrors":"◇","Jefferson Medals":"☆","Gunpowder":"✦","Cloth Bolts":"≋",
            "Corn":"◉","Dried Meat":"▲","Buffalo Hides":"◈","Horses":"↑",
            "Canoes":"⌂","Salmon":"~","Furs":"◎","Mountain Maps":"⊞","Medicinal Herbs":"✿",
        }

        for cat,items in [
            ("⚔  Trade Goods",["Trade Beads","Tobacco","Whiskey","Iron Tools","Mirrors","Jefferson Medals","Gunpowder","Cloth Bolts"]),
            ("🌿  Acquired",   ["Corn","Dried Meat","Buffalo Hides","Horses","Canoes","Salmon","Furs","Mountain Maps","Medicinal Herbs"]),
        ]:
            tk.Label(outer,text=cat,font=self.F["subhead"],bg=C["bg"],fg=C["parch3"],anchor="w").pack(fill="x",pady=(8,4))
            grid=tk.Frame(outer,bg=C["bg"]); grid.pack(fill="x")
            cols=4
            for gi,item in enumerate(items):
                qty=inv.get(item,0); val=TRADE_GOOD_VALUES.get(item,1)
                has=qty>0
                card=tk.Frame(grid,bg=C["card"] if has else C["bg3"],
                              width=124,height=58,relief="flat")
                card.grid(row=gi//cols,column=gi%cols,padx=2,pady=2,sticky="nsew")
                card.pack_propagate(False)
                # Icon + name row
                top=tk.Frame(card,bg=card["bg"]); top.pack(fill="x",padx=6,pady=(4,0))
                icon=CAT_ICONS.get(item,"·")
                tk.Label(top,text=icon,font=self.F["body"],bg=card["bg"],
                         fg=C["gold"] if has else C["dim"]).pack(side="left")
                tk.Label(top,text=item,font=self.F["tiny"],bg=card["bg"],
                         fg=C["parch2"] if has else C["dim2"],
                         wraplength=90,anchor="w").pack(side="left",padx=2)
                # Qty + value row
                bot=tk.Frame(card,bg=card["bg"]); bot.pack(fill="x",padx=6)
                qty_col=C["gold2"] if qty>3 else C["gold"] if qty>0 else C["dim2"]
                tk.Label(bot,text=f"×{qty}",font=self.F["header"],bg=card["bg"],fg=qty_col).pack(side="left")
                tk.Label(bot,text=f" val {val}",font=self.F["tiny"],bg=card["bg"],fg=C["dim2"]).pack(side="left")

        tk.Button(win,text="Close",font=self.F["btn"],bg=C["card2"],fg=C["parch2"],
                  activebackground=C["gold"],activeforeground=C["ink"],
                  relief="flat",cursor="hand2",pady=7,command=win.destroy).pack(pady=10)

    def _show_char_detail(self,char_key):
        SFX["click"]()
        base=SPECIAL_CHARACTERS[char_key]; active=self.state.characters[char_key]["active"]
        win=tk.Toplevel(self.root); win.title(base["name"]); win.configure(bg=C["bg"])
        win.geometry("500x520"); win.resizable(False,False); win.grab_set()

        PORTRAITS = {
            "york":       ("#d08030","◆","#2a1a0a"),
            "drouillard": ("#a87840","⬟","#1a1408"),
            "sacagawea":  ("#c09060","★","#2a1808"),
        }
        BIOS = {
            "york": '"His appearance intimidated and astonished the natives; he increased my influence." — William Clark',
            "drouillard": '"He was the best hunter and interpreter in the service." — Meriwether Lewis',
            "sacagawea": '"The wife of Charbonneau was of great service to me as a pilot through this country." — William Clark',
        }
        ABILITY_ICONS = {
            "diplomacy":"🤝","strength":"💪","hunting":"🦌","morale_lift":"♪",
            "mountain_passage":"⛰","tribe_diplomacy":"🤝","foraging":"🌿","language":"🗣",
            "scouting":"👁","sign_lang":"🤲","trapping":"🪤","portage_bonus":"⚒",
        }

        skin_col,sym,cloth_col=PORTRAITS.get(char_key,("#c0a878","◆","#2a1808"))

        # Gold top border
        tk.Frame(win,bg=C["gold"],height=2).pack(fill="x")

        # Hero header — portrait left, info right
        hdr=tk.Frame(win,bg=C["bg2"]); hdr.pack(fill="x")

        # Large drawn portrait
        port_c=tk.Canvas(hdr,width=100,height=110,bg=C["card2"],highlightthickness=0)
        port_c.pack(side="left",padx=12,pady=8)
        self._draw_portrait_large(port_c,skin_col,cloth_col,sym,active)

        inf=tk.Frame(hdr,bg=C["bg2"]); inf.pack(side="left",pady=10,fill="both",expand=True)
        tk.Label(inf,text=base["name"],font=self.F["title"],bg=C["bg2"],fg=C["parch"]).pack(anchor="w")
        tk.Label(inf,text=base["title"],font=self.F["year"],bg=C["bg2"],fg=C["parch3"]).pack(anchor="w",pady=(0,4))
        # Active status with colored indicator
        status_frame=tk.Frame(inf,bg=C["bg2"]); status_frame.pack(anchor="w")
        ind_col=C["green2"] if active else C["dim"]
        tk.Label(status_frame,text="●",font=self.F["small"],bg=C["bg2"],fg=ind_col).pack(side="left")
        st="Active — traveling with the corps" if active else f"Joins at {WAYPOINTS[base['joined_at']]['name']}"
        tk.Label(status_frame,text=st,font=self.F["small"],bg=C["bg2"],fg=ind_col).pack(side="left",padx=4)

        # Historical quote
        quote=BIOS.get(char_key,"")
        if quote:
            q_frame=tk.Frame(inf,bg=C["bg3"],padx=8,pady=4); q_frame.pack(anchor="w",pady=(4,0),fill="x")
            tk.Label(q_frame,text=quote,font=self.F["tiny"],bg=C["bg3"],fg=C["parch3"],
                     wraplength=310,justify="left",slant="italic").pack(anchor="w")

        tk.Frame(win,bg=C["border"],height=1).pack(fill="x",padx=0,pady=0)

        # Description
        body=tk.Frame(win,bg=C["card"],padx=16,pady=10); body.pack(fill="x")
        tk.Label(body,text=base["desc"],font=self.F["body"],bg=C["card"],fg=C["parch2"],
                 wraplength=440,justify="left").pack(anchor="w",pady=(0,8))

        # Abilities grid — each with icon, name, bar, description
        tk.Label(body,text="SPECIAL ABILITIES",font=self.F["subhead"],bg=C["card"],fg=C["parch3"]).pack(anchor="w",pady=(0,4))
        for ab_k,ab in base["abilities"].items():
            ab_row=tk.Frame(body,bg=C["card2"],padx=8,pady=4); ab_row.pack(fill="x",pady=1)
            icon=ABILITY_ICONS.get(ab_k,"◆")
            left=tk.Frame(ab_row,bg=C["card2"],width=130); left.pack(side="left"); left.pack_propagate(False)
            tk.Label(left,text=f"{icon}  {ab_k.replace('_',' ').title()}",
                     font=self.F["small"],bg=C["card2"],
                     fg=C["gold"] if active else C["dim"]).pack(anchor="w")
            tk.Label(ab_row,text=ab["desc"],font=self.F["tiny"],bg=C["card2"],
                     fg=C["parch3"] if active else C["dim2"],wraplength=280,anchor="w").pack(side="left",padx=6)

        tk.Button(win,text="Close",font=self.F["btn"],bg=C["card2"],fg=C["parch2"],
                  activebackground=C["gold"],activeforeground=C["ink"],
                  relief="flat",cursor="hand2",pady=6,command=win.destroy).pack(pady=10)

    def _draw_portrait_large(self,canvas,skin,cloth,sym,active):
        """Larger, more detailed portrait for the character detail window."""
        c=canvas; W,H=100,110
        bg=C["card2"] if active else C["bg2"]; c.configure(bg=bg)
        cx=W//2

        if not active:
            # Greyed out silhouette
            c.create_oval(cx-18,18,cx+18,54,fill=C["dim"],outline="")
            c.create_rectangle(cx-20,54,cx+20,90,fill=C["dim"],outline="")
            c.create_text(cx,H//2,text="NOT YET\nJOINED",font=self.F["tiny"],fill=C["dim2"],anchor="center",justify="center")
            return

        # Body + coat
        c.create_rectangle(cx-22,55,cx+22,92,fill=cloth,outline="")
        # Coat details
        c.create_line(cx,55,cx,82,fill=C["bg"],width=2)  # button line
        for by in range(60,82,10):
            c.create_oval(cx-2,by-2,cx+2,by+2,fill=C["parch3"],outline="")
        # Collar/lapels
        c.create_polygon(cx-22,55,cx-8,55,cx,64,fill=C["bg3"],outline="")
        c.create_polygon(cx+22,55,cx+8,55,cx,64,fill=C["bg3"],outline="")
        # Arms
        c.create_rectangle(cx-30,56,cx-22,85,fill=cloth,outline="")
        c.create_rectangle(cx+22,56,cx+30,85,fill=cloth,outline="")
        # Hands
        c.create_oval(cx-32,82,cx-22,92,fill=skin,outline="")
        c.create_oval(cx+22,82,cx+32,92,fill=skin,outline="")
        # Neck
        c.create_rectangle(cx-6,40,cx+6,56,fill=skin,outline="")
        # Head
        c.create_oval(cx-18,16,cx+18,48,fill=skin,outline="")
        # Eyes
        for ex in [cx-7,cx+7]:
            c.create_oval(ex-3,27,ex+3,33,fill=C["bg"],outline="")
            c.create_oval(ex-2,28,ex+2,32,fill="#1a1008",outline="")
        # Nose
        c.create_line(cx,30,cx-2,38,cx+2,38,fill=skin,width=1,smooth=True)
        # Mouth (slight smile)
        c.create_arc(cx-7,38,cx+7,46,start=200,extent=140,style="arc",outline="#3a2010",width=1)
        # Hat
        brim_y=16
        c.create_rectangle(cx-20,brim_y,cx+20,brim_y+3,fill="#1a1208",outline="")  # brim
        c.create_rectangle(cx-14,brim_y-18,cx+14,brim_y+3,fill="#1a1208",outline="")  # crown
        # Symbol badge bottom
        c.create_rectangle(cx-12,H-16,cx+12,H-2,fill=C["card"],outline=C["bgold"],width=1)
        c.create_text(cx,H-9,text=sym,font=self.F["tiny"],fill=C["gold"],anchor="center")

    # ══════════════════════════════════════════════════════════════════════════
    #  END GAME
    # ══════════════════════════════════════════════════════════════════════════
    def _end_game(self,failure=None):
        self._cancel_anim(); s=self.state; s.game_over=True
        if s.current_wp>=len(WAYPOINTS)-1:
            if s.health>40 and 4 not in s.completed_objectives: s.completed_objectives.append(4)

        score=len(s.completed_objectives)
        iv=sum(TRADE_GOOD_VALUES.get(k,1)*v for k,v in s.inventory.items() if v>0)

        if failure:
            reason={"starvation":"The corps ran out of food in the wilderness.",
                    "illness":"Disease and hardship claimed too many lives."}.get(failure,"The expedition was abandoned.")
            s.add_journal(f"EXPEDITION FAILED: {reason}")
            rating,rating_col,success=("FAILED",C["red2"],False)
        else:
            rt,rc=next(((r,c) for n,c,r in [
                (6,C["gold2"],"LEGENDARY"),(5,C["gold"],"TRIUMPHANT"),
                (3,C["parch2"],"PARTIAL SUCCESS"),(0,C["dim"],"PYRRHIC")] if score>=n),("PYRRHIC",C["dim"]))
            rating,rating_col,success=(rt,rc,True)
            s.add_journal(f"EXPEDITION COMPLETE — {score}/6 objectives. Rating: {rating}.")

        # ── Full-screen summary ────────────────────────────────────────────
        for w in self.root.winfo_children(): w.destroy()
        W,H=self.W,self.H

        self.summary_canvas=tk.Canvas(self.root,width=W,height=H,bg=C["bg"],highlightthickness=0)
        self.summary_canvas.place(x=0,y=0)
        self._summary_frame=0
        self._summary_success=success
        self._summary_rating=rating
        self._summary_rating_col=rating_col
        self._summary_score=score
        self._summary_iv=iv
        self._summary_failure=failure
        self._animate_summary()

        # Overlay buttons
        btn_y=H-62
        tk.Button(self.root,text="⚑  Begin New Expedition",font=self.F["btn_lg"],
                  bg=C["gold"],fg=C["ink"],activebackground=C["gold2"],activeforeground=C["ink"],
                  relief="flat",bd=0,cursor="hand2",padx=22,pady=10,
                  command=self._new_game).place(x=W//2-250,y=btn_y)
        tk.Button(self.root,text="📜  Watch Intro",font=self.F["btn"],
                  bg=C["card2"],fg=C["parch2"],activebackground=C["card"],activeforeground=C["parch"],
                  relief="flat",bd=0,cursor="hand2",padx=14,pady=9,
                  command=self._rewatch_intro).place(x=W//2+60,y=btn_y)
        tk.Button(self.root,text="💾  Save Record",font=self.F["btn"],
                  bg=C["card2"],fg=C["parch2"],activebackground=C["card"],activeforeground=C["parch"],
                  relief="flat",bd=0,cursor="hand2",padx=14,pady=9,
                  command=self._save_game).place(x=W//2+180,y=btn_y)

    def _animate_summary(self):
        if not hasattr(self,'summary_canvas') or not self.summary_canvas.winfo_exists(): return
        c=self.summary_canvas; c.delete("all")
        W,H=self.W,self.H; f=self._summary_frame; t=f*0.02
        s=self.state

        success=self._summary_success
        rating_col=self._summary_rating_col

        # ── Background: twilight or storm depending on outcome ─────────────
        if success:
            # Golden twilight sky
            for i in range(int(H*0.55)):
                frac=i/(H*0.55)
                rr=int(0x18+frac*0x30); gg=int(0x10+frac*0x1e); bb=int(0x06+frac*0x10)
                c.create_line(0,i,W,i,fill=f"#{rr:02x}{gg:02x}{bb:02x}")
            # Sun on horizon
            sun_x=W*0.72; sun_y=int(H*0.46+math.sin(t*0.3)*4)
            for r in range(70,2,-10):
                frac=(70-r)/70
                rr=min(255,int(0xb0*frac+0x28)); gg=min(255,int(0x50*frac+0x0a)); bb=0
                c.create_oval(sun_x-r,sun_y-r,sun_x+r,sun_y+r,fill=f"#{rr:02x}{gg:02x}{bb:02x}",outline="")
        else:
            # Dark storm
            c.create_rectangle(0,0,W,H,fill="#080810",outline="")
            for ci in range(6):
                cloud_x=(ci*220+int(t*25))%(W+200)-100; cloud_y=H*0.15+ci*20; cr=55+ci*12
                dk=int(0x10+math.sin(t+ci)*3)
                c.create_oval(cloud_x-cr,cloud_y-cr//2,cloud_x+cr,cloud_y+cr//2,
                              fill=f"#{dk:02x}{dk:02x}{dk+5:02x}",outline="")

        # Rolling terrain
        for hi,(base,col,amp) in enumerate([(0.55,C["land"],16),(0.65,C["land2"],10),(0.78,C["bg3"],6)]):
            pts=[0,H]
            for rx in range(0,W+8,8):
                ry=H*base+math.sin(rx*0.007+hi+t*0.08)*amp+math.sin(rx*0.02+hi)*6
                pts.extend([rx,int(ry)])
            pts.extend([W,H]); c.create_polygon(pts,fill=col,outline="")

        # River
        rv_y=int(H*0.56)
        for ri in range(16):
            sh=math.sin((rv_y+ri)*0.12+t*1.5)*0.35+0.55
            rr2=min(255,int(0x12+sh*0x1c)); gg2=min(255,int(0x1e+sh*0x10)); bb2=min(255,int(0x28+sh*0x0e))
            c.create_line(0,rv_y+ri,W,rv_y+ri,fill=f"#{rr2:02x}{gg2:02x}{bb2:02x}")

        if success:
            # Ocean at the left — Pacific!
            for oi in range(int(W*0.22)):
                sh2=math.sin(oi*0.03+t*1.8)*0.3+0.6
                rr3=min(255,int(0x0c+sh2*0x18)); gg3=min(255,int(0x20+sh2*0x14)); bb3=min(255,int(0x38+sh2*0x18))
                c.create_line(oi,int(H*0.48),oi,H,fill=f"#{rr3:02x}{gg3:02x}{bb3:02x}")
            c.create_text(W*0.10,H*0.42,text="PACIFIC\nOCEAN",font=self.F["small"],
                          fill=C["water3"],anchor="center",justify="center")

        # ── Central result panel ───────────────────────────────────────────
        px=W//2; py=int(H*0.14)
        # Glow behind panel
        for gi in range(8,0,-1):
            gc=int(0x08+gi*4)
            c.create_oval(px-gi*40,py-gi*20,px+gi*40,py+gi*20+200,
                          fill=f"#{gc:02x}{int(gc*0.6):02x}{int(gc*0.3):02x}",outline="")

        # Panel backdrop
        c.create_rectangle(px-320,py-10,px+320,py+260,fill=C["bg2"],outline=C["bgold"],width=2)
        c.create_line(px-316,py+8,px+316,py+8,fill=C["bgold"],width=1)

        # Rating badge
        badge_text=self._summary_rating
        bw=len(badge_text)*9+24
        c.create_rectangle(px-bw//2,py+4,px+bw//2,py+26,fill=rating_col,outline="")
        c.create_text(px,py+15,text=badge_text,font=self.F["subhead"],fill=C["ink"],anchor="center")

        # Main title
        main_text="THE EXPEDITION IS COMPLETE" if success else "THE EXPEDITION HAS FAILED"
        c.create_text(px+2,py+46,text=main_text,font=self.F["cine"],fill=C["bg"],anchor="center")
        c.create_text(px,  py+44,text=main_text,font=self.F["cine"],fill=C["parch"],anchor="center")

        # Stats grid
        stats=[
            ("Objectives",f"{self._summary_score}/6",rating_col),
            ("Waypoints",f"{s.current_wp}/{len(WAYPOINTS)-1}",C["parch2"]),
            ("Discoveries",str(s.discoveries),C["gold"]),
            ("Trade Value",str(self._summary_iv),C["amber"]),
            ("Tribes Allied",str(s.peaceful_tribes),C["teal2"]),
            ("Final Health",str(s.health),C["green2"] if s.health>50 else C["red2"]),
        ]
        for si,(label,val,col) in enumerate(stats):
            col_i=si%3; row_i=si//3
            bx2=px-260+col_i*180; by2=py+68+row_i*56
            c.create_rectangle(bx2,by2,bx2+160,by2+46,fill=C["card"],outline=C["border"],width=1)
            c.create_text(bx2+80,by2+12,text=label.upper(),font=self.F["tiny"],fill=C["dim2"],anchor="center")
            c.create_text(bx2+80,by2+30,text=val,font=self.F["header"],fill=col,anchor="center")

        # Route summary
        if s.route_taken:
            route_text="Route: "+"  →  ".join(s.route_taken[:4])
            if len(s.route_taken)>4: route_text+="  → ..."
            c.create_text(px,py+186,text=route_text,font=self.F["tiny"],fill=C["dim2"],anchor="center",width=580)

        # Active characters
        active_chars=[v["name"] for k,v in s.characters.items() if v["active"]]
        if active_chars:
            c.create_text(px,py+200,text="Corps: "+"  ·  ".join(active_chars),
                          font=self.F["small"],fill=C["parch3"],anchor="center")

        # Divider
        c.create_line(px-300,py+216,px+300,py+216,fill=C["bgold"],width=1)

        # Quote
        quotes={
            "LEGENDARY": '"The object of your mission is accomplished." — Capt. Lewis',
            "TRIUMPHANT": '"Ocean in view! O! The joy!" — Capt. Clark',
            "PARTIAL SUCCESS": '"We have lived through extraordinary difficulties." — Capt. Lewis',
            "PYRRHIC": '"The Missouri is a treacherous river." — Capt. Clark',
            "FAILED": '"I fear we have reached our limits." — Capt. Lewis',
        }
        quote=quotes.get(self._summary_rating,quotes["FAILED"])
        c.create_text(px,py+232,text=quote,font=self.F["year"],fill=C["parch3"],anchor="center",width=560)

        # Film grain
        if f%4<2:
            for _ in range(30):
                gx=random.randint(0,W); gy=random.randint(0,H)
                c.create_rectangle(gx,gy,gx+2,gy+2,fill=C["bg2"],outline="")

        self._summary_frame+=1
        self._cine_anim_id=self.root.after(50,self._animate_summary)

    # ══════════════════════════════════════════════════════════════════════════
    #  SAVE / LOAD
    # ══════════════════════════════════════════════════════════════════════════
    def _save_game(self):
        if not self.state: messagebox.showinfo("Save","No game in progress."); return
        path=filedialog.asksaveasfilename(defaultextension=".json",filetypes=[("Lewis & Clark Save","*.json"),("All Files","*.*")],initialfile="expedition_save.json",title="Save Expedition")
        if not path: return
        try:
            with open(path,"w") as f: json.dump(self.state.to_dict(),f,indent=2)
            messagebox.showinfo("Saved",f"Expedition saved:\n{os.path.basename(path)}")
        except Exception as e: messagebox.showerror("Error",str(e))

    def _load_game(self):
        path=filedialog.askopenfilename(filetypes=[("Lewis & Clark Save","*.json"),("All Files","*.*")],title="Load Expedition")
        if not path: return
        try:
            with open(path,"r") as f: data=json.load(f)
            self._start_game(state=GameState.from_dict(data)); messagebox.showinfo("Loaded","Expedition loaded.")
        except Exception as e: messagebox.showerror("Error",str(e))

    def _new_game(self):
        if messagebox.askyesno("New Expedition","Start over? Progress will be lost."):
            self._cancel_anim(); self._cine_idx=0; self._show_title()

    def _rewatch_intro(self):
        self._cancel_anim(); self._cine_idx=0; self._show_cinematic()


# ═══════════════════════════════════════════════════════════════════════════════
def main():
    root=tk.Tk()
    LewisClarkGame(root)
    root.mainloop()

if __name__=="__main__":
    main()
